+func TestBuildAPIURL_EmptyEndpoint(t *testing.T) {
+	endpoint := ""
+	resourceType := MODEL
+	repoName := "test-repo"
+
+	url, err := buildAPIURL(endpoint, resourceType, repoName)
+
+	assert.NotNil(t, err)
+	assert.Equal(t, "", url)
+	assert.Equal(t, "endpoint, resourceType, and repoName must not be empty", err.Error())
+}
