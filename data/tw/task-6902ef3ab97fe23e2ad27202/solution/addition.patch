+	repoName := "test-repo"
+
+	expectedURL := "https://huggingface.co/api/models/test-repo"
+
+	url, err := buildAPIURL(endpoint, resourceType, repoName)
+
+	assert.Nil(t, err)
+	assert.Equal(t, expectedURL, url)
+}
