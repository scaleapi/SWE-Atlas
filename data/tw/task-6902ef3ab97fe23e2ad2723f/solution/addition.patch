+	firstDisk := erasureDisks[0]
+	secondDisk := erasureDisks[1]
+
+	fileInfos, errs := readAllFileInfo(ctx, erasureDisks, "", bucket, object, "", false, true)
+	fi, err := getLatestFileInfo(ctx, fileInfos, er.defaultParityCount, errs)
