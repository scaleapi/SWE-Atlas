+
+        lb = create_lbuf('12', 'abc')
+        lb2 = self.line_comparison_rewrap(lb, '12', 'abc')
+        self.assertContinued(lb2, False, False)
+
+    def test_rewrap_narrower(self):
+        ' New buffer narrower '
+        lb = create_lbuf('123', 'abcde')
+        lb2 = self.line_comparison_rewrap(lb, '123', 'abc', 'de')
