+// --- Status Removal: JSON serialization ---
+
+func TestInvestigationJSONRoundTripHasNoStatus(t *testing.T) {
+	inv := &Investigation{}
+	inv.Spec.Title = "roundtrip-test"
+	data, err := json.Marshal(inv)
+	if err != nil {
+		t.Fatalf("marshal failed: %v", err)
+	}
+	var raw map[string]interface{}
+	if err := json.Unmarshal(data, &raw); err != nil {
+		t.Fatalf("unmarshal to map failed: %v", err)
+	}
+	if _, exists := raw["status"]; exists {
+		t.Fatal("serialized Investigation should not contain a 'status' key")
+	}
+}
