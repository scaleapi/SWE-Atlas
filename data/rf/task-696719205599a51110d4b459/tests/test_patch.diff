+// --- CUE kind definitions simplified ---
+
+func TestCUEKindDefinitionsAreSimplified(t *testing.T) {
+	for _, file := range []string{"investigation.cue", "investigationindex.cue"} {
+		data, err := os.ReadFile("../../../../kinds/" + file)
+		if err != nil {
+			t.Fatalf("could not read %s: %v", file, err)
+		}
+		content := string(data)
+		if strings.Contains(content, "\tgroup:") || strings.Contains(content, " group:") {
+			t.Errorf("%s should not contain group metadata (should be in manifest)", file)
+		}
+		if strings.Contains(content, "apiResource:") {
+			t.Errorf("%s should not contain apiResource (should be in manifest)", file)
+		}
+		if strings.Contains(content, "\tcurrent:") || strings.Contains(content, " current:") {
+			t.Errorf("%s should not contain current version field", file)
+		}
+	}
+}
