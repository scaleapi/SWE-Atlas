+// --- CUE kind identifiers are version-aware ---
+
+func TestCUEKindIdentifiersAreVersionAware(t *testing.T) {
+	tests := []struct {
+		file     string
+		kindName string
+	}{
+		{"investigation.cue", "investigation"},
+		{"investigationindex.cue", "investigationindex"},
+	}
+	for _, tc := range tests {
+		data, err := os.ReadFile("../../../../kinds/" + tc.file)
+		if err != nil {
+			t.Fatalf("could not read %s: %v", tc.file, err)
+		}
+		lower := strings.ToLower(string(data))
+		pattern := tc.kindName + "v0alpha1"
+		if !strings.Contains(lower, pattern) {
+			t.Errorf("%s should contain a version-aware identifier (e.g., %sv0alpha1)", tc.file, tc.kindName)
+		}
+	}
+}
+
+func TestCUEManifestReferencesVersionAwareKinds(t *testing.T) {
+	data, err := os.ReadFile("../../../../kinds/manifest.cue")
+	if err != nil {
+		t.Fatalf("could not read manifest.cue: %v", err)
+	}
+	lower := strings.ToLower(string(data))
+	if !strings.Contains(lower, "investigationv0alpha1") {
+		t.Fatal("manifest.cue should reference a version-aware Investigation kind identifier")
+	}
+	if !strings.Contains(lower, "investigationindexv0alpha1") {
+		t.Fatal("manifest.cue should reference a version-aware InvestigationIndex kind identifier")
+	}
+}
