+    if (!p) return 0;
+    memset(&tv, 0, sizeof(tv));
+    memset(&dtv, 0, sizeof(dtv));
+    memset(&pq, 0, sizeof(pq));
+    SCMutexInit(&pq.mutex_q, NULL);
+    p->ts.tv_sec = 1;
+    p->ts.tv_usec = 0;
+    uint8_t pkt[] = {
+        0x00, 0x00, 0x81, 0x00,
+        0x00, 0x20, 0x08, 0x00,
+        0x45, 0x00, 0x00, 0x14, 0x00, 0x00, 0x40, 0x00,
+        0x40, 0x11, 0x00, 0x00, 0xc0, 0xa8, 0x01, 0x01,
+        0xc0, 0xa8, 0x01, 0x02
+    };
+    (void)DecodeGRE(&tv, &dtv, p, pkt, sizeof(pkt), &pq);
+    SCMutexDestroy(&pq.mutex_q);
+    PacketFree(p);
+    return 1;
+}
