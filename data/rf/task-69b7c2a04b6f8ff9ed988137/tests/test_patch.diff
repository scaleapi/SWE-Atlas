+static int PacketTunnelPktSetupExists(void)
+{
+    ThreadVars tv;
+    DecodeThreadVars dtv;
+    PacketQueue pq;
+    Packet *parent = PacketGetFromAlloc();
+    if (!parent) return 0;
+    memset(&tv, 0, sizeof(tv));
+    memset(&dtv, 0, sizeof(dtv));
+    memset(&pq, 0, sizeof(pq));
+    SCMutexInit(&pq.mutex_q, NULL);
+    uint8_t raw[] = {0x45, 0};
+    parent->ts.tv_sec = 1;
+    parent->ts.tv_usec = 0;
+    Packet *tp = PacketTunnelPktSetup(&tv, &dtv, parent, raw, 2, IPPROTO_IP, &pq);
+    if (tp) PacketFree(tp);
+    SCMutexDestroy(&pq.mutex_q);
+    PacketFree(parent);
+    return 1;
+}
