+    memset(&dtv, 0, sizeof(dtv));
+    uint8_t raw[] = {0};
+    int ret = DecodeEthernet(&tv, &dtv, p, raw, 1, NULL);
+    PacketFree(p);
+    return (ret == TM_ECODE_OK || ret == TM_ECODE_FAILED);
+}
