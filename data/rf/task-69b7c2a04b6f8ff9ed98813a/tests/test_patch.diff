+#!/usr/bin/env python3
+"""
+Behavioral tests for metrics ingestion performance and streaming reliability.
+
+These tests verify prompt-level behavioral outcomes, not gold.patch specifics.
+A correct alternative implementation that satisfies the same prompt must pass.
+"""
+
+import os
+import re
+import unittest
+
+REPO_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
+
+
+def read_file(relpath):
+    with open(os.path.join(REPO_ROOT, relpath), "r") as f:
+        return f.read()
+
+
+def has_forced_inlining(text):
+    """Check if text contains any form of forced inlining annotation."""
+    return bool(re.search(
+        r"ALWAYS_INLINE|__attribute__\s*\(\s*\(\s*always_inline|__forceinline",
+        text,
+    ))
+
+
+def count_forced_inline_functions(content):
+    """Count how many function definitions use forced inlining."""
+    return len(re.findall(
+        r"(?:ALWAYS_INLINE|__attribute__\s*\(\s*\(\s*always_inline|__forceinline)"
+        r"[^;{]*\w+\s*\([^)]*\)\s*\{",
+        content,
+        re.DOTALL,
+    ))
+
+
+def count_advisory_inline_functions(content):
+    """Count function definitions that still use advisory 'inline' only."""
+    all_inline = re.findall(
+        r"\binline\b[^;{]*\w+\s*\([^)]*\)\s*\{",
+        content,
+        re.DOTALL,
+    )
+    forced = re.findall(
+        r"(?:ALWAYS_INLINE|__attribute__\s*\(\s*\(\s*always_inline|__forceinline)"
+        r"[^;{]*\w+\s*\([^)]*\)\s*\{",
+        content,
+        re.DOTALL,
+    )
+    return len(all_inline) - len(forced)
+
+
+class TestHotPathForcedInlining(unittest.TestCase):
+    """
+    Prompt: "Functions on the hot path should use forced inlining instead of
+    the advisory keyword."
+
+    A valid solution uses any forced-inlining mechanism the codebase provides.
+    We check that hot-path files have the MAJORITY of their inline functions
+    converted, not that specific named functions use a specific macro.
+    """
+
+    def test_page_cache_uses_forced_inlining(self):
+        content = read_file("src/database/engine/cache.c")
+        forced = count_forced_inline_functions(content)
+        self.assertGreaterEqual(
+            forced, 5,
+            "Page cache (cache.c) should have multiple functions using "
+            "forced inlining on the data collection hot path",
+        )
+
+    def test_buffer_header_uses_forced_inlining(self):
+        content = read_file("src/libnetdata/buffer/buffer.h")
+        forced = count_forced_inline_functions(content)
+        advisory = count_advisory_inline_functions(content)
+        self.assertGreater(
+            forced, advisory,
+            "Buffer header should have more forced-inline functions than "
+            "advisory-inline functions on the hot path",
+        )
+
+    def test_buffer_source_uses_forced_inlining(self):
+        content = read_file("src/libnetdata/buffer/buffer.c")
+        self.assertTrue(
+            has_forced_inlining(content),
+            "Buffer source file should use forced inlining for hot-path functions",
+        )
+
+    def test_refcount_helpers_use_forced_inlining(self):
+        content = read_file("src/libnetdata/atomics/refcount.h")
+        forced = count_forced_inline_functions(content)
+        self.assertGreaterEqual(
+            forced, 3,
+            "Reference counting helpers should use forced inlining",
+        )
+
+    def test_pluginsd_parser_uses_forced_inlining(self):
+        content = read_file("src/plugins.d/pluginsd_parser.c")
+        self.assertTrue(
+            has_forced_inlining(content),
+            "Plugin data parser should use forced inlining on the hot path",
+        )
+
+    def test_pluginsd_replication_uses_forced_inlining(self):
+        content = read_file("src/plugins.d/pluginsd_replication.c")
+        self.assertTrue(
+            has_forced_inlining(content),
+            "Plugin replication handlers should use forced inlining",
+        )
+
+    def test_streaming_protocol_uses_forced_inlining(self):
+        content = read_file(
+            "src/streaming/protocol/command-begin-set-end-init.c"
+        )
+        self.assertTrue(
+            has_forced_inlining(content),
+            "Streaming protocol command handlers should use forced inlining",
+        )
+
+    def test_collection_completion_uses_forced_inlining(self):
+        content = read_file("src/database/rrddim-collection.c")
+        self.assertTrue(
+            has_forced_inlining(content),
+            "Metrics collection completion path should use forced inlining",
+        )
+
+    def test_ml_public_interface_uses_forced_inlining(self):
+        content = read_file("src/ml/ml_public.cc")
+        self.assertTrue(
+            has_forced_inlining(content),
+            "ML public interface should use forced inlining for hot-path entries",
+        )
+
+    def test_inlined_number_parsers_use_forced_inlining(self):
+        content = read_file("src/libnetdata/inlined.h")
+        self.assertTrue(
+            has_forced_inlining(content),
+            "Encoded number parsers (inlined.h) should use forced inlining",
+        )
+
+    def test_line_splitter_uses_forced_inlining(self):
+        content = read_file("src/libnetdata/line_splitter/line_splitter.h")
+        self.assertTrue(
+            has_forced_inlining(content),
+            "Line splitter should use forced inlining on the ingestion path",
+        )
+
