@@ -0,0 +1,181 @@
+package lib
+
+import (
+	"reflect"
+	"testing"
+
+	"github.com/sirupsen/logrus"
+	"github.com/stretchr/testify/assert"
+	"github.com/stretchr/testify/require"
+
+	"go.k6.io/k6/metrics"
+)
+
+func TestRootGroupPathConstant(t *testing.T) {
+	t.Parallel()
+	assert.Equal(t, "", RootGroupPath, "RootGroupPath should be an empty string")
+}
+
+func TestNewGroupPath_RootToChild(t *testing.T) {
+	t.Parallel()
+	path, err := NewGroupPath(RootGroupPath, "my group")
+	require.NoError(t, err)
+	assert.Equal(t, "::my group", path)
+}
+
+func TestNewGroupPath_Nested(t *testing.T) {
+	t.Parallel()
+	first, err := NewGroupPath(RootGroupPath, "outer")
+	require.NoError(t, err)
+	second, err := NewGroupPath(first, "inner")
+	require.NoError(t, err)
+	assert.Equal(t, "::outer::inner", second)
+}
+
+func TestNewGroupPath_RejectsGroupSeparator(t *testing.T) {
+	t.Parallel()
+	_, err := NewGroupPath(RootGroupPath, "bad::name")
+	assert.ErrorIs(t, err, ErrNameContainsGroupSeparator)
+}
+
+func TestNewGroupPath_RootToRoot(t *testing.T) {
+	t.Parallel()
+	path, err := NewGroupPath(RootGroupPath, RootGroupPath)
+	require.NoError(t, err)
+	assert.Equal(t, RootGroupPath, path)
+}
+
+func TestGroupSummaryImplementsOutputInterface(t *testing.T) {
+	t.Parallel()
+	outputType := reflect.TypeOf((*interface {
+		Description() string
+		Start() error
+		Stop() error
+		AddMetricSamples([]metrics.SampleContainer)
+	})(nil)).Elem()
+
+	gsType := reflect.TypeOf(&GroupSummary{})
+	assert.True(t, gsType.Implements(outputType),
+		"GroupSummary should implement the output.Output interface")
+}
+
+func TestGroupSummaryBuildsGroupHierarchy(t *testing.T) {
+	t.Parallel()
+	logger := logrus.New()
+	logger.SetLevel(logrus.WarnLevel)
+
+	gs := NewGroupSummary(logger)
+	require.NoError(t, gs.Start())
+
+	registry := metrics.NewRegistry()
+	groupDuration := registry.MustNewMetric("group_duration", metrics.Trend, metrics.Time)
+
+	gs.AddMetricSamples([]metrics.SampleContainer{
+		metrics.Sample{
+			TimeSeries: metrics.TimeSeries{
+				Metric: groupDuration,
+				Tags:   registry.RootTagSet().With("group", "::outer"),
+			},
+		},
+		metrics.Sample{
+			TimeSeries: metrics.TimeSeries{
+				Metric: groupDuration,
+				Tags:   registry.RootTagSet().With("group", "::outer::inner"),
+			},
+		},
+	})
+
+	require.NoError(t, gs.Stop())
+
+	root := gs.Group()
+	require.NotNil(t, root)
+	assert.Equal(t, RootGroupPath, root.Path, "root group should have the root path")
+
+	outerGroup, exists := root.Groups["outer"]
+	require.True(t, exists, "outer group should exist")
+	assert.Equal(t, "outer", outerGroup.Name)
+
+	innerGroup, exists := outerGroup.Groups["inner"]
+	require.True(t, exists, "inner group should exist under outer")
+	assert.Equal(t, "inner", innerGroup.Name)
+}
+
+func TestGroupSummaryTracksCheckPassFail(t *testing.T) {
+	t.Parallel()
+	logger := logrus.New()
+	logger.SetLevel(logrus.WarnLevel)
+
+	gs := NewGroupSummary(logger)
+	require.NoError(t, gs.Start())
+
+	registry := metrics.NewRegistry()
+	checks := registry.MustNewMetric("checks", metrics.Rate)
+
+	gs.AddMetricSamples([]metrics.SampleContainer{
+		metrics.Sample{
+			TimeSeries: metrics.TimeSeries{
+				Metric: checks,
+				Tags:   registry.RootTagSet().With("group", "::mygroup").With("check", "status is 200"),
+			},
+			Value: 1,
+		},
+		metrics.Sample{
+			TimeSeries: metrics.TimeSeries{
+				Metric: checks,
+				Tags:   registry.RootTagSet().With("group", "::mygroup").With("check", "status is 200"),
+			},
+			Value: 0,
+		},
+		metrics.Sample{
+			TimeSeries: metrics.TimeSeries{
+				Metric: checks,
+				Tags:   registry.RootTagSet().With("group", "::mygroup").With("check", "status is 200"),
+			},
+			Value: 1,
+		},
+	})
+
+	require.NoError(t, gs.Stop())
+
+	root := gs.Group()
+	myGroup, exists := root.Groups["mygroup"]
+	require.True(t, exists, "mygroup should exist")
+
+	check, exists := myGroup.Checks["status is 200"]
+	require.True(t, exists, "check 'status is 200' should exist")
+	assert.Equal(t, int64(2), check.Passes, "should have 2 passes")
+	assert.Equal(t, int64(1), check.Fails, "should have 1 fail")
+}
+
+func TestVUStateDoesNotHaveGroupField(t *testing.T) {
+	t.Parallel()
+	rt := reflect.TypeOf(State{})
+	_, found := rt.FieldByName("Group")
+	assert.False(t, found,
+		"State struct should not have a Group field after refactoring")
+}
+
+func TestRunnerInterfaceDoesNotHaveGetDefaultGroup(t *testing.T) {
+	t.Parallel()
+	rt := reflect.TypeOf((*Runner)(nil)).Elem()
+	_, found := rt.MethodByName("GetDefaultGroup")
+	assert.False(t, found,
+		"Runner interface should not have GetDefaultGroup method after refactoring")
+}
+
+func TestTestRunStateHasGroupSummaryField(t *testing.T) {
+	t.Parallel()
+	rt := reflect.TypeOf(TestRunState{})
+	field, found := rt.FieldByName("GroupSummary")
