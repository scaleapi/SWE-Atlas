+          dependencies = ["coverage==6.5"]
+        `,
+        'pyproject.toml',
+      );
+      const hatchDeps = result?.deps.filter(
+        (d) => d.depType === 'tool.hatch.envs.default',
+      );
+      expect(hatchDeps).toEqual([
+        expect.objectContaining({
+          packageName: 'coverage',
+          depType: 'tool.hatch.envs.default',
+          currentValue: '==6.5',
+        }),
+      ]);
+    });
+
+    it('should extract pdm dev-dependencies with depGroup metadata', async () => {
+      const result = await extractPackageFile(
+        codeBlock`
+          [project]
+          name = "test"
+          dependencies = ["requests==1.0"]
+          [tool.pdm.dev-dependencies]
+          test = ["pytest>=7.0"]
+        `,
+        'pyproject.toml',
+      );
+      const pdmDeps = result?.deps.filter(
+        (d) => d.depType === 'tool.pdm.dev-dependencies',
+      );
