+      const result = await extractPackageFile(
+        codeBlock`
+          [project]
+          name = "test"
+          [project.optional-dependencies]
+          dev = ["pytest>=7.0"]
+        `,
+        'pyproject.toml',
+      );
+      const optDeps = result?.deps.filter(
+        (d) => d.depType === 'project.optional-dependencies',
+      );
+      expect(optDeps).toEqual([
+        expect.objectContaining({
+          packageName: 'pytest',
+          depName: 'pytest',
+          managerData: { depGroup: 'dev' },
+        }),
+      ]);
+    });
+
+    it('should extract dependency-groups with depGroup metadata', async () => {
+      const result = await extractPackageFile(
+        codeBlock`
+          [project]
+          name = "test"
+          dependencies = ["requests==2.28.0"]
+          [dependency-groups]
+          test = ["pytest==7.4.0"]
+        `,
+        'pyproject.toml',
+      );
+      const groupDeps = result?.deps.filter(
+        (d) => d.depType === 'dependency-groups',
+      );
+      expect(groupDeps).toEqual([
+        expect.objectContaining({
+          packageName: 'pytest',
+          depName: 'pytest',
+          managerData: { depGroup: 'test' },
+        }),
+      ]);
+    });
+
+    it('should extract build-system.requires dependencies', async () => {
+      const result = await extractPackageFile(
+        codeBlock`
+          [build-system]
+          requires = ["setuptools>=42"]
+          build-backend = "setuptools.build_meta"
+          [project]
+          name = "test"
+          dependencies = ["requests==1.0"]
+        `,
+        'pyproject.toml',
+      );
+      const buildDeps = result?.deps.filter(
+        (d) => d.depType === 'build-system.requires',
+      );
+      expect(buildDeps).toEqual([
+        expect.objectContaining({
+          packageName: 'setuptools',
+          depType: 'build-system.requires',
+        }),
+      ]);
+    });
+
+    it('should skip malformed dependency strings gracefully', async () => {
+      const result = await extractPackageFile(
+        codeBlock`
+          [project]
+          name = "test"
+          dependencies = ["valid-pkg==1.0", ";;;invalid;;;"]
+        `,
+        'pyproject.toml',
+      );
+      expect(result).not.toBeNull();
+      const projDeps = result?.deps.filter(
+        (d) => d.depType === 'project.dependencies',
+      );
+      expect(projDeps).toEqual([
+        expect.objectContaining({
+          packageName: 'valid-pkg',
+          currentValue: '==1.0',
+        }),
+      ]);
+    });
+
+    it('should extract hatch environment dependencies', async () => {
+      const result = await extractPackageFile(
+        codeBlock`
+          [project]
+          name = "test"
