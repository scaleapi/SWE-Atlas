diff --git a/tests/user_settings/test_set_default_mailbox.py b/tests/user_settings/test_set_default_mailbox.py
new file mode 100644
index 00000000..9c55d595
--- /dev/null
+++ b/tests/user_settings/test_set_default_mailbox.py
@@ -0,0 +1,155 @@
+from typing import Optional
+import pytest
+
+from flask import url_for
+
+from app import mailbox_utils, user_settings, config
+from app.db import Session
+from app.models import User, Mailbox
+from tests.utils import create_new_user, random_email, login
+
+
+user: Optional[User] = None
+
+
+def setup_module():
+    global user
+    config.SKIP_MX_LOOKUP_ON_CHECK = True
+    user = create_new_user()
+    user.trial_end = None
+    user.lifetime = True
+    Session.commit()
+
+
+def teardown_module():
+    config.SKIP_MX_LOOKUP_ON_CHECK = False  # noqa: F821
+
+
+def test_set_default_mailbox():
+    other = create_new_user()
+    mailbox = mailbox_utils.create_mailbox(
+        other,
+        random_email(),
+        use_digit_codes=True,
+        send_verification_link=False,
+    )
+    mailbox.verified = True
+    Session.commit()
+    user_settings.set_default_mailbox(other, mailbox.id)
+    other = User.get(other.id)
+    assert other.default_mailbox_id == mailbox.id
+
+
+def test_cannot_set_unverified():
+    mailbox = mailbox_utils.create_mailbox(
+        user,
+        random_email(),
+        use_digit_codes=True,
+        send_verification_link=False,
+    )
+    with pytest.raises(user_settings.CannotSetMailbox):
+        user_settings.set_default_mailbox(user, mailbox.id)
+
+
+def test_cannot_default_other_user_mailbox():
+    other = create_new_user()
+    mailbox = mailbox_utils.create_mailbox(
+        other,
+        random_email(),
+        use_digit_codes=True,
+        send_verification_link=False,
+    )
+    with pytest.raises(user_settings.CannotSetMailbox):
+        user_settings.set_default_mailbox(user, mailbox.id)
+
+
+def test_cannot_set_mailbox_stores_msg():
+    exc = user_settings.CannotSetMailbox("test error message")
+    assert exc.msg == "test error message"
+
+
+def test_set_already_default_mailbox_is_noop():
+    other = create_new_user()
+    mailbox = mailbox_utils.create_mailbox(
+        other,
+        random_email(),
+        use_digit_codes=True,
+        send_verification_link=False,
+    )
+    mailbox.verified = True
+    Session.commit()
+    user_settings.set_default_mailbox(other, mailbox.id)
+    other = User.get(other.id)
+    assert other.default_mailbox_id == mailbox.id
+    result = user_settings.set_default_mailbox(other, mailbox.id)
+    assert result.id == mailbox.id
+    assert other.default_mailbox_id == mailbox.id
+
+
+def test_set_default_mailbox_in_user_settings():
+    assert hasattr(user_settings, "set_default_mailbox")
+    assert callable(user_settings.set_default_mailbox)
+
+
+def test_create_mailbox_log_not_premium():
+    free_user = create_new_user()
+    free_user.lifetime = False
+    free_user.trial_end = None
+    Session.commit()
+    with pytest.raises(mailbox_utils.MailboxError):
+        mailbox_utils.create_mailbox(free_user, random_email())
+
+
+def test_create_mailbox_log_invalid_email():
+    with pytest.raises(mailbox_utils.MailboxError):
+        mailbox_utils.create_mailbox(user, "invalid")
+
+
+def test_create_mailbox_log_email_already_used():
+    email = random_email()
+    mailbox_utils.create_mailbox(
+        user, email, use_digit_codes=True, send_verification_link=False
+    )
+    with pytest.raises(mailbox_utils.MailboxError):
+        mailbox_utils.create_mailbox(user, email)
+
+
+def test_create_mailbox_log_email_cannot_be_used():
+    with pytest.raises(mailbox_utils.MailboxError):
+        mailbox_utils.create_mailbox(user, f"test@sl.local")
+
+
+def test_dashboard_set_default_mailbox(flask_client):
+    dashboard_user = login(flask_client)
+    dashboard_user.trial_end = None
+    dashboard_user.lifetime = True
+    Session.commit()
+    mb = Mailbox.create(
+        user_id=dashboard_user.id, email=random_email(), verified=True, commit=True
+    )
+    r = flask_client.post(
+        url_for("dashboard.mailbox_route"),
+        data={"form-name": "set-default", "mailbox_id": mb.id},
+        follow_redirects=True,
+    )
+    assert r.status_code == 200
+    dashboard_user = User.get(dashboard_user.id)
+    assert dashboard_user.default_mailbox_id == mb.id
+
+
+def test_dashboard_set_default_mailbox_unverified(flask_client):
+    dashboard_user = login(flask_client)
+    dashboard_user.trial_end = None
+    dashboard_user.lifetime = True
+    Session.commit()
+    mb = Mailbox.create(
+        user_id=dashboard_user.id, email=random_email(), verified=False, commit=True
+    )
+    r = flask_client.post(
+        url_for("dashboard.mailbox_route"),
+        data={"form-name": "set-default", "mailbox_id": mb.id},
+        follow_redirects=True,
+    )
+    assert r.status_code == 200
+    dashboard_user = User.get(dashboard_user.id)
+    assert dashboard_user.default_mailbox_id != mb.id
