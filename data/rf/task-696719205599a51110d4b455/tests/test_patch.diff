@@ -0,0 +1,103 @@
+package rvmanager_test
+
+import (
+	"testing"
+
+	"github.com/grafana/grafana/pkg/storage/unified/sql/rvmanager"
+	"github.com/grafana/grafana/pkg/storage/unified/sql/sqltemplate"
+	"github.com/stretchr/testify/assert"
+	"github.com/stretchr/testify/require"
+)
+
+func TestTemplateVariablesAreLoaded(t *testing.T) {
+	assert.NotNil(t, rvmanager.SqlResourceUpdateRV)
+	assert.NotNil(t, rvmanager.SqlResourceHistoryUpdateRV)
+	assert.NotNil(t, rvmanager.SqlResourceVersionGet)
+	assert.NotNil(t, rvmanager.SqlResourceVersionUpdate)
+	assert.NotNil(t, rvmanager.SqlResourceVersionInsert)
+}
+
+func TestSqlResourceUpdateRVRequest_RendersWithTemplate(t *testing.T) {
+	req := rvmanager.SqlResourceUpdateRVRequest{
+		SQLTemplate: sqltemplate.New(sqltemplate.MySQL),
+		GUIDToRV:    map[string]int64{"abc-123": 42},
+	}
+	out, err := sqltemplate.Execute(rvmanager.SqlResourceUpdateRV, req)
+	require.NoError(t, err)
+	assert.NotEmpty(t, out)
+}
+
+func TestSqlResourceUpdateRVRequest_RendersHistoryWithTemplate(t *testing.T) {
+	req := rvmanager.SqlResourceUpdateRVRequest{
+		SQLTemplate:       sqltemplate.New(sqltemplate.MySQL),
+		GUIDToRV:          map[string]int64{"abc-123": 42},
+		GUIDToSnowflakeRV: map[string]int64{"abc-123": 99},
+	}
+	out, err := sqltemplate.Execute(rvmanager.SqlResourceHistoryUpdateRV, req)
+	require.NoError(t, err)
+	assert.NotEmpty(t, out)
+}
+
+func TestSqlResourceVersionGetRequest_RendersWithTemplate(t *testing.T) {
+	req := rvmanager.SqlResourceVersionGetRequest{
+		SQLTemplate: sqltemplate.New(sqltemplate.MySQL),
+		Group:       "test.grafana.app",
+		Resource:    "dashboards",
+		ReadOnly:    false,
+		Response:    &rvmanager.ResourceVersionResponse{},
+	}
+	out, err := sqltemplate.Execute(rvmanager.SqlResourceVersionGet, req)
+	require.NoError(t, err)
+	assert.NotEmpty(t, out)
+}
+
+func TestSqlResourceVersionUpsertRequest_RendersInsertWithTemplate(t *testing.T) {
+	req := rvmanager.SqlResourceVersionUpsertRequest{
+		SQLTemplate:     sqltemplate.New(sqltemplate.MySQL),
+		Group:           "test.grafana.app",
+		Resource:        "dashboards",
+		ResourceVersion: 100,
+	}
+	out, err := sqltemplate.Execute(rvmanager.SqlResourceVersionInsert, req)
+	require.NoError(t, err)
+	assert.NotEmpty(t, out)
+}
+
+func TestSqlResourceVersionUpsertRequest_RendersUpdateWithTemplate(t *testing.T) {
+	req := rvmanager.SqlResourceVersionUpsertRequest{
+		SQLTemplate:     sqltemplate.New(sqltemplate.MySQL),
+		Group:           "test.grafana.app",
+		Resource:        "dashboards",
+		ResourceVersion: 200,
+	}
+	out, err := sqltemplate.Execute(rvmanager.SqlResourceVersionUpdate, req)
+	require.NoError(t, err)
+	assert.NotEmpty(t, out)
+}
+
+func TestResourceVersionResponse_HasExpectedFields(t *testing.T) {
+	resp := &rvmanager.ResourceVersionResponse{
+		ResourceVersion: 42,
+		CurrentEpoch:    1000,
+	}
+	assert.Equal(t, int64(42), resp.ResourceVersion)
+	assert.Equal(t, int64(1000), resp.CurrentEpoch)
+}
+
+func TestTypesWorkAcrossDialects(t *testing.T) {
+	dialects := []sqltemplate.Dialect{
+		sqltemplate.MySQL,
+		sqltemplate.PostgreSQL,
+	}
+	for _, dialect := range dialects {
+		t.Run(dialect.DialectName(), func(t *testing.T) {
+			req := rvmanager.SqlResourceUpdateRVRequest{
+				SQLTemplate: sqltemplate.New(dialect),
+				GUIDToRV:    map[string]int64{"guid-1": 10},
+			}
+			out, err := sqltemplate.Execute(rvmanager.SqlResourceUpdateRV, req)
+			require.NoError(t, err)
+			assert.NotEmpty(t, out)
+		})
+	}
+}
