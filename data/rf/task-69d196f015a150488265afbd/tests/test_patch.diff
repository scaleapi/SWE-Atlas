+		expect( useGenerateActionCallback ).toHaveBeenCalledWith(
+			expect.objectContaining( { redirectTo: '/marketplace/plugin/test/install/test.wordpress.com' } )
+		);
+	} );
+
+	it( 'should not include redirectTo when it is not provided', () => {
+		renderHook( () =>
+			useGenerateActionHook( {
+				isInSignup: false,
+				isLaunchPage: false,
+			} )
