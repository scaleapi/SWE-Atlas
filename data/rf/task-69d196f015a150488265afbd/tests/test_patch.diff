+import { PlanUSPS } from '../usps';
+
+const mockSite = { ID: 123, slug: 'test.wordpress.com' };
+
+describe( 'PlanUSPS', () => {
+	beforeEach( () => {
+		jest.clearAllMocks();
+		( useSelector as jest.Mock ).mockImplementation( ( selector ) => selector( {
+			ui: { selectedSiteId: 123 },
+			sites: { items: { 123: mockSite } },
+			marketplace: { billingInterval: { interval: 'yearly' } },
+			productsList: {},
+		} ) );
+		( getProductDisplayCost as jest.Mock ).mockImplementation( ( state, plan, isMonthly ) => isMonthly ? 'US$4' : 'US$48' );
+	} );
+
+	it( 'should show generic all paid plans text when promotional condition is active for Personal plan', () => {
+		( useIsPluginAvailableOnAllPlans as jest.Mock ).mockReturnValue( true );
+		const { container } = render( <PlanUSPS pluginSlug="test-plugin" shouldUpgrade={ true } isFreePlan={ true } isMarketplaceProduct={ false } isAvailableOnAllPlans={ true } billingPeriod="yearly" /> );
+		expect( container.textContent ).toContain( 'all paid plans' );
+	} );
+
+	it( 'should show plan-specific text when promotional condition is inactive', () => {
+		( useIsPluginAvailableOnAllPlans as jest.Mock ).mockReturnValue( false );
+		const { container } = render( <PlanUSPS pluginSlug="test-plugin" shouldUpgrade={ true } isFreePlan={ true } isMarketplaceProduct={ false } isAvailableOnAllPlans={ false } billingPeriod="yearly" /> );
+		expect( container.textContent ).not.toContain( 'all paid plans' );
+	} );
+
+	it( 'should not apply promotional pricing for marketplace products', () => {
+		( useIsPluginAvailableOnAllPlans as jest.Mock ).mockReturnValue( true );
+		const { container } = render( <PlanUSPS pluginSlug="test-plugin" shouldUpgrade={ true } isFreePlan={ true } isMarketplaceProduct={ true } isAvailableOnAllPlans={ false } billingPeriod="yearly" /> );
+		expect( container.textContent ).not.toContain( 'all paid plans' );
+	} );
+
+	it( 'should not apply promotional pricing for preinstalled premium plugins', () => {
+		( useIsPluginAvailableOnAllPlans as jest.Mock ).mockReturnValue( true );
+		const usePreinstalledPremiumPlugin = require( 'calypso/my-sites/plugins/use-preinstalled-premium-plugin' );
+		usePreinstalledPremiumPlugin.mockReturnValue( { isPreinstalledPremiumPlugin: true } );
+		const { container } = render( <PlanUSPS pluginSlug="test-plugin" shouldUpgrade={ true } isFreePlan={ true } isMarketplaceProduct={ false } isAvailableOnAllPlans={ false } billingPeriod="yearly" /> );
+		expect( container.textContent ).not.toContain( 'all paid plans' );
+		usePreinstalledPremiumPlugin.mockReturnValue( { isPreinstalledPremiumPlugin: false } );
+	} );
+
+	it( 'should return null when shouldUpgrade is false', () => {
+		( useIsPluginAvailableOnAllPlans as jest.Mock ).mockReturnValue( true );
+		const { container } = render( <PlanUSPS pluginSlug="test-plugin" shouldUpgrade={ false } isFreePlan={ true } isMarketplaceProduct={ false } isAvailableOnAllPlans={ true } billingPeriod="yearly" /> );
+		expect( container.innerHTML ).toBe( '' );
+	} );
+
+	it( 'should not show promo text when shouldUpgrade is false even if promo is active', () => {
+		( useIsPluginAvailableOnAllPlans as jest.Mock ).mockReturnValue( true );
+		const { container } = render( <PlanUSPS pluginSlug="test-plugin" shouldUpgrade={ false } isFreePlan={ true } isMarketplaceProduct={ false } isAvailableOnAllPlans={ true } billingPeriod="yearly" /> );
+		expect( container.textContent ).not.toContain( 'all paid plans' );
+	} );
+
+	it( 'should use monthly cost label when promotional condition is active', () => {
+		( useIsPluginAvailableOnAllPlans as jest.Mock ).mockReturnValue( true );
+		const { container } = render( <PlanUSPS pluginSlug="test-plugin" shouldUpgrade={ true } isFreePlan={ true } isMarketplaceProduct={ false } isAvailableOnAllPlans={ true } billingPeriod="yearly" /> );
+		expect( container.textContent ).toContain( 'month' );
+	} );
+
+	it( 'should show generic text for Business plan tier when promotional condition is active', () => {
+		( useIsPluginAvailableOnAllPlans as jest.Mock ).mockReturnValue( true );
+		const config = require( '@automattic/calypso-config' );
+		config.isEnabled.mockReturnValue( false );
+		const { container } = render( <PlanUSPS pluginSlug="test-plugin" shouldUpgrade={ true } isFreePlan={ true } isMarketplaceProduct={ false } isAvailableOnAllPlans={ true } billingPeriod="yearly" /> );
+		expect( container.textContent ).toContain( 'all paid plans' );
+		config.isEnabled.mockReturnValue( true );
+	} );
