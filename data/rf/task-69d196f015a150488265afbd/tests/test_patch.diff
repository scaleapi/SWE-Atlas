+describe( 'useGenerateActionHook - redirectTo interface compliance', () => {
+	beforeEach( () => {
+		jest.resetAllMocks();
+		( useSelector as jest.Mock ).mockImplementation( ( selector ) =>
+			selector( {
+				ui: {},
+				sites: { items: [] },
+				route: { query: { current: { get_domain: null } } },
+			} )
+		);
+		( Plans.useCurrentPlan as jest.Mock ).mockImplementation( () => null );
+	} );
+
+	it( 'should forward redirectTo to useGenerateActionCallback', () => {
+		renderHook( () =>
+			useGenerateActionHook( {
+				isInSignup: false,
+				isLaunchPage: false,
+				redirectTo: '/marketplace/plugin/test/install/test.wordpress.com',
