+func TestOptionsWithoutStrict(t *testing.T) {
+	t.Parallel()
+	c := New(testutils.NewLogger(t))
+	c.Options = Options{
+		CompatibilityMode: lib.CompatibilityModeBase,
+		SourceMapLoader:   nil,
+	}
+	src := `1+(function() { return 2; })()`
+	prg, code, err := c.Parse(src, "test.js", false)
+	require.NoError(t, err)
+	assert.Equal(t, src, code)
+	pgm, err := sobek.CompileAST(prg, true)
+	require.NoError(t, err)
+	v, err := sobek.New().RunProgram(pgm)
+	require.NoError(t, err)
+	assert.Equal(t, int64(3), v.Export())
+}
+
+func TestParseCommonJSWrapBehavior(t *testing.T) {
+	t.Parallel()
+	c := New(testutils.NewLogger(t))
+
+	t.Run("wrapping produces CommonJS module function", func(t *testing.T) {
+		t.Parallel()
+		src := `exports.value = 42`
+		_, code, err := c.Parse(src, "module.js", true)
+		require.NoError(t, err)
+		assert.Contains(t, code, "(function(module, exports){")
+		assert.Contains(t, code, "exports.value = 42")
+	})
+
+	t.Run("no wrapping preserves original source", func(t *testing.T) {
+		t.Parallel()
+		src := `var x = 42`
+		_, code, err := c.Parse(src, "script.js", false)
+		require.NoError(t, err)
+		assert.Equal(t, src, code)
+	})
+}
