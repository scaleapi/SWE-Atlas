+package filesystem
+
+import (
+	"os"
+	"path/filepath"
+	"testing"
+	"time"
+
+	log "github.com/sirupsen/logrus"
+	"google.golang.org/protobuf/types/known/anypb"
+
+	"github.com/trufflesecurity/trufflehog/v3/pkg/context"
+	"github.com/trufflesecurity/trufflehog/v3/pkg/pb/sourcespb"
+	"github.com/trufflesecurity/trufflehog/v3/pkg/sources"
+)
+
+func TestSource_ChunksSendCompleteData(t *testing.T) {
+	tmpDir := t.TempDir()
+	testContent := "this is test content for chunking verification"
+	testFile := filepath.Join(tmpDir, "testfile.txt")
+	if err := os.WriteFile(testFile, []byte(testContent), 0644); err != nil {
+		t.Fatal(err)
+	}
+
+	ctx, cancel := context.WithTimeout(context.Background(), time.Second*5)
+	defer cancel()
+
+	s := Source{}
+	log.SetLevel(log.DebugLevel)
+
+	conn, err := anypb.New(&sourcespb.Filesystem{
+		Directories: []string{tmpDir},
+	})
+	if err != nil {
+		t.Fatal(err)
+	}
+
+	err = s.Init(ctx, "test-fs-source", 0, 0, false, conn, 1)
+	if err != nil {
+		t.Fatal(err)
+	}
+
+	chunksCh := make(chan *sources.Chunk, 10)
+	go func() {
+		if err := s.Chunks(ctx, chunksCh); err != nil {
+			t.Errorf("Chunks() error: %v", err)
+		}
+		close(chunksCh)
+	}()
+
+	var receivedChunks []*sources.Chunk
+	for chunk := range chunksCh {
+		receivedChunks = append(receivedChunks, chunk)
+	}
+
+	if len(receivedChunks) == 0 {
+		t.Fatal("Expected at least one chunk from filesystem source")
+	}
+
+	found := false
+	for _, chunk := range receivedChunks {
+		if chunk.SourceMetadata == nil {
+			t.Error("Chunk missing SourceMetadata")
+			continue
+		}
+		fsMeta := chunk.SourceMetadata.GetFilesystem()
+		if fsMeta == nil {
+			continue
+		}
+		if filepath.Base(fsMeta.GetFile()) == "testfile.txt" {
+			found = true
+			if string(chunk.Data) != testContent {
+				t.Errorf("Chunk data incomplete. Got %d bytes, expected %d bytes", len(chunk.Data), len(testContent))
+			}
+			if chunk.SourceName != "test-fs-source" {
+				t.Errorf("SourceName not set. Got %q", chunk.SourceName)
+			}
+		}
+	}
+
+	if !found {
+		t.Error("Did not receive chunk for testfile.txt")
+	}
+}
