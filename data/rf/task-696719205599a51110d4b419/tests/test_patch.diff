+package sources
+
+import (
+	"bytes"
+	"testing"
+
+	source_metadatapb "github.com/trufflesecurity/trufflehog/v3/pkg/pb/source_metadatapb"
+	"github.com/trufflesecurity/trufflehog/v3/pkg/pb/sourcespb"
+)
+
+func TestChunkerSmallChunkPassthrough(t *testing.T) {
+	smallData := bytes.Repeat([]byte("a"), ChunkSize)
+	original := &Chunk{
+		SourceName: "test-source",
+		SourceID:   42,
+		SourceType: sourcespb.SourceType_SOURCE_TYPE_FILESYSTEM,
+		Data:       smallData,
+		Verify:     true,
+	}
+
+	chunks := make([]*Chunk, 0)
+	for chunk := range Chunker(original) {
+		chunks = append(chunks, chunk)
+	}
+
+	if len(chunks) != 1 {
+		t.Fatalf("Expected 1 chunk for small data, got %d", len(chunks))
+	}
+	if !bytes.Equal(chunks[0].Data, smallData) {
+		t.Errorf("Small chunk data was modified. Got %d bytes, expected %d bytes", len(chunks[0].Data), len(smallData))
+	}
+}
+
+func TestChunkerPreservesMetadata(t *testing.T) {
+	largeData := bytes.Repeat([]byte("x"), ChunkSize*3)
+	metadata := &source_metadatapb.MetaData{
+		Data: &source_metadatapb.MetaData_Filesystem{
+			Filesystem: &source_metadatapb.Filesystem{
+				File: "/test/file.txt",
+			},
+		},
+	}
+	original := &Chunk{
+		SourceName:     "my-source",
+		SourceID:       99,
+		SourceType:     sourcespb.SourceType_SOURCE_TYPE_S3,
+		SourceMetadata: metadata,
+		Data:           largeData,
+		Verify:         true,
+	}
+
+	nonEmptyCount := 0
+	for chunk := range Chunker(original) {
+		if len(chunk.Data) == 0 {
+			continue
+		}
+		nonEmptyCount++
+		if chunk.SourceName != original.SourceName {
+			t.Errorf("SourceName not preserved. Got %q, expected %q", chunk.SourceName, original.SourceName)
+		}
+		if chunk.SourceID != original.SourceID {
+			t.Errorf("SourceID not preserved. Got %d, expected %d", chunk.SourceID, original.SourceID)
+		}
+		if chunk.SourceType != original.SourceType {
+			t.Errorf("SourceType not preserved. Got %v, expected %v", chunk.SourceType, original.SourceType)
+		}
+		if chunk.Verify != original.Verify {
+			t.Errorf("Verify not preserved. Got %v, expected %v", chunk.Verify, original.Verify)
+		}
+		if chunk.SourceMetadata != original.SourceMetadata {
+			t.Errorf("SourceMetadata not preserved")
+		}
+	}
+	if nonEmptyCount == 0 {
+		t.Error("Expected at least one non-empty chunk")
+	}
+}
+
+func TestChunkerEmptyData(t *testing.T) {
+	original := &Chunk{
+		SourceName: "empty-source",
+		Data:       []byte{},
+	}
+
+	chunks := make([]*Chunk, 0)
+	for chunk := range Chunker(original) {
+		chunks = append(chunks, chunk)
+	}
+
+	if len(chunks) != 1 {
+		t.Fatalf("Expected 1 chunk for empty data, got %d", len(chunks))
+	}
+}
+
+func TestChunkerLargeDataSplitsCorrectly(t *testing.T) {
+	largeData := bytes.Repeat([]byte("d"), ChunkSize*5)
+	original := &Chunk{
+		SourceName: "large-source",
+		SourceID:   7,
+		Data:       largeData,
+		Verify:     false,
+	}
+
+	chunks := make([]*Chunk, 0)
+	for chunk := range Chunker(original) {
+		chunks = append(chunks, chunk)
+	}
+
+	if len(chunks) < 2 {
+		t.Fatalf("Expected multiple chunks for large data, got %d", len(chunks))
+	}
+
+	for i, chunk := range chunks {
+		if len(chunk.Data) > ChunkSize+PeekSize {
+			t.Errorf("Chunk %d exceeds max size: got %d, max %d", i, len(chunk.Data), ChunkSize+PeekSize)
+		}
+	}
+}
+
+func TestChunkerConstants(t *testing.T) {
+	if ChunkSize != 10*1024 {
+		t.Errorf("ChunkSize has unexpected value: got %d, expected %d", ChunkSize, 10*1024)
+	}
+	if PeekSize != 3*1024 {
+		t.Errorf("PeekSize has unexpected value: got %d, expected %d", PeekSize, 3*1024)
+	}
+}
+
+func TestChunkerFunctionSignature(t *testing.T) {
+	input := &Chunk{Data: []byte("test")}
+	var result chan *Chunk = Chunker(input)
+	for range result {
+	}
+}
