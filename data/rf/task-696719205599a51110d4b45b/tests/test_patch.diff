@@ -0,0 +1,136 @@
+package es
+
+import (
+	"encoding/json"
+	"testing"
+	"time"
+
+	"github.com/grafana/grafana-plugin-sdk-go/backend"
+	"github.com/grafana/grafana/pkg/components/simplejson"
+	"github.com/stretchr/testify/require"
+)
+
+func newTestSearchRequestBuilder() *SearchRequestBuilder {
+	from := time.Date(2023, 1, 1, 0, 0, 0, 0, time.UTC)
+	to := time.Date(2023, 1, 2, 0, 0, 0, 0, time.UTC)
+	timeRange := backend.TimeRange{From: from, To: to}
+	return NewSearchRequestBuilder(10*time.Second, timeRange)
+}
+
+func TestAggBuilder_GeoHashGrid(t *testing.T) {
+	b := newTestSearchRequestBuilder()
+	b.Agg().GeoHashGrid("1", "location", nil)
+
+	sr, err := b.Build()
+	require.NoError(t, err)
+	require.Len(t, sr.Aggs, 1)
+	require.Equal(t, "1", sr.Aggs[0].Key)
+	require.Equal(t, "geohash_grid", sr.Aggs[0].Aggregation.Type)
+
+	body, err := json.Marshal(sr)
+	require.NoError(t, err)
+	j, err := simplejson.NewJson(body)
+	require.NoError(t, err)
+	require.Equal(t, "location", j.GetPath("aggs", "1", "geohash_grid", "field").MustString())
+	require.Equal(t, DefaultGeoHashPrecision, j.GetPath("aggs", "1", "geohash_grid", "precision").MustInt())
+}
+
+func TestAggBuilder_Nested(t *testing.T) {
+	b := newTestSearchRequestBuilder()
+	b.Agg().Nested("1", "comments", func(a *NestedAggregation, ib AggBuilder) {
+		ib.Metric("2", "avg", "comments.rating", nil)
+	})
+
+	sr, err := b.Build()
+	require.NoError(t, err)
+	require.Len(t, sr.Aggs, 1)
+	require.Equal(t, "1", sr.Aggs[0].Key)
+	require.Equal(t, "nested", sr.Aggs[0].Aggregation.Type)
+	require.Len(t, sr.Aggs[0].Aggregation.Aggs, 1)
+	require.Equal(t, "2", sr.Aggs[0].Aggregation.Aggs[0].Key)
+	require.Equal(t, "avg", sr.Aggs[0].Aggregation.Aggs[0].Aggregation.Type)
+}
+
+func TestAggBuilder_Pipeline(t *testing.T) {
+	b := newTestSearchRequestBuilder()
+	b.Agg().Pipeline("1", "derivative", "the_sum", func(a *PipelineAggregation) {
+		a.Settings["unit"] = "day"
+	})
+
+	sr, err := b.Build()
+	require.NoError(t, err)
+	require.Len(t, sr.Aggs, 1)
+	require.Equal(t, "1", sr.Aggs[0].Key)
+	require.Equal(t, "derivative", sr.Aggs[0].Aggregation.Type)
+
+	body, err := json.Marshal(sr)
+	require.NoError(t, err)
+	j, err := simplejson.NewJson(body)
+	require.NoError(t, err)
+	require.Equal(t, "the_sum", j.GetPath("aggs", "1", "derivative", "buckets_path").MustString())
+	require.Equal(t, "day", j.GetPath("aggs", "1", "derivative", "unit").MustString())
+}
+
+func TestAggBuilder_Metric_WithSettings(t *testing.T) {
+	b := newTestSearchRequestBuilder()
+	b.Agg().Metric("1", "percentiles", "response_time", func(a *MetricAggregation) {
+		a.Settings["percents"] = []float64{25, 50, 75, 95, 99}
+	})
+
+	sr, err := b.Build()
+	require.NoError(t, err)
+	require.Len(t, sr.Aggs, 1)
+	require.Equal(t, "1", sr.Aggs[0].Key)
+	require.Equal(t, "percentiles", sr.Aggs[0].Aggregation.Type)
+
+	body, err := json.Marshal(sr)
+	require.NoError(t, err)
+	j, err := simplejson.NewJson(body)
+	require.NoError(t, err)
+	require.Equal(t, "response_time", j.GetPath("aggs", "1", "percentiles", "field").MustString())
+	percents := j.GetPath("aggs", "1", "percentiles", "percents").MustArray()
+	require.Len(t, percents, 5)
+}
+
+func TestAggBuilder_EmptyBuild(t *testing.T) {
+	b := newTestSearchRequestBuilder()
+	sr, err := b.Build()
+	require.NoError(t, err)
+	require.Nil(t, sr.Aggs)
+}
+
+func TestAggBuilder_TermsOrderReplacement(t *testing.T) {
+	b := newTestSearchRequestBuilder()
+	b.Agg().Terms("1", "status", func(a *TermsAggregation, ib AggBuilder) {
+		a.Order["_term"] = "asc"
+	})
+
+	sr, err := b.Build()
+	require.NoError(t, err)
+	require.Len(t, sr.Aggs, 1)
+
+	body, err := json.Marshal(sr)
+	require.NoError(t, err)
+	j, err := simplejson.NewJson(body)
+	require.NoError(t, err)
+	require.Equal(t, "asc", j.GetPath("aggs", "1", "terms", "order", "_key").MustString())
+
+	orderMap := j.GetPath("aggs", "1", "terms", "order").MustMap()
+	_, hasTermKey := orderMap["_term"]
+	require.False(t, hasTermKey)
+}
+
+func TestAggBuilder_NilCallback(t *testing.T) {
+	b := newTestSearchRequestBuilder()
+	aggBuilder := b.Agg()
+	aggBuilder.Terms("1", "status", nil)
+	aggBuilder.Histogram("2", "price", nil)
+	aggBuilder.DateHistogram("3", "@timestamp", nil)
+	aggBuilder.Filters("4", nil)
+	aggBuilder.GeoHashGrid("5", "location", nil)
+	aggBuilder.Nested("6", "comments", nil)
+
+	sr, err := b.Build()
+	require.NoError(t, err)
+	require.Len(t, sr.Aggs, 6)
+}
