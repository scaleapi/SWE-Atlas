+package es
+
+import (
+	"context"
+	"io"
+	"net/http"
+	"net/http/httptest"
+	"strings"
+	"testing"
+	"time"
+
+	"github.com/stretchr/testify/require"
+
+	"github.com/grafana/grafana-plugin-sdk-go/backend"
+	"github.com/grafana/grafana-plugin-sdk-go/backend/log"
+)
+
+func TestClient_IntervalSubstitution(t *testing.T) {
+	var requestBody string
+
+	ts := httptest.NewServer(http.HandlerFunc(func(rw http.ResponseWriter, r *http.Request) {
+		buf, err := io.ReadAll(r.Body)
+		require.NoError(t, err)
+		requestBody = string(buf)
+
+		rw.Header().Set("Content-Type", "application/x-ndjson")
+		_, err = rw.Write([]byte(`{
+			"responses": [
+				{
+					"hits": { "hits": [], "total": { "value": 0, "relation": "eq" } },
+					"status": 200
+				}
+			]
+		}`))
+		require.NoError(t, err)
+	}))
+	defer ts.Close()
+
+	ds := DatasourceInfo{
+		URL:        ts.URL,
+		HTTPClient: ts.Client(),
+		Database:   "test-*",
+	}
+
+	c, err := NewClient(context.Background(), &ds, log.New())
+	require.NoError(t, err)
+
+	interval := 15 * time.Second
+	from := time.Date(2023, 1, 1, 0, 0, 0, 0, time.UTC)
+	to := time.Date(2023, 1, 2, 0, 0, 0, 0, time.UTC)
+	timeRange := backend.TimeRange{From: from, To: to}
+
+	msb := c.MultiSearch()
+	s := msb.Search(interval, timeRange)
+	s.Agg().DateHistogram("2", "@timestamp", func(a *DateHistogramAgg, ab AggBuilder) {
+		a.FixedInterval = "$__interval"
+		ab.Metric("1", "avg", "@hostname", func(a *MetricAggregation) {
+			a.Settings["script"] = "$__interval_ms*@hostname"
+		})
+	})
+
+	ms, err := msb.Build()
+	require.NoError(t, err)
+
+	_, err = c.ExecuteMultisearch(ms)
+	require.NoError(t, err)
+
+	require.Contains(t, requestBody, "15s")
+	require.Contains(t, requestBody, "15000")
+	require.NotContains(t, requestBody, "$__interval_ms")
+	require.NotContains(t, requestBody, "$__interval\"")
+}
+
+func TestClient_NDJSONFormat(t *testing.T) {
+	var requestBody string
+
+	ts := httptest.NewServer(http.HandlerFunc(func(rw http.ResponseWriter, r *http.Request) {
+		buf, err := io.ReadAll(r.Body)
+		require.NoError(t, err)
+		requestBody = string(buf)
+
+		rw.Header().Set("Content-Type", "application/x-ndjson")
+		_, err = rw.Write([]byte(`{
+			"responses": [
+				{
+					"hits": { "hits": [], "total": { "value": 0, "relation": "eq" } },
+					"status": 200
+				}
+			]
+		}`))
+		require.NoError(t, err)
+	}))
+	defer ts.Close()
+
+	ds := DatasourceInfo{
+		URL:        ts.URL,
+		HTTPClient: ts.Client(),
+		Database:   "logs-*",
+	}
+
+	c, err := NewClient(context.Background(), &ds, log.New())
+	require.NoError(t, err)
+
+	from := time.Date(2023, 1, 1, 0, 0, 0, 0, time.UTC)
+	to := time.Date(2023, 1, 2, 0, 0, 0, 0, time.UTC)
+	timeRange := backend.TimeRange{From: from, To: to}
+
+	msb := c.MultiSearch()
+	msb.Search(10*time.Second, timeRange)
+
+	ms, err := msb.Build()
+	require.NoError(t, err)
+
+	_, err = c.ExecuteMultisearch(ms)
+	require.NoError(t, err)
+
+	lines := strings.Split(strings.TrimRight(requestBody, "\n"), "\n")
+	require.Equal(t, 2, len(lines), "NDJSON should have header and body lines")
+
+	for _, line := range lines {
+		require.NotEmpty(t, line, "NDJSON lines should not be empty")
+		require.True(t, strings.HasPrefix(strings.TrimSpace(line), "{"), "Each line should be valid JSON")
+	}
+}
+
+func TestClient_ContentTypeHeader(t *testing.T) {
+	var receivedContentType string
+
+	ts := httptest.NewServer(http.HandlerFunc(func(rw http.ResponseWriter, r *http.Request) {
+		receivedContentType = r.Header.Get("Content-Type")
+
+		rw.Header().Set("Content-Type", "application/x-ndjson")
+		_, err := rw.Write([]byte(`{
+			"responses": [
