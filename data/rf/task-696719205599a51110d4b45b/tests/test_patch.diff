+package es
+
+import (
+	"encoding/json"
+	"testing"
+
+	"github.com/grafana/grafana/pkg/components/simplejson"
+	"github.com/stretchr/testify/require"
+)
+
+func TestQueryBuilder_EmptyBuild(t *testing.T) {
+	qb := NewQueryBuilder()
+	q, err := qb.Build()
+	require.NoError(t, err)
+	require.NotNil(t, q)
+	require.Nil(t, q.Bool)
+}
+
+func TestQueryBuilder_BoolWithFilters(t *testing.T) {
+	qb := NewQueryBuilder()
+	qb.Bool().Filter().AddDateRangeFilter("@timestamp", 100, 50, DateFormatEpochMS)
+	qb.Bool().Filter().AddQueryStringFilter("error AND critical", true)
+
+	q, err := qb.Build()
+	require.NoError(t, err)
+	require.NotNil(t, q.Bool)
+	require.Len(t, q.Bool.Filters, 2)
+
+	rangeFilter, ok := q.Bool.Filters[0].(*RangeFilter)
+	require.True(t, ok)
+	require.Equal(t, "@timestamp", rangeFilter.Key)
+	require.Equal(t, int64(100), rangeFilter.Lte)
+	require.Equal(t, int64(50), rangeFilter.Gte)
+
+	qsFilter, ok := q.Bool.Filters[1].(*QueryStringFilter)
+	require.True(t, ok)
+	require.Equal(t, "error AND critical", qsFilter.Query)
+	require.True(t, qsFilter.AnalyzeWildcard)
+}
+
+func TestQueryBuilder_BoolReturnsExistingBuilder(t *testing.T) {
+	qb := NewQueryBuilder()
+	b1 := qb.Bool()
+	b2 := qb.Bool()
+	require.Same(t, b1, b2)
+}
+
+func TestFilterQueryBuilder_EmptyQueryStringIgnored(t *testing.T) {
+	fb := NewFilterQueryBuilder()
+	fb.AddQueryStringFilter("   ", false)
+	fb.AddQueryStringFilter("", false)
+
+	filters, err := fb.Build()
+	require.NoError(t, err)
+	require.Len(t, filters, 0)
+}
+
+func TestFilterQueryBuilder_EmptyBuild(t *testing.T) {
+	fb := NewFilterQueryBuilder()
+	filters, err := fb.Build()
+	require.NoError(t, err)
+	require.Len(t, filters, 0)
+}
+
+func TestBoolQueryBuilder_FilterReturnsExistingBuilder(t *testing.T) {
+	bqb := NewBoolQueryBuilder()
+	f1 := bqb.Filter()
+	f2 := bqb.Filter()
+	require.Same(t, f1, f2)
+}
+
+func TestBoolQueryBuilder_EmptyBuild(t *testing.T) {
+	bqb := NewBoolQueryBuilder()
+	bq, err := bqb.Build()
+	require.NoError(t, err)
+	require.NotNil(t, bq)
+	require.Nil(t, bq.Filters)
+}
+
+func TestQueryBuilder_MarshalJSON(t *testing.T) {
+	qb := NewQueryBuilder()
+	qb.Bool().Filter().AddDateRangeFilter("@timestamp", 200, 100, DateFormatEpochMS)
+
+	q, err := qb.Build()
+	require.NoError(t, err)
+
+	body, err := json.Marshal(q)
+	require.NoError(t, err)
+
+	j, err := simplejson.NewJson(body)
+	require.NoError(t, err)
+
+	rangeFilter := j.GetPath("bool", "filter", "range", "@timestamp")
+	require.Equal(t, int64(100), rangeFilter.Get("gte").MustInt64())
+	require.Equal(t, int64(200), rangeFilter.Get("lte").MustInt64())
+	require.Equal(t, DateFormatEpochMS, rangeFilter.Get("format").MustString())
+}
