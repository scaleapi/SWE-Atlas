@@ -0,0 +1,123 @@
+package es
+
+import (
+	"strings"
+	"testing"
+
+	"github.com/stretchr/testify/require"
+)
+
+func TestStreamMultiSearchResponse_WithAggregations(t *testing.T) {
+	jsonBody := `{
+		"responses": [
+			{
+				"hits": { "hits": [], "total": { "value": 10, "relation": "eq" } },
+				"aggregations": { "2": { "buckets": [{ "key": 1000, "doc_count": 5 }] } }
+			}
+		]
+	}`
+
+	msr := &MultiSearchResponse{}
+	err := StreamMultiSearchResponse(strings.NewReader(jsonBody), msr)
+	require.NoError(t, err)
+	require.Len(t, msr.Responses, 1)
+	require.NotNil(t, msr.Responses[0].Aggregations)
+	require.Contains(t, msr.Responses[0].Aggregations, "2")
