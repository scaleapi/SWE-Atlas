@@ -0,0 +1,171 @@
+package es
+
+import (
+	"context"
+	"io"
+	"net/http"
+	"net/http/httptest"
+	"testing"
+	"time"
+
+	"github.com/stretchr/testify/assert"
+	"github.com/stretchr/testify/require"
+
+	"github.com/grafana/grafana-plugin-sdk-go/backend"
+	"github.com/grafana/grafana-plugin-sdk-go/backend/log"
+)
+
+func TestClient_PostMethod(t *testing.T) {
+	var receivedMethod string
+
+	ts := httptest.NewServer(http.HandlerFunc(func(rw http.ResponseWriter, r *http.Request) {
+		receivedMethod = r.Method
+
+		rw.Header().Set("Content-Type", "application/x-ndjson")
+		_, err := rw.Write([]byte(`{
+			"responses": [
+				{ "hits": { "hits": [], "total": { "value": 0, "relation": "eq" } }, "status": 200 }
+			]
+		}`))
+		require.NoError(t, err)
+	}))
+	defer ts.Close()
+
+	ds := DatasourceInfo{
+		URL:        ts.URL,
+		HTTPClient: ts.Client(),
+		Database:   "test-*",
+	}
+
+	c, err := NewClient(context.Background(), &ds, log.New())
+	require.NoError(t, err)
+
+	from := time.Date(2023, 1, 1, 0, 0, 0, 0, time.UTC)
+	to := time.Date(2023, 1, 2, 0, 0, 0, 0, time.UTC)
+	timeRange := backend.TimeRange{From: from, To: to}
+
+	msb := c.MultiSearch()
+	msb.Search(10*time.Second, timeRange)
+
+	ms, err := msb.Build()
+	require.NoError(t, err)
+
+	_, err = c.ExecuteMultisearch(ms)
+	require.NoError(t, err)
+
+	assert.Equal(t, http.MethodPost, receivedMethod)
+}
+
+func TestClient_URLPathConstruction(t *testing.T) {
+	var receivedPath string
+	var receivedQuery string
+
+	ts := httptest.NewServer(http.HandlerFunc(func(rw http.ResponseWriter, r *http.Request) {
+		receivedPath = r.URL.Path
+		receivedQuery = r.URL.RawQuery
+
+		rw.Header().Set("Content-Type", "application/x-ndjson")
+		_, err := rw.Write([]byte(`{
+			"responses": [
+				{ "hits": { "hits": [], "total": { "value": 0, "relation": "eq" } }, "status": 200 }
+			]
+		}`))
+		require.NoError(t, err)
+	}))
+	defer ts.Close()
+
+	ds := DatasourceInfo{
+		URL:                        ts.URL,
+		HTTPClient:                 ts.Client(),
+		Database:                   "test-*",
+		MaxConcurrentShardRequests: 5,
+		IncludeFrozen:              true,
+	}
+
+	c, err := NewClient(context.Background(), &ds, log.New())
+	require.NoError(t, err)
+
+	from := time.Date(2023, 1, 1, 0, 0, 0, 0, time.UTC)
+	to := time.Date(2023, 1, 2, 0, 0, 0, 0, time.UTC)
+	timeRange := backend.TimeRange{From: from, To: to}
+
+	msb := c.MultiSearch()
+	msb.Search(10*time.Second, timeRange)
+
+	ms, err := msb.Build()
+	require.NoError(t, err)
+
+	_, err = c.ExecuteMultisearch(ms)
+	require.NoError(t, err)
+
+	assert.Equal(t, "/_msearch", receivedPath)
+	assert.Contains(t, receivedQuery, "max_concurrent_shard_requests=5")
+	assert.Contains(t, receivedQuery, "ignore_throttled=false")
+}
+
+func TestClient_RequestBodyReceived(t *testing.T) {
+	var receivedBody []byte
+
+	ts := httptest.NewServer(http.HandlerFunc(func(rw http.ResponseWriter, r *http.Request) {
+		var err error
+		receivedBody, err = io.ReadAll(r.Body)
+		require.NoError(t, err)
+
+		rw.Header().Set("Content-Type", "application/x-ndjson")
+		_, err = rw.Write([]byte(`{
+			"responses": [
+				{ "hits": { "hits": [], "total": { "value": 0, "relation": "eq" } }, "status": 200 }
+			]
+		}`))
+		require.NoError(t, err)
+	}))
+	defer ts.Close()
+
+	ds := DatasourceInfo{
+		URL:        ts.URL,
+		HTTPClient: ts.Client(),
+		Database:   "test-*",
+	}
+
+	c, err := NewClient(context.Background(), &ds, log.New())
+	require.NoError(t, err)
+
+	from := time.Date(2023, 1, 1, 0, 0, 0, 0, time.UTC)
+	to := time.Date(2023, 1, 2, 0, 0, 0, 0, time.UTC)
+	timeRange := backend.TimeRange{From: from, To: to}
+
+	msb := c.MultiSearch()
+	msb.Search(10*time.Second, timeRange)
+
+	ms, err := msb.Build()
+	require.NoError(t, err)
+
+	_, err = c.ExecuteMultisearch(ms)
+	require.NoError(t, err)
+
+	require.NotEmpty(t, receivedBody, "Server should receive a non-empty request body")
+}
+
+func TestClient_InvalidURL(t *testing.T) {
+	ds := &DatasourceInfo{
+		URL:        "://invalid-url",
+		HTTPClient: http.DefaultClient,
+		Database:   "test-*",
+	}
+
+	c, err := NewClient(context.Background(), ds, log.NewNullLogger())
+	require.NoError(t, err)
+
+	from := time.Date(2023, 1, 1, 0, 0, 0, 0, time.UTC)
+	to := time.Date(2023, 1, 2, 0, 0, 0, 0, time.UTC)
+	timeRange := backend.TimeRange{From: from, To: to}
+
+	msb := c.MultiSearch()
+	msb.Search(10*time.Second, timeRange)
+	ms, err := msb.Build()
+	require.NoError(t, err)
+
+	_, err = c.ExecuteMultisearch(ms)
+	require.Error(t, err)
+	require.True(t, backend.IsDownstreamError(err))
+}
