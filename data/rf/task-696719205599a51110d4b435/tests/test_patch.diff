+// TestLocatorStrictModeEnforcement verifies that all Locator methods enforce
+// strict mode by returning an error when the selector matches multiple elements.
+func TestLocatorStrictModeEnforcement(t *testing.T) {
+	t.Parallel()
+
+	tb := newTestBrowser(t, withFileServer())
+	p := tb.NewPage(nil)
+	opts := &common.FrameGotoOptions{
+		Timeout: common.DefaultTimeout,
+	}
+	_, err := p.Goto(tb.staticURL("locators.html"), opts)
+	require.NoError(t, err)
+
+	multiL := p.Locator("a", nil)
+	multiInput := p.Locator(`input[type=text]`, nil)
+	multiCheckbox := p.Locator(`input[type=checkbox]`, nil)
+	multiSelect := p.Locator("select", nil)
+
+	actionTests := []struct {
+		name string
+		fn   func() error
+	}{
+		{"Click", func() error { return multiL.Click(common.NewFrameClickOptions(100 * time.Millisecond)) }},
+		{"Dblclick", func() error {
+			return multiL.Dblclick(common.NewFrameDblClickOptions(100 * time.Millisecond))
+		}},
+		{"Fill", func() error { return multiInput.Fill("x", common.NewFrameFillOptions(100 * time.Millisecond)) }},
+		{"Clear", func() error { return multiInput.Clear(common.NewFrameFillOptions(100 * time.Millisecond)) }},
+		{"Focus", func() error { return multiL.Focus(common.NewFrameBaseOptions(100 * time.Millisecond)) }},
+		{"Hover", func() error { return multiL.Hover(common.NewFrameHoverOptions(100 * time.Millisecond)) }},
+		{"Press", func() error {
+			return multiL.Press("x", common.NewFramePressOptions(100 * time.Millisecond))
+		}},
+		{"Type", func() error { return multiL.Type("x", common.NewFrameTypeOptions(100 * time.Millisecond)) }},
+		{"Check", func() error { return multiCheckbox.Check(common.NewFrameCheckOptions(100 * time.Millisecond)) }},
+		{"Uncheck", func() error {
+			return multiCheckbox.Uncheck(common.NewFrameUncheckOptions(100 * time.Millisecond))
+		}},
+		{"SetChecked", func() error {
+			return multiCheckbox.SetChecked(true, common.NewFrameCheckOptions(100*time.Millisecond))
+		}},
+		{"DispatchEvent", func() error {
+			return multiL.DispatchEvent("click", "mouseevent",
+				common.NewFrameDispatchEventOptions(100*time.Millisecond))
+		}},
+		{"WaitFor", func() error {
+			return multiL.WaitFor(common.NewFrameWaitForSelectorOptions(100 * time.Millisecond))
+		}},
+		{"GetAttribute", func() error {
+			_, _, err := multiL.GetAttribute("href", common.NewFrameBaseOptions(100*time.Millisecond))
+			return err
+		}},
+		{"InnerHTML", func() error {
+			_, err := multiL.InnerHTML(common.NewFrameInnerHTMLOptions(100 * time.Millisecond))
+			return err
+		}},
+		{"InnerText", func() error {
+			_, err := multiL.InnerText(common.NewFrameInnerTextOptions(100 * time.Millisecond))
+			return err
+		}},
+		{"TextContent", func() error {
+			_, _, err := multiL.TextContent(common.NewFrameTextContentOptions(100 * time.Millisecond))
+			return err
+		}},
+		{"InputValue", func() error {
+			_, err := multiInput.InputValue(common.NewFrameInputValueOptions(100 * time.Millisecond))
+			return err
+		}},
+		{"SelectOption", func() error {
+			_, err := multiSelect.SelectOption([]any{""}, common.NewFrameSelectOptionOptions(100*time.Millisecond))
+			return err
+		}},
+		{"IsChecked", func() error {
+			_, err := multiL.IsChecked(common.NewFrameIsCheckedOptions(100 * time.Millisecond))
+			return err
+		}},
+		{"IsEditable", func() error {
+			_, err := multiL.IsEditable(common.NewFrameIsEditableOptions(100 * time.Millisecond))
+			return err
+		}},
+		{"IsEnabled", func() error {
+			_, err := multiL.IsEnabled(common.NewFrameIsEnabledOptions(100 * time.Millisecond))
+			return err
+		}},
+		{"IsDisabled", func() error {
+			_, err := multiL.IsDisabled(common.NewFrameIsDisabledOptions(100 * time.Millisecond))
+			return err
+		}},
+	}
+
+	for _, tt := range actionTests {
+		t.Run(tt.name, func(t *testing.T) {
+			t.Parallel()
+			require.Error(t, tt.fn(), "expected strict mode error for %s", tt.name)
+		})
+	}
+}
