+import { AnnoKeyRepoName, AnnoKeyRepoPath } from '../apiserver/types';
+
+import { loadDashboardFromProvisioning } from './dashboard';
+
+const mockGet = jest.fn();
+
+jest.mock('@grafana/runtime', () => ({
+  ...jest.requireActual('@grafana/runtime'),
+  getBackendSrv: () => ({
+    get: mockGet,
+  }),
+  config: {
+    ...jest.requireActual('@grafana/runtime').config,
+    namespace: 'test-ns',
+  },
+}));
+
+function buildDryRunResponse(overrides: Record<string, any> = {}) {
+  return {
+    resource: {
+      dryRun: {
+        apiVersion: 'dashboard.grafana.app/v0alpha1',
+        kind: 'Dashboard',
+        metadata: {
+          name: 'test-dash',
+          resourceVersion: '1',
+          creationTimestamp: '2024-01-01',
+          annotations: {},
+          ...overrides.metadata,
+        },
+        spec: {
+          title: 'Test Dashboard',
+          ...overrides.spec,
+        },
+      },
+    },
+  };
+}
+
+describe('loadDashboardFromProvisioning', () => {
+  beforeEach(() => {
+    mockGet.mockReset();
+    Object.defineProperty(window, 'location', {
+      value: { search: '' },
+      writable: true,
+    });
+  });
+
+  it('calls the provisioning API with repo and path', async () => {
+    mockGet.mockResolvedValue(buildDryRunResponse());
+
+    await loadDashboardFromProvisioning('my-repo', 'dashboards/test.json');
+
+    expect(mockGet).toHaveBeenCalledTimes(1);
+    const [url] = mockGet.mock.calls[0];
+    expect(url).toContain('my-repo');
+    expect(url).toContain('dashboards/test.json');
+    expect(url).toContain('repositories/');
+    expect(url).toContain('files/');
+  });
+
+  it('uses BASE_URL in the request URL', async () => {
+    mockGet.mockResolvedValue(buildDryRunResponse());
+
+    await loadDashboardFromProvisioning('my-repo', 'dashboards/test.json');
+
+    const [url] = mockGet.mock.calls[0];
+    expect(url).toContain('apis/provisioning.grafana.app/v0alpha1/namespaces/');
+  });
+
+  it('returns a DashboardDTO with expected meta fields', async () => {
+    mockGet.mockResolvedValue(buildDryRunResponse());
+
+    const result = await loadDashboardFromProvisioning('my-repo', 'dashboards/test.json');
+
+    expect(result.meta.canStar).toBe(false);
+    expect(result.meta.isSnapshot).toBe(false);
+    expect(result.meta.canShare).toBe(false);
+    expect(result.meta.canDelete).toBe(true);
+    expect(result.meta.canSave).toBe(true);
+    expect(result.meta.canEdit).toBe(true);
+  });
+
+  it('returns the dashboard spec as the dashboard data', async () => {
+    mockGet.mockResolvedValue(buildDryRunResponse({ spec: { title: 'My Dash', uid: 'abc' } }));
+
+    const result = await loadDashboardFromProvisioning('my-repo', 'dashboards/test.json');
+
+    expect(result.dashboard.title).toBe('My Dash');
+  });
+
+  it('sets AnnoKeyRepoName annotation to the repo parameter', async () => {
+    mockGet.mockResolvedValue(buildDryRunResponse());
+
+    const result = await loadDashboardFromProvisioning('my-repo', 'dashboards/test.json');
+
+    expect(result.meta.k8s?.annotations?.[AnnoKeyRepoName]).toBe('my-repo');
+  });
+
+  it('sets AnnoKeyRepoPath annotation to the path parameter', async () => {
+    mockGet.mockResolvedValue(buildDryRunResponse());
+
+    const result = await loadDashboardFromProvisioning('my-repo', 'dashboards/test.json');
+
+    expect(result.meta.k8s?.annotations?.[AnnoKeyRepoPath]).toBe('dashboards/test.json');
+  });
+
+  it('creates annotations object if metadata has none', async () => {
+    const response = buildDryRunResponse();
+    delete response.resource.dryRun.metadata.annotations;
+    mockGet.mockResolvedValue(response);
+
+    const result = await loadDashboardFromProvisioning('my-repo', 'dashboards/test.json');
+
+    expect(result.meta.k8s?.annotations?.[AnnoKeyRepoName]).toBe('my-repo');
+    expect(result.meta.k8s?.annotations?.[AnnoKeyRepoPath]).toBe('dashboards/test.json');
+  });
+
+  it('rejects when dryRun is missing', async () => {
+    mockGet.mockResolvedValue({ resource: {} });
+
+    await expect(loadDashboardFromProvisioning('my-repo', 'test.json')).rejects.toBe(
+      'failed to read provisioned dashboard'
+    );
+  });
+
+  it('rejects when apiVersion does not start with dashboard.grafana.app', async () => {
+    const response = buildDryRunResponse();
+    response.resource.dryRun.apiVersion = 'playlist.grafana.app/v0alpha1';
+    mockGet.mockResolvedValue(response);
+
+    await expect(loadDashboardFromProvisioning('my-repo', 'test.json')).rejects.toContain(
+      'unexpected resource type'
+    );
+  });
+
+  it('passes ref query parameter when present in URL', async () => {
+    Object.defineProperty(window, 'location', {
+      value: { search: '?ref=abc123' },
+      writable: true,
+    });
+    mockGet.mockResolvedValue(buildDryRunResponse());
+
+    await loadDashboardFromProvisioning('my-repo', 'dashboards/test.json');
+
+    const [, params] = mockGet.mock.calls[0];
+    expect(params).toEqual({ ref: 'abc123' });
+  });
+
+  it('does not pass ref parameter when not in URL', async () => {
+    mockGet.mockResolvedValue(buildDryRunResponse());
+
+    await loadDashboardFromProvisioning('my-repo', 'dashboards/test.json');
+
+    const [, params] = mockGet.mock.calls[0];
+    expect(params).toBeUndefined();
+  });
+
+  it('includes k8s metadata in the returned meta', async () => {
+    mockGet.mockResolvedValue(buildDryRunResponse());
+
+    const result = await loadDashboardFromProvisioning('my-repo', 'dashboards/test.json');
+
+    expect(result.meta.k8s).toBeDefined();
+    expect(result.meta.k8s?.name).toBe('test-dash');
+  });
+});
