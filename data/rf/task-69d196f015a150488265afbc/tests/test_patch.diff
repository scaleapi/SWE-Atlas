+import { BASE_URL } from './baseAPI';
+
+jest.mock('@grafana/runtime', () => ({
+  ...jest.requireActual('@grafana/runtime'),
+  config: {
+    ...jest.requireActual('@grafana/runtime').config,
+    namespace: 'test-ns',
+  },
+}));
+
+describe('baseAPI', () => {
+  describe('BASE_URL', () => {
+    it('is a string containing the provisioning API path', () => {
+      expect(typeof BASE_URL).toBe('string');
+      expect(BASE_URL).toContain('apis/provisioning.grafana.app/v0alpha1/namespaces/');
+    });
+
+    it('includes the configured namespace', () => {
+      expect(BASE_URL).toContain('test-ns');
+    });
+
+    it('does not have a leading slash', () => {
+      expect(BASE_URL.startsWith('/')).toBe(false);
+    });
+
+    it('ends with the namespace segment', () => {
+      expect(BASE_URL).toMatch(/namespaces\/[^/]+$/);
+    });
+  });
+});
diff --git a/public/app/features/provisioning/dashboard.test.ts b/public/app/features/provisioning/dashboard.test.ts
