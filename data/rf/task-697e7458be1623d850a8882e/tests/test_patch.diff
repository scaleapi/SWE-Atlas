+func newTestSource(conn *sourcespb.S3) *Source {
+	g := new(errgroup.Group)
+	g.SetLimit(1)
+	return &Source{
+		name:       "test-source",
+		conn:       conn,
+		log:        logr.Discard(),
+		errorCount: &sync.Map{},
+		jobPool:    g,
+	}
+}
