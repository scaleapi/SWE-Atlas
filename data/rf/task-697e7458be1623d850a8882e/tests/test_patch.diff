+// TestScanBuckets_SkipsBucketOnRegionalClientError covers the bug fix where scanBuckets must
+// continue when creating a regional S3 client fails (non-default region from HeadBucket response).
+// GetBucketRegionWithClient is exercised against a local server; newClient fails because the
+// source has no valid static credential for the non-role path.
+func TestScanBuckets_SkipsBucketOnRegionalClientError(t *testing.T) {
+	server := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		if r.Method == http.MethodHead {
+			w.Header().Set("X-Amz-Bucket-Region", "eu-west-1")
+			w.WriteHeader(http.StatusOK)
+			return
+		}
+		t.Fatalf("unexpected %s %s", r.Method, r.URL.Path)
+	}))
+	t.Cleanup(server.Close)
+
+	sess, err := session.NewSession(&aws.Config{
+		Region:      aws.String("us-east-1"),
+		Endpoint:    aws.String(server.URL),
+		DisableSSL:  aws.Bool(true),
+		Credentials: credentials.AnonymousCredentials,
+	})
+	require.NoError(t, err)
+	client := awss3.New(sess)
+
+	conn := &sourcespb.S3{
+		Credential: nil,
+		Buckets:    []string{"any-bucket"},
+	}
+	s := newTestSource(conn)
+	ctx := context.Background()
+	chunksChan := make(chan *sources.Chunk, 1)
+
+	err = s.scanBuckets(ctx, client, "", []string{"any-bucket"}, chunksChan)
+	assert.NoError(t, err)
+}
