diff --git a/src/database/tests/rrd_refactor_test.c b/src/database/tests/rrd_refactor_test.c
new file mode 100644
index 000000000..3a0905913
--- /dev/null
+++ b/src/database/tests/rrd_refactor_test.c
@@ -0,0 +1,165 @@
+// SPDX-License-Identifier: GPL-3.0-or-later
+//
+// Standalone unit tests for the RRD database refactoring:
+// - RRD_DB_MODE enum rename and conversion functions
+// - RRD_ALGORITHM extraction and conversion functions
+// - RRDSET_TYPE extraction and conversion functions
+// - Storage engine lookup with renamed types
+//
+// Compiled separately by the test runner, not part of the main netdata binary.
+
+#include <stdio.h>
+#include <string.h>
+#include <stdlib.h>
+
+#include "database/rrd-database-mode.h"
+#include "database/rrd-algorithm.h"
+#include "database/rrdset-type.h"
+#include "database/storage-engine.h"
+#include "database/rrd.h"
+
+static int errors = 0;
+static int tests_passed = 0;
+
+#define ASSERT_EQ_INT(name, got, expected) do { \
+    if ((got) != (expected)) { \
+        fprintf(stderr, "FAIL: %s: got %d, expected %d\n", name, (int)(got), (int)(expected)); \
+        errors++; \
+    } else { tests_passed++; } \
+} while(0)
+
+#define ASSERT_EQ_STR(name, got, expected) do { \
+    if (strcmp((got), (expected)) != 0) { \
+        fprintf(stderr, "FAIL: %s: got '%s', expected '%s'\n", name, (got), (expected)); \
+        errors++; \
+    } else { tests_passed++; } \
+} while(0)
+
+#define ASSERT_NOT_NULL(name, ptr) do { \
+    if ((ptr) == NULL) { \
+        fprintf(stderr, "FAIL: %s: got NULL\n", name); \
+        errors++; \
+    } else { tests_passed++; } \
+} while(0)
+
+static void test_rrd_db_mode_enum_values(void) {
+    fprintf(stderr, "test_rrd_db_mode_enum_values...");
+    ASSERT_EQ_INT("RRD_DB_MODE_NONE", RRD_DB_MODE_NONE, 0);
+    ASSERT_EQ_INT("RRD_DB_MODE_RAM", RRD_DB_MODE_RAM, 1);
+    ASSERT_EQ_INT("RRD_DB_MODE_ALLOC", RRD_DB_MODE_ALLOC, 4);
+    ASSERT_EQ_INT("RRD_DB_MODE_DBENGINE", RRD_DB_MODE_DBENGINE, 5);
+    ASSERT_EQ_STR("RRD_DB_MODE_NONE_NAME", RRD_DB_MODE_NONE_NAME, "none");
+    ASSERT_EQ_STR("RRD_DB_MODE_RAM_NAME", RRD_DB_MODE_RAM_NAME, "ram");
+    ASSERT_EQ_STR("RRD_DB_MODE_ALLOC_NAME", RRD_DB_MODE_ALLOC_NAME, "alloc");
+    ASSERT_EQ_STR("RRD_DB_MODE_DBENGINE_NAME", RRD_DB_MODE_DBENGINE_NAME, "dbengine");
+    fprintf(stderr, "OK\n");
+}
+
+static void test_rrd_db_mode_conversions(void) {
+    fprintf(stderr, "test_rrd_db_mode_conversions...");
+    ASSERT_EQ_STR("name(NONE)", rrd_memory_mode_name(RRD_DB_MODE_NONE), "none");
+    ASSERT_EQ_STR("name(RAM)", rrd_memory_mode_name(RRD_DB_MODE_RAM), "ram");
+    ASSERT_EQ_STR("name(ALLOC)", rrd_memory_mode_name(RRD_DB_MODE_ALLOC), "alloc");
+    ASSERT_EQ_STR("name(DBENGINE)", rrd_memory_mode_name(RRD_DB_MODE_DBENGINE), "dbengine");
+    ASSERT_EQ_INT("id(none)", rrd_memory_mode_id("none"), RRD_DB_MODE_NONE);
+    ASSERT_EQ_INT("id(ram)", rrd_memory_mode_id("ram"), RRD_DB_MODE_RAM);
+    ASSERT_EQ_INT("id(alloc)", rrd_memory_mode_id("alloc"), RRD_DB_MODE_ALLOC);
+    ASSERT_EQ_INT("id(dbengine)", rrd_memory_mode_id("dbengine"), RRD_DB_MODE_DBENGINE);
+    ASSERT_EQ_INT("id(unknown)", rrd_memory_mode_id("nonexistent_mode"), RRD_DB_MODE_RAM);
+    fprintf(stderr, "OK\n");
+}
+
+static void test_rrd_algorithm_conversions(void) {
+    fprintf(stderr, "test_rrd_algorithm_conversions...");
+    ASSERT_EQ_STR("name(ABSOLUTE)", rrd_algorithm_name(RRD_ALGORITHM_ABSOLUTE), RRD_ALGORITHM_ABSOLUTE_NAME);
+    ASSERT_EQ_STR("name(INCREMENTAL)", rrd_algorithm_name(RRD_ALGORITHM_INCREMENTAL), RRD_ALGORITHM_INCREMENTAL_NAME);
+    ASSERT_EQ_STR("name(PCENT_DIFF)", rrd_algorithm_name(RRD_ALGORITHM_PCENT_OVER_DIFF_TOTAL), RRD_ALGORITHM_PCENT_OVER_DIFF_TOTAL_NAME);
+    ASSERT_EQ_STR("name(PCENT_ROW)", rrd_algorithm_name(RRD_ALGORITHM_PCENT_OVER_ROW_TOTAL), RRD_ALGORITHM_PCENT_OVER_ROW_TOTAL_NAME);
+    ASSERT_EQ_INT("id(absolute)", rrd_algorithm_id(RRD_ALGORITHM_ABSOLUTE_NAME), RRD_ALGORITHM_ABSOLUTE);
+    ASSERT_EQ_INT("id(incremental)", rrd_algorithm_id(RRD_ALGORITHM_INCREMENTAL_NAME), RRD_ALGORITHM_INCREMENTAL);
+    ASSERT_EQ_INT("id(pcent_diff)", rrd_algorithm_id(RRD_ALGORITHM_PCENT_OVER_DIFF_TOTAL_NAME), RRD_ALGORITHM_PCENT_OVER_DIFF_TOTAL);
+    ASSERT_EQ_INT("id(pcent_row)", rrd_algorithm_id(RRD_ALGORITHM_PCENT_OVER_ROW_TOTAL_NAME), RRD_ALGORITHM_PCENT_OVER_ROW_TOTAL);
+    ASSERT_EQ_INT("id(unknown)", rrd_algorithm_id("nonexistent_algorithm"), RRD_ALGORITHM_ABSOLUTE);
+    fprintf(stderr, "OK\n");
+}
+
+static void test_rrdset_type_conversions(void) {
+    fprintf(stderr, "test_rrdset_type_conversions...");
+    ASSERT_EQ_STR("name(LINE)", rrdset_type_name(RRDSET_TYPE_LINE), RRDSET_TYPE_LINE_NAME);
+    ASSERT_EQ_STR("name(AREA)", rrdset_type_name(RRDSET_TYPE_AREA), RRDSET_TYPE_AREA_NAME);
+    ASSERT_EQ_STR("name(STACKED)", rrdset_type_name(RRDSET_TYPE_STACKED), RRDSET_TYPE_STACKED_NAME);
+    ASSERT_EQ_STR("name(HEATMAP)", rrdset_type_name(RRDSET_TYPE_HEATMAP), RRDSET_TYPE_HEATMAP_NAME);
+    ASSERT_EQ_INT("id(line)", rrdset_type_id(RRDSET_TYPE_LINE_NAME), RRDSET_TYPE_LINE);
+    ASSERT_EQ_INT("id(area)", rrdset_type_id(RRDSET_TYPE_AREA_NAME), RRDSET_TYPE_AREA);
+    ASSERT_EQ_INT("id(stacked)", rrdset_type_id(RRDSET_TYPE_STACKED_NAME), RRDSET_TYPE_STACKED);
+    ASSERT_EQ_INT("id(heatmap)", rrdset_type_id(RRDSET_TYPE_HEATMAP_NAME), RRDSET_TYPE_HEATMAP);
+    ASSERT_EQ_INT("id(unknown)", rrdset_type_id("nonexistent_type"), RRDSET_TYPE_LINE);
+    fprintf(stderr, "OK\n");
+}
+
+static void test_storage_engine_modes(void) {
+    fprintf(stderr, "test_storage_engine_modes...");
+    STORAGE_ENGINE *eng;
+
+    eng = storage_engine_get(RRD_DB_MODE_NONE);
+    ASSERT_NOT_NULL("engine(NONE)", eng);
+    if (eng) ASSERT_EQ_INT("engine(NONE).id", eng->id, RRD_DB_MODE_NONE);
+
+    eng = storage_engine_get(RRD_DB_MODE_RAM);
+    ASSERT_NOT_NULL("engine(RAM)", eng);
+    if (eng) ASSERT_EQ_INT("engine(RAM).id", eng->id, RRD_DB_MODE_RAM);
+
+    eng = storage_engine_get(RRD_DB_MODE_ALLOC);
+    ASSERT_NOT_NULL("engine(ALLOC)", eng);
+    if (eng) ASSERT_EQ_INT("engine(ALLOC).id", eng->id, RRD_DB_MODE_ALLOC);
+
+    fprintf(stderr, "OK\n");
+}
+
+static void test_align_entries_to_pagesize(void) {
+    fprintf(stderr, "test_align_entries_to_pagesize...");
+    ASSERT_EQ_INT("DBENGINE->0", align_entries_to_pagesize(RRD_DB_MODE_DBENGINE, 1000), 0);
+    ASSERT_EQ_INT("NONE->5", align_entries_to_pagesize(RRD_DB_MODE_NONE, 1000), 5);
+
+    long alloc_small = align_entries_to_pagesize(RRD_DB_MODE_ALLOC, 2);
+    if (alloc_small < 5) {
+        fprintf(stderr, "FAIL: ALLOC(2): got %ld, expected >= 5\n", alloc_small);
+        errors++;
+    } else { tests_passed++; }
+
+    long alloc_big = align_entries_to_pagesize(RRD_DB_MODE_ALLOC, RRD_HISTORY_ENTRIES_MAX + 100);
+    if (alloc_big > RRD_HISTORY_ENTRIES_MAX) {
+        fprintf(stderr, "FAIL: ALLOC(MAX+100): got %ld, expected <= %d\n", alloc_big, RRD_HISTORY_ENTRIES_MAX);
+        errors++;
+    } else { tests_passed++; }
+
+    long ram_normal = align_entries_to_pagesize(RRD_DB_MODE_RAM, 100);
+    if (ram_normal < 100) {
+        fprintf(stderr, "FAIL: RAM(100): got %ld, expected >= 100\n", ram_normal);
+        errors++;
+    } else { tests_passed++; }
+
+    fprintf(stderr, "OK\n");
+}
+
+int main(int argc, char *argv[]) {
+    (void)argc; (void)argv;
+
+    fprintf(stderr, "=== RRD Refactor Tests ===\n");
+
+    test_rrd_db_mode_enum_values();
+    test_rrd_db_mode_conversions();
+    test_rrd_algorithm_conversions();
+    test_rrdset_type_conversions();
+    test_storage_engine_modes();
+    test_align_entries_to_pagesize();
+
+    fprintf(stderr, "\n%d passed, %d failed\n", tests_passed, errors);
+
+    if (errors > 0) {
+        fprintf(stderr, "TESTS FAILED\n");
+        return 1;
+    }
+    fprintf(stderr, "ALL RRD REFACTOR TESTS PASSED\n");
+    return 0;
+}
