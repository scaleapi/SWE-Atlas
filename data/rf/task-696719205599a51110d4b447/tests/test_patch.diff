+			{
+				TimeSeries: metrics.TimeSeries{
+					Metric: builtinMetrics.DataSent,
+					Tags:   registry.RootTagSet(),
+				},
+				Time:  now,
+				Value: float64(200),
+			},
+			{
+				TimeSeries: metrics.TimeSeries{
+					Metric: builtinMetrics.DataReceived,
+					Tags:   registry.RootTagSet(),
