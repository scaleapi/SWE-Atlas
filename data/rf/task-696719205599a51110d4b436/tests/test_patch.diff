+func TestNewModuleResolver(t *testing.T) {
+	t.Parallel()
+
+	t.Run("creates resolver independently", func(t *testing.T) {
+		t.Parallel()
+		preInitState := getTestPreInitState(t, nil, nil)
+		pwd := &url.URL{Scheme: "file", Path: "/"}
+		fss := map[string]fsext.Fs{"file": fsext.NewMemMapFs(), "https": fsext.NewMemMapFs()}
+		mr := NewModuleResolver(pwd, preInitState, fss)
+		require.NotNil(t, mr)
+	})
+
+	t.Run("LoadMainModule valid script", func(t *testing.T) {
+		t.Parallel()
+		preInitState := getTestPreInitState(t, nil, nil)
+		filenameURL := &url.URL{Scheme: "file", Path: "/script.js"}
+		fss := map[string]fsext.Fs{"file": fsext.NewMemMapFs(), "https": fsext.NewMemMapFs()}
+		mr := NewModuleResolver(loader.Dir(filenameURL), preInitState, fss)
+
+		err := mr.LoadMainModule(loader.Dir(filenameURL), filenameURL.String(), []byte(`export default function() {};`))
+		require.NoError(t, err)
+	})
+
+	t.Run("LoadMainModule syntax error", func(t *testing.T) {
+		t.Parallel()
+		preInitState := getTestPreInitState(t, nil, nil)
+		filenameURL := &url.URL{Scheme: "file", Path: "/script.js"}
+		fss := map[string]fsext.Fs{"file": fsext.NewMemMapFs(), "https": fsext.NewMemMapFs()}
+		mr := NewModuleResolver(loader.Dir(filenameURL), preInitState, fss)
+
+		err := mr.LoadMainModule(loader.Dir(filenameURL), filenameURL.String(), []byte(`1+(=>2)()`))
+		require.Error(t, err)
+	})
+
+	t.Run("LoadMainModule unresolvable import", func(t *testing.T) {
+		t.Parallel()
+		preInitState := getTestPreInitState(t, nil, nil)
+		filenameURL := &url.URL{Scheme: "file", Path: "/script.js"}
+		fss := map[string]fsext.Fs{"file": fsext.NewMemMapFs(), "https": fsext.NewMemMapFs()}
+		mr := NewModuleResolver(loader.Dir(filenameURL), preInitState, fss)
+
+		err := mr.LoadMainModule(
+			loader.Dir(filenameURL), filenameURL.String(),
+			[]byte(`import something from "./nonexistent.js"; export default function() {};`),
+		)
+		require.Error(t, err)
+	})
+
+	t.Run("resolver passed to NewBundle", func(t *testing.T) {
+		t.Parallel()
+		preInitState := getTestPreInitState(t, nil, nil)
+		filenameURL := &url.URL{Scheme: "file", Path: "/script.js"}
+		fss := map[string]fsext.Fs{"file": fsext.NewMemMapFs(), "https": fsext.NewMemMapFs()}
+		mr := NewModuleResolver(loader.Dir(filenameURL), preInitState, fss)
+
+		b, err := NewBundle(
+			preInitState,
+			&loader.SourceData{URL: filenameURL, Data: []byte(`export default function() {};`)},
+			fss,
+			mr,
+		)
+		require.NoError(t, err)
+		require.NotNil(t, b)
+		require.NotNil(t, b.ModuleResolver)
