+	preInitState := getTestPreInitState(tb, logger, rtOpts)
+
+	fss := arc.Filesystems
+	moduleResolver := NewModuleResolver(arc.PwdURL, preInitState, fss)
+	return NewBundleFromArchive(preInitState, arc, moduleResolver)
