++ SOCKS add_payload port pair coverage
+
+= Load SOCKS contrib
+load_contrib("socks")
+
+= SOCKS5Request sets both dport and sport on TCP
+pkt = TCP()/SOCKS()/SOCKS5Request()
+assert pkt[TCP].dport == 1080, "SOCKS5Request should set dport=1080"
+assert pkt[TCP].sport != 0, "SOCKS5Request should set a non-zero sport"
+
+= SOCKS5Reply sets both sport and dport on TCP
+pkt = TCP()/SOCKS()/SOCKS5Reply()
+assert pkt[TCP].sport == 1080, "SOCKS5Reply should set sport=1080"
+assert pkt[TCP].dport != 0, "SOCKS5Reply should set a non-zero dport"
+
+= SOCKS4Request sets both dport and sport on TCP
+pkt = TCP()/SOCKS()/SOCKS4Request()
+assert pkt[TCP].dport == 1080, "SOCKS4Request should set dport=1080"
+assert pkt[TCP].sport != 0, "SOCKS4Request should set a non-zero sport"
+
+= SOCKS4Reply sets both sport and dport on TCP
+pkt = TCP()/SOCKS()/SOCKS4Reply()
+assert pkt[TCP].sport == 1080, "SOCKS4Reply should set sport=1080"
+assert pkt[TCP].dport != 0, "SOCKS4Reply should set a non-zero dport"
+
+= SOCKS request and reply set complementary port pairs
+req = TCP()/SOCKS()/SOCKS5Request()
+rep = TCP()/SOCKS()/SOCKS5Reply()
+assert req[TCP].dport == 1080 and req[TCP].sport != 0, "request sets dport=1080 and a sport"
+assert rep[TCP].sport == 1080 and rep[TCP].dport != 0, "reply sets sport=1080 and a dport"
