+import {
+  useGetRepositoryExportQuery,
+  useCreateRepositoryExportMutation,
+  useGetRepositoryFilesQuery,
+  useUpdateRepositoryFilesMutation,
+  useCreateRepositoryFilesMutation,
+  useDeleteRepositoryFilesMutation,
+  useGetRepositoryHelloQuery,
+  useGetRepositoryWebhookQuery,
+  useCreateRepositoryWebhookMutation,
+  generatedAPI,
+} from './endpoints';
+
+describe('Provisioning API endpoints', () => {
+  describe('renamed endpoint hooks are exported', () => {
+    it.each([
+      ['useGetRepositoryExportQuery', useGetRepositoryExportQuery],
+      ['useCreateRepositoryExportMutation', useCreateRepositoryExportMutation],
+      ['useGetRepositoryFilesQuery', useGetRepositoryFilesQuery],
+      ['useUpdateRepositoryFilesMutation', useUpdateRepositoryFilesMutation],
+      ['useCreateRepositoryFilesMutation', useCreateRepositoryFilesMutation],
+      ['useDeleteRepositoryFilesMutation', useDeleteRepositoryFilesMutation],
+      ['useGetRepositoryHelloQuery', useGetRepositoryHelloQuery],
+      ['useGetRepositoryWebhookQuery', useGetRepositoryWebhookQuery],
+      ['useCreateRepositoryWebhookMutation', useCreateRepositoryWebhookMutation],
+    ])('exports %s as a function', (_name, hook) => {
+      expect(typeof hook).toBe('function');
+    });
+  });
+
+  describe('connect-prefixed endpoints are removed', () => {
+    it('no endpoint name starts with connect', () => {
+      const endpointNames = Object.keys(generatedAPI.endpoints);
+      const connectPrefixed = endpointNames.filter((n) => n.startsWith('connect'));
+      expect(connectPrefixed).toEqual([]);
+    });
+  });
+
+  describe('watch endpoints are removed', () => {
+    it('does not include watchRepositoryList or watchRepository', () => {
+      const endpointNames = Object.keys(generatedAPI.endpoints);
+      expect(endpointNames).not.toContain('watchRepositoryList');
+      expect(endpointNames).not.toContain('watchRepository');
+    });
+  });
+
+  describe('file operation endpoints include ref support', () => {
+    function getEndpointQueryFn(endpointName: string): (arg: Record<string, unknown>) => Record<string, unknown> {
+      let queryFn: ((arg: Record<string, unknown>) => Record<string, unknown>) | undefined;
+      generatedAPI.enhanceEndpoints({
+        endpoints: {
+          [endpointName]: (definition: { query: (arg: Record<string, unknown>) => Record<string, unknown> }) => {
+            queryFn = definition.query;
+          },
+        },
+      });
+      if (!queryFn) {
+        throw new Error(`Could not extract query function for endpoint "${endpointName}"`);
+      }
+      return queryFn;
+    }
+
+    it.each([
+      'getRepositoryFiles',
+      'updateRepositoryFiles',
+      'createRepositoryFiles',
+      'deleteRepositoryFiles',
+    ])('%s endpoint is registered', (endpointName) => {
+      expect(generatedAPI.endpoints).toHaveProperty(endpointName);
+    });
+
+    it('getRepositoryFiles passes ref as a query param', () => {
+      const queryFn = getEndpointQueryFn('getRepositoryFiles');
+      const result = queryFn({ name: 'my-repo', path: 'dashboards/test.json', ref: 'some-branch' });
+      expect(result.params).toHaveProperty('ref', 'some-branch');
+    });
+
+    it('updateRepositoryFiles passes ref as a query param', () => {
+      const queryFn = getEndpointQueryFn('updateRepositoryFiles');
+      const result = queryFn({
+        name: 'my-repo',
+        path: 'dashboards/test.json',
+        ref: 'some-branch',
+        body: { kind: 'Dashboard' },
+        message: 'update file',
+      });
+      expect(result.params).toHaveProperty('ref', 'some-branch');
+    });
+
+    it('createRepositoryFiles passes ref as a query param', () => {
+      const queryFn = getEndpointQueryFn('createRepositoryFiles');
+      const result = queryFn({
+        name: 'my-repo',
+        path: 'dashboards/test.json',
+        ref: 'some-branch',
+        body: { kind: 'Dashboard' },
+        message: 'create file',
+      });
+      expect(result.params).toHaveProperty('ref', 'some-branch');
+    });
+
+    it('deleteRepositoryFiles passes ref as a query param', () => {
+      const queryFn = getEndpointQueryFn('deleteRepositoryFiles');
+      const result = queryFn({
+        name: 'my-repo',
+        path: 'dashboards/test.json',
+        ref: 'some-branch',
+        message: 'delete file',
+      });
+      expect(result.params).toHaveProperty('ref', 'some-branch');
+    });
+  });
+});
