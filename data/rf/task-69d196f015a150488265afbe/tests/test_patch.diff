+/**
+ * @jest-environment jsdom
+ */
+import { render } from '@testing-library/react';
+import React from 'react';
+import { ChecklistCard, type ChecklistCardItem } from '../';
+
+describe( 'ChecklistCard', () => {
+	const items: ChecklistCardItem[] = [
+		{ icon: <svg data-testid="icon-a" />, text: 'First benefit' },
+		{ icon: <svg data-testid="icon-b" />, text: 'Second benefit' },
+		{ icon: <svg data-testid="icon-c" />, text: 'Third benefit' },
+	];
+
+	it( 'renders the title', () => {
+		const { getByText } = render(
+			<ChecklistCard title="Test Title" items={ items } />
+		);
+		expect( getByText( 'Test Title' ) ).toBeVisible();
+	} );
+
+	it( 'renders all provided item texts', () => {
+		const { getByText } = render(
+			<ChecklistCard title="Title" items={ items } />
+		);
+		expect( getByText( 'First benefit' ) ).toBeVisible();
+		expect( getByText( 'Second benefit' ) ).toBeVisible();
+		expect( getByText( 'Third benefit' ) ).toBeVisible();
+	} );
+
+	it( 'renders with a single item', () => {
+		const singleItem: ChecklistCardItem[] = [
+			{ icon: <svg />, text: 'Only item' },
+		];
+		const { getByText } = render(
+			<ChecklistCard title="Single" items={ singleItem } />
+		);
+		expect( getByText( 'Single' ) ).toBeVisible();
+		expect( getByText( 'Only item' ) ).toBeVisible();
+	} );
+
+	it( 'renders with an empty items array', () => {
+		const { getByText, queryByText } = render(
+			<ChecklistCard title="No Items" items={ [] } />
+		);
+		expect( getByText( 'No Items' ) ).toBeVisible();
+		expect( queryByText( 'First benefit' ) ).not.toBeInTheDocument();
+	} );
+} );
