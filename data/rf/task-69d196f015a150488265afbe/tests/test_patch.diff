+			/>
+		);
+		expect(
+			getByText( 'Uninterrupted service throughout the entire migration experience.' )
+		).toBeVisible();
+	} );
+
+	it( 'renders the reliability benefit', () => {
+		const { getByText } = render(
+			<Authorization
+				onShareCredentialsClick={ jest.fn() }
+				onAuthorizationClick={ jest.fn() }
+			/>
+		);
+		expect(
+			getByText( /uptime and unmetered traffic/ )
+		).toBeVisible();
+	} );
+
+	it( 'renders the security benefit', () => {
+		const { getByText } = render(
+			<Authorization
+				onShareCredentialsClick={ jest.fn() }
+				onAuthorizationClick={ jest.fn() }
+			/>
+		);
+		expect(
+			getByText( 'Round-the-clock security monitoring and DDoS protection.' )
+		).toBeVisible();
+	} );
+} );
