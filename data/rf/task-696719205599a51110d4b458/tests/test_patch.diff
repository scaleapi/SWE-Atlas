+func TestMetaJSONDataWithAllOptionalFields(t *testing.T) {
+	alerting := true
+	backend := true
+	exe := "plugin-exe"
+	cat := MetaJSONDataCategoryCloud
+	state := MetaJSONDataStateAlpha
+
+	data := MetaJSONData{
+		Id:   "full-plugin",
+		Type: MetaJSONDataTypeDatasource,
+		Name: "Full Plugin",
+		Info: MetaInfo{
+			Keywords: []string{"test"},
+			Logos:    MetaV0alpha1InfoLogos{Small: "s.png", Large: "l.png"},
+			Updated:  "2024-01-01",
+			Version:  "1.0.0",
+		},
+		Dependencies: MetaDependencies{GrafanaDependency: ">=10.0.0"},
+		Alerting:     &alerting,
+		Backend:      &backend,
+		Executable:   &exe,
+		Category:     &cat,
+		State:        &state,
+		Includes:     []MetaInclude{*NewMetaInclude()},
+		Routes:       []MetaRoute{*NewMetaRoute()},
+		Roles:        []MetaRole{*NewMetaRole()},
+	}
+
+	assert.Equal(t, "full-plugin", data.Id)
+	assert.Equal(t, MetaJSONDataTypeDatasource, data.Type)
+	assert.True(t, *data.Alerting)
+	assert.True(t, *data.Backend)
+	assert.Equal(t, "plugin-exe", *data.Executable)
+	assert.Equal(t, MetaJSONDataCategoryCloud, *data.Category)
+	assert.Equal(t, MetaJSONDataStateAlpha, *data.State)
+	assert.Len(t, data.Includes, 1)
+	assert.Len(t, data.Routes, 1)
+	assert.Len(t, data.Roles, 1)
+}
