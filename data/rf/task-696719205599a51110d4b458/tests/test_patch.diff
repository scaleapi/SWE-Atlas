+package rbac
+
+import (
+	"testing"
+
+	"github.com/stretchr/testify/assert"
+	"github.com/stretchr/testify/require"
+)
+
+func TestMapperRegistryUsesRenamedMetasResource(t *testing.T) {
+	registry := NewMapperRegistry()
+
+	mapping, found := registry.Get("plugins.grafana.app", "metas")
+	require.True(t, found, "metas should be registered under plugins.grafana.app")
+	assert.Contains(t, mapping.Prefix(), "plugins.metas")
+
+	_, oldFound := registry.Get("plugins.grafana.app", "pluginsmeta")
+	assert.False(t, oldFound, "old resource pluginsmeta should not be registered")
+}
+
+func TestMapperRegistryMetasScopeResolution(t *testing.T) {
+	registry := NewMapperRegistry()
+	mapping, found := registry.Get("plugins.grafana.app", "metas")
+	require.True(t, found)
+
+	scope := mapping.Scope("test-plugin")
+	assert.Contains(t, scope, "plugins.metas")
+	assert.Contains(t, scope, "test-plugin")
+}
+
+func TestMapperRegistryPluginsResourceUnchanged(t *testing.T) {
+	registry := NewMapperRegistry()
+	mapping, found := registry.Get("plugins.grafana.app", "plugins")
+	require.True(t, found)
+	assert.Contains(t, mapping.Prefix(), "plugins.plugins")
+}
