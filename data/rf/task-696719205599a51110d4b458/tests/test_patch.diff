+func TestPermissionRegistryUsesRenamedMetasKey(t *testing.T) {
+	pr := newPermissionRegistry()
+
+	prefix, exists := pr.kindScopePrefix["plugins.metas"]
+	require.True(t, exists, "plugins.metas should be registered as a kind scope")
+	assert.Equal(t, "plugins.metas:uid:", prefix)
+
+	_, oldExists := pr.kindScopePrefix["plugins.pluginsmeta"]
+	assert.False(t, oldExists, "old key plugins.pluginsmeta should not exist")
+}
+
+func TestPermissionRegistryPluginsKeyUnchanged(t *testing.T) {
+	pr := newPermissionRegistry()
+	prefix, exists := pr.kindScopePrefix["plugins.plugins"]
+	require.True(t, exists)
+	assert.Equal(t, "plugins.plugins:uid:", prefix)
+}
