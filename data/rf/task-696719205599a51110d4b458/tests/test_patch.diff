+func TestNewMetaReturnsInitializedObject(t *testing.T) {
+	meta := NewMeta()
+	require.NotNil(t, meta)
+	assert.Equal(t, *NewMetaSpec(), meta.Spec)
+	assert.Equal(t, *NewMetaStatus(), meta.Status)
+}
+
+func TestNewPluginReturnsInitializedObject(t *testing.T) {
+	plugin := NewPlugin()
+	require.NotNil(t, plugin)
+	assert.Equal(t, *NewPluginSpec(), plugin.Spec)
+	assert.Equal(t, *NewPluginStatus(), plugin.Status)
+}
+
+func TestMetaKindRegistration(t *testing.T) {
+	kind := MetaKind()
+	assert.Equal(t, "Meta", kind.Kind())
+	assert.Equal(t, "metas", kind.Plural())
+	assert.Equal(t, "plugins.grafana.app", kind.Group())
+	assert.Equal(t, "v0alpha1", kind.Version())
+}
+
+func TestPluginKindRegistration(t *testing.T) {
+	kind := PluginKind()
+	assert.Equal(t, "Plugin", kind.Kind())
+	assert.Equal(t, "plugins", kind.Plural())
+	assert.Equal(t, "plugins.grafana.app", kind.Group())
+	assert.Equal(t, "v0alpha1", kind.Version())
+}
+
+func TestMetaGetAndSetSpec(t *testing.T) {
+	meta := NewMeta()
+	newSpec := MetaSpec{PluginJSON: MetaJSONData{Id: "test-id", Name: "Test"}}
+	err := meta.SetSpec(newSpec)
+	require.NoError(t, err)
+
+	got, ok := meta.GetSpec().(MetaSpec)
+	require.True(t, ok)
+	assert.Equal(t, "test-id", got.PluginJSON.Id)
+}
+
+func TestMetaSetSpecRejectsWrongType(t *testing.T) {
+	meta := NewMeta()
+	err := meta.SetSpec("not-a-spec")
+	assert.Error(t, err)
+}
+
+func TestMetaDeepCopyIsIsolated(t *testing.T) {
+	meta := NewMeta()
+	meta.Name = "original"
+	meta.Spec.PluginJSON.Id = "test-plugin"
+
+	copied := meta.DeepCopy()
+	assert.Equal(t, "original", copied.Name)
+	assert.Equal(t, "test-plugin", copied.Spec.PluginJSON.Id)
+
+	copied.Name = "modified"
+	copied.Spec.PluginJSON.Id = "changed"
+	assert.Equal(t, "original", meta.Name)
+	assert.Equal(t, "test-plugin", meta.Spec.PluginJSON.Id)
+}
+
+func TestMetaListDeepCopyIsIsolated(t *testing.T) {
+	list := &MetaList{Items: []Meta{*NewMeta()}}
+	list.Items[0].Name = "item1"
+
+	copied := list.DeepCopy()
+	require.Len(t, copied.Items, 1)
+	assert.Equal(t, "item1", copied.Items[0].Name)
+
+	copied.Items[0].Name = "modified"
+	assert.Equal(t, "item1", list.Items[0].Name)
+}
+
+func TestMetaSubresourceAccess(t *testing.T) {
+	meta := NewMeta()
+
+	subs := meta.GetSubresources()
+	assert.Contains(t, subs, "status")
+
+	_, found := meta.GetSubresource("status")
+	assert.True(t, found)
+
+	_, found = meta.GetSubresource("nonexistent")
+	assert.False(t, found)
+}
+
+func TestMetaSetSubresourceValidation(t *testing.T) {
+	meta := NewMeta()
+
+	err := meta.SetSubresource("status", MetaStatus{})
+	assert.NoError(t, err)
+
+	err = meta.SetSubresource("status", "wrong-type")
+	assert.Error(t, err)
+
+	err = meta.SetSubresource("unknown", nil)
+	assert.Error(t, err)
+}
+
+func TestMetaJSONCodecRoundTrip(t *testing.T) {
+	codec := &MetaJSONCodec{}
+	original := NewMeta()
+	original.Name = "roundtrip-test"
+	original.Spec.PluginJSON.Id = "test-plugin"
+
+	var buf bytes.Buffer
+	err := codec.Write(&buf, original)
+	require.NoError(t, err)
+
+	decoded := NewMeta()
+	err = codec.Read(&buf, decoded)
+	require.NoError(t, err)
+	assert.Equal(t, "roundtrip-test", decoded.Name)
+	assert.Equal(t, "test-plugin", decoded.Spec.PluginJSON.Id)
+}
