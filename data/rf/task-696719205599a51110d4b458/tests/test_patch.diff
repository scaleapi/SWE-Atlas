+func TestMetaSpecNestedTypesExist(t *testing.T) {
+	spec := NewMetaSpec()
+	require.NotNil(t, spec)
+
+	jsonData := NewMetaJSONData()
+	require.NotNil(t, jsonData)
+	assert.Equal(t, MetaJSONDataType(""), jsonData.Type)
+
+	jsonData.Type = MetaJSONDataTypeDatasource
+	assert.Equal(t, MetaJSONDataTypeDatasource, jsonData.Type)
+	jsonData.Type = MetaJSONDataTypeApp
+	assert.Equal(t, MetaJSONDataTypeApp, jsonData.Type)
+	jsonData.Type = MetaJSONDataTypePanel
+	assert.Equal(t, MetaJSONDataTypePanel, jsonData.Type)
+	jsonData.Type = MetaJSONDataTypeRenderer
+	assert.Equal(t, MetaJSONDataTypeRenderer, jsonData.Type)
+}
