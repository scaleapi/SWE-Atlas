+func Test_getOrAdd_retrievable_via_get(t *testing.T) {
+	logger := log.NewNopLogger()
+	c := newCache()
+
+	s := State{
+		OrgID:        1,
+		AlertRuleUID: "rule-1",
+		CacheID:      data.Fingerprint(42),
+		Labels:       data.Labels{"key": "val"},
+	}
+
+	added := c.getOrAdd(s, logger)
+
+	fetched := c.get(s.OrgID, s.AlertRuleUID, s.CacheID)
+	require.NotNil(t, fetched, "state added via getOrAdd must be retrievable via get")
+	require.Equal(t, added, fetched)
+}
