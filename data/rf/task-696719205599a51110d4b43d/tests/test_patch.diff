+}
+
+func TestIOSamples_ReturnsMetricsSamples(t *testing.T) {
+	t.Parallel()
+
+	registry := metrics.NewRegistry()
+	builtinMetrics := metrics.RegisterBuiltinMetrics(registry)
+
+	dialer := NewDialer(net.Dialer{}, newResolver())
+	dialer.BytesWritten = 50
+	dialer.BytesRead = 75
+
+	sampleTime := time.Now()
+	ctm := metrics.TagsAndMeta{Tags: registry.RootTagSet()}
+
+	result := dialer.IOSamples(sampleTime, ctm, builtinMetrics)
+
+	_, ok := result.(metrics.Samples)
+	require.True(t, ok, "IOSamples should return metrics.Samples type")
+}
+
+func TestIOSamples_AtomicSwap(t *testing.T) {
+	t.Parallel()
+
+	registry := metrics.NewRegistry()
+	builtinMetrics := metrics.RegisterBuiltinMetrics(registry)
+
+	dialer := NewDialer(net.Dialer{}, newResolver())
+	dialer.BytesWritten = 1000
+	dialer.BytesRead = 2000
+
+	ctm := metrics.TagsAndMeta{Tags: registry.RootTagSet()}
+
+	result1 := dialer.IOSamples(time.Now(), ctm, builtinMetrics)
+	result2 := dialer.IOSamples(time.Now(), ctm, builtinMetrics)
+
+	require.Equal(t, float64(1000), result1.GetSamples()[0].Value)
+	require.Equal(t, float64(0), result2.GetSamples()[0].Value)
+}
