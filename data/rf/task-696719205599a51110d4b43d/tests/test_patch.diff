+func TestIOSamples(t *testing.T) {
+	t.Parallel()
+
+	registry := metrics.NewRegistry()
+	builtinMetrics := metrics.RegisterBuiltinMetrics(registry)
+
+	dialer := NewDialer(net.Dialer{}, newResolver())
+	dialer.BytesWritten = 100
+	dialer.BytesRead = 200
+
+	sampleTime := time.Now()
+	tags := registry.RootTagSet().With("test", "value")
+	ctm := metrics.TagsAndMeta{Tags: tags}
+
+	result := dialer.IOSamples(sampleTime, ctm, builtinMetrics)
+	require.NotNil(t, result)
+
+	samples := result.GetSamples()
+	require.Len(t, samples, 2)
+
+	require.Equal(t, builtinMetrics.DataSent, samples[0].Metric)
+	require.Equal(t, float64(100), samples[0].Value)
+	require.Equal(t, sampleTime, samples[0].Time)
+	require.Equal(t, tags, samples[0].Tags)
+
+	require.Equal(t, builtinMetrics.DataReceived, samples[1].Metric)
+	require.Equal(t, float64(200), samples[1].Value)
+	require.Equal(t, sampleTime, samples[1].Time)
+	require.Equal(t, tags, samples[1].Tags)
+
+	require.Equal(t, int64(0), dialer.BytesWritten)
+	require.Equal(t, int64(0), dialer.BytesRead)
+}
+
+func TestIOSamples_ZeroBytes(t *testing.T) {
+	t.Parallel()
+
+	registry := metrics.NewRegistry()
