+func TestSetUserResponse_AllFields(t *testing.T) {
+	userRes := &UserRes{
+		Login:     "testuser",
+		Type:      "User",
+		SiteAdmin: true,
+		Name:      "Test User",
+		Company:   "Test Company",
+		UserURL:   "https://github.com/testuser",
+		LdapDN:    "cn=testuser,dc=example,dc=com",
+	}
+
+	result := &detectors.Result{
+		ExtraData: make(map[string]string),
+	}
+
+	SetUserResponse(userRes, result)
+
+	if result.ExtraData["username"] != "testuser" {
+		t.Errorf("expected username 'testuser', got '%s'", result.ExtraData["username"])
+	}
+	if result.ExtraData["url"] != "https://github.com/testuser" {
+		t.Errorf("expected url 'https://github.com/testuser', got '%s'", result.ExtraData["url"])
+	}
+	if result.ExtraData["account_type"] != "User" {
+		t.Errorf("expected account_type 'User', got '%s'", result.ExtraData["account_type"])
+	}
+	if result.ExtraData["site_admin"] != "true" {
+		t.Errorf("expected site_admin 'true', got '%s'", result.ExtraData["site_admin"])
+	}
+	if result.ExtraData["name"] != "Test User" {
+		t.Errorf("expected name 'Test User', got '%s'", result.ExtraData["name"])
+	}
+	if result.ExtraData["company"] != "Test Company" {
+		t.Errorf("expected company 'Test Company', got '%s'", result.ExtraData["company"])
+	}
+	if result.ExtraData["ldap_dn"] != "cn=testuser,dc=example,dc=com" {
+		t.Errorf("expected ldap_dn 'cn=testuser,dc=example,dc=com', got '%s'", result.ExtraData["ldap_dn"])
+	}
+}
