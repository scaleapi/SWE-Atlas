+func TestVerifyGithub_Success(t *testing.T) {
+	userJSON := `{
+		"login": "verifieduser",
+		"type": "User",
+		"site_admin": false,
+		"name": "Verified User",
+		"company": "",
+		"html_url": "https://github.com/verifieduser",
+		"ldap_dn": ""
+	}`
+
+	header := http.Header{}
+	header.Set("X-OAuth-Scopes", "repo,user")
+	header.Set("github-authentication-token-expiration", "2025-12-31 23:59:59 UTC")
+
+	transport := &mockTransport{
+		response: &http.Response{
+			StatusCode: 200,
+			Body:       io.NopCloser(strings.NewReader(userJSON)),
+			Header:     header,
+		},
+	}
+
+	client := &http.Client{Transport: transport}
+	scanner := Scanner{}
+
+	verified, userRes, headers, err := scanner.VerifyGithub(context.Background(), client, "test_token")
+
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if !verified {
+		t.Error("expected verified to be true")
+	}
+	if userRes == nil {
+		t.Fatal("expected userRes to not be nil")
+	}
+	if userRes.Login != "verifieduser" {
+		t.Errorf("expected login 'verifieduser', got '%s'", userRes.Login)
+	}
+	if userRes.Type != "User" {
+		t.Errorf("expected type 'User', got '%s'", userRes.Type)
+	}
+	if userRes.Name != "Verified User" {
+		t.Errorf("expected name 'Verified User', got '%s'", userRes.Name)
+	}
+	if headers == nil {
+		t.Fatal("expected headers to not be nil")
+	}
+	if headers.Scopes != "repo,user" {
+		t.Errorf("expected scopes 'repo,user', got '%s'", headers.Scopes)
+	}
+	if headers.Expiry != "2025-12-31 23:59:59 UTC" {
+		t.Errorf("expected expiry '2025-12-31 23:59:59 UTC', got '%s'", headers.Expiry)
+	}
+}
