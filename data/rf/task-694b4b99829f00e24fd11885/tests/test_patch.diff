+func TestScanner_V1_FromData_MultipleMatches(t *testing.T) {
+	s := Scanner{}
+	ctx := context.Background()
+	
+	// Avoid tokens containing false positive patterns like "abcde"
+	data := []byte("github token=f9e8d7c6b5a4039281706f5e4d3c2b1a09f8e7d6 and gh key:a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2")
