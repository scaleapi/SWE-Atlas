+type mockTransport struct {
+	response   *http.Response
+	err        error
+	requestURL string
+}
+
+func (m *mockTransport) RoundTrip(req *http.Request) (*http.Response, error) {
+	m.requestURL = req.URL.String()
+	if m.err != nil {
+		return nil, m.err
+	}
+	return m.response, nil
