+func TestScanner_V1_FromData_NoVerify(t *testing.T) {
+	s := Scanner{}
+	ctx := context.Background()
+	
+	// v1 regex: (?i)(?:github|gh|pat|token)[^\.].{0,40}[ =:'"]+([a-f0-9]{40})\b
+	// The token must be exactly 40 hex chars, avoid "abcde" which is a false positive
+	data := []byte("github token=f9e8d7c6b5a4039281706f5e4d3c2b1a09f8e7d6")
+	results, err := s.FromData(ctx, false, data)
+	
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if len(results) != 1 {
+		t.Fatalf("expected 1 result, got %d", len(results))
+	}
+	if results[0].DetectorType != detectorspb.DetectorType_Github {
+		t.Error("expected DetectorType_Github")
+	}
+	if results[0].ExtraData["version"] != "1" {
+		t.Errorf("expected version '1', got '%s'", results[0].ExtraData["version"])
+	}
+	if results[0].ExtraData["rotation_guide"] != "https://howtorotate.com/docs/tutorials/github/" {
+		t.Error("expected rotation_guide to be set")
+	}
+}
