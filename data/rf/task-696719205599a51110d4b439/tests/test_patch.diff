+func TestElementHandleBaseOptionsParse(t *testing.T) {
+	t.Parallel()
+
+	t.Run("nil_opts_preserves_defaults", func(t *testing.T) {
+		t.Parallel()
+
+		vu := k6test.NewVU(t)
+		baseOpts := NewElementHandleBaseOptions(30 * time.Second)
+		err := baseOpts.Parse(vu.Context(), nil)
+		require.NoError(t, err)
+
+		assert.Equal(t, 30*time.Second, baseOpts.Timeout)
+		assert.False(t, baseOpts.Force)
+		assert.False(t, baseOpts.NoWaitAfter)
+	})
+
+	t.Run("undefined_opts_preserves_defaults", func(t *testing.T) {
+		t.Parallel()
+
+		vu := k6test.NewVU(t)
+		baseOpts := NewElementHandleBaseOptions(30 * time.Second)
+		err := baseOpts.Parse(vu.Context(), sobek.Undefined())
+		require.NoError(t, err)
+
+		assert.Equal(t, 30*time.Second, baseOpts.Timeout)
+		assert.False(t, baseOpts.Force)
+		assert.False(t, baseOpts.NoWaitAfter)
+	})
+
+	t.Run("null_opts_preserves_defaults", func(t *testing.T) {
+		t.Parallel()
+
+		vu := k6test.NewVU(t)
+		baseOpts := NewElementHandleBaseOptions(30 * time.Second)
+		err := baseOpts.Parse(vu.Context(), sobek.Null())
+		require.NoError(t, err)
+
+		assert.Equal(t, 30*time.Second, baseOpts.Timeout)
+		assert.False(t, baseOpts.Force)
+		assert.False(t, baseOpts.NoWaitAfter)
+	})
+
+	t.Run("valid_opts_overrides_defaults", func(t *testing.T) {
+		t.Parallel()
+
+		vu := k6test.NewVU(t)
+		opts := vu.ToSobekValue(map[string]any{
+			"timeout":     "5000",
+			"force":       true,
+			"noWaitAfter": true,
+		})
+		baseOpts := NewElementHandleBaseOptions(30 * time.Second)
+		err := baseOpts.Parse(vu.Context(), opts)
+		require.NoError(t, err)
+
+		assert.Equal(t, 5*time.Second, baseOpts.Timeout)
+		assert.True(t, baseOpts.Force)
+		assert.True(t, baseOpts.NoWaitAfter)
+	})
+}
