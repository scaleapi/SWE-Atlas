+func TestParseGetByRoleOptionsWithValidOptions(t *testing.T) {
+	t.Parallel()
+
+	vu := k6test.NewVU(t)
+
+	optsObj, err := vu.Runtime().RunString(`({
+		checked: true,
+		disabled: false,
+		exact: true,
+		expanded: true,
+		includeHidden: false,
+		level: 2,
+		name: "test-name",
+		pressed: true,
+		selected: false
+	})`)
+	require.NoError(t, err)
+
+	parsedOpts := parseGetByRoleOptions(vu.Context(), optsObj)
+	assert.NotNil(t, parsedOpts)
+	assert.NotNil(t, parsedOpts.Checked)
+	assert.True(t, *parsedOpts.Checked)
+	assert.NotNil(t, parsedOpts.Disabled)
+	assert.False(t, *parsedOpts.Disabled)
+	assert.NotNil(t, parsedOpts.Exact)
+	assert.True(t, *parsedOpts.Exact)
+	assert.NotNil(t, parsedOpts.Expanded)
+	assert.True(t, *parsedOpts.Expanded)
+	assert.NotNil(t, parsedOpts.IncludeHidden)
+	assert.False(t, *parsedOpts.IncludeHidden)
+	assert.NotNil(t, parsedOpts.Level)
+	assert.Equal(t, int64(2), *parsedOpts.Level)
+	assert.NotNil(t, parsedOpts.Name)
+	assert.Equal(t, "'test-name'", *parsedOpts.Name)
+	assert.NotNil(t, parsedOpts.Pressed)
+	assert.True(t, *parsedOpts.Pressed)
+	assert.NotNil(t, parsedOpts.Selected)
+	assert.False(t, *parsedOpts.Selected)
+}
