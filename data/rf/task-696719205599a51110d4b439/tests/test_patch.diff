+package browser
+
+import (
+	"testing"
+	"time"
+
+	"github.com/grafana/sobek"
+	"github.com/stretchr/testify/assert"
+	"github.com/stretchr/testify/require"
+
+	"go.k6.io/k6/internal/js/modules/k6/browser/k6ext/k6test"
+)
+
+func TestParseWaitForEventOptionsNullishHandling(t *testing.T) {
+	t.Parallel()
+
+	defaultTimeout := 30 * time.Second
+
+	tests := []struct {
+		name     string
+		getValue func(*sobek.Runtime) sobek.Value
+	}{
+		{
+			name: "nil_returns_default_options",
+			getValue: func(rt *sobek.Runtime) sobek.Value {
+				return nil
+			},
+		},
+		{
+			name: "undefined_returns_default_options",
+			getValue: func(rt *sobek.Runtime) sobek.Value {
+				return sobek.Undefined()
+			},
+		},
+		{
+			name: "null_returns_default_options",
+			getValue: func(rt *sobek.Runtime) sobek.Value {
+				return sobek.Null()
+			},
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			t.Parallel()
+
+			vu := k6test.NewVU(t)
+			opts := tt.getValue(vu.Runtime())
+
+			parsedOpts, err := parseWaitForEventOptions(vu.Runtime(), opts, defaultTimeout)
+			assert.NoError(t, err)
+			assert.NotNil(t, parsedOpts)
+			assert.Equal(t, defaultTimeout, parsedOpts.Timeout)
+			assert.Nil(t, parsedOpts.PredicateFn)
+		})
+	}
+}
+
+func TestParseWaitForEventOptionsWithPredicate(t *testing.T) {
+	t.Parallel()
+
+	vu := k6test.NewVU(t)
+	defaultTimeout := 30 * time.Second
+
+	predicateFn, err := vu.Runtime().RunString(`(function() { return true; })`)
+	require.NoError(t, err)
+
+	parsedOpts, err := parseWaitForEventOptions(vu.Runtime(), predicateFn, defaultTimeout)
+	assert.NoError(t, err)
+	assert.NotNil(t, parsedOpts)
+	assert.Equal(t, defaultTimeout, parsedOpts.Timeout)
+	assert.NotNil(t, parsedOpts.PredicateFn)
+}
+
+func TestParseWaitForEventOptionsWithObject(t *testing.T) {
+	t.Parallel()
+
+	vu := k6test.NewVU(t)
+	defaultTimeout := 30 * time.Second
+
+	optsObj, err := vu.Runtime().RunString(`({
+		predicate: function() { return true; },
+		timeout: 5000
+	})`)
+	require.NoError(t, err)
+
+	parsedOpts, err := parseWaitForEventOptions(vu.Runtime(), optsObj, defaultTimeout)
+	assert.NoError(t, err)
+	assert.NotNil(t, parsedOpts)
+	assert.Equal(t, 5*time.Second, parsedOpts.Timeout)
+	assert.NotNil(t, parsedOpts.PredicateFn)
+}
+
+func TestParseWaitForEventOptionsInvalidPredicate(t *testing.T) {
+	t.Parallel()
+
+	vu := k6test.NewVU(t)
+	defaultTimeout := 30 * time.Second
+
+	optsObj, err := vu.Runtime().RunString(`({
+		predicate: "not a function",
+		timeout: 5000
+	})`)
+	require.NoError(t, err)
+
+	_, err = parseWaitForEventOptions(vu.Runtime(), optsObj, defaultTimeout)
+	assert.Error(t, err)
+	assert.Contains(t, err.Error(), "predicate function is not callable")
+}
+
+func TestParseWaitForEventOptionsUnknownOption(t *testing.T) {
+	t.Parallel()
+
+	vu := k6test.NewVU(t)
+	defaultTimeout := 30 * time.Second
+
+	optsObj, err := vu.Runtime().RunString(`({
+		unknownOption: "value"
+	})`)
+	require.NoError(t, err)
+
+	_, err = parseWaitForEventOptions(vu.Runtime(), optsObj, defaultTimeout)
+	assert.Error(t, err)
+	assert.Contains(t, err.Error(), "unknown option")
+}
