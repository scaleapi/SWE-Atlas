+// TestGetRuntimeOptionsIntegration tests the full getRuntimeOptions flow
+// with various combinations of flags and environment variables.
+func TestGetRuntimeOptionsIntegration(t *testing.T) {
+	t.Parallel()
+
+	t.Run("env vars combined with flags", func(t *testing.T) {
+		t.Parallel()
+		flags := runtimeOptionFlagSet(true)
+		require.NoError(t, flags.Parse([]string{"--env", "CLI_VAR=cli_value"}))
+		env := map[string]string{
+			"SYS_VAR":                    "sys_value",
+			"K6_COMPATIBILITY_MODE":      "extended",
+			"K6_INCLUDE_SYSTEM_ENV_VARS": "true",
+		}
+		opts, err := getRuntimeOptions(flags, env)
+		require.NoError(t, err)
+		assert.Equal(t, "cli_value", opts.Env["CLI_VAR"])
+		assert.Equal(t, "sys_value", opts.Env["SYS_VAR"])
+	})
+
+	t.Run("cli flag overrides env var", func(t *testing.T) {
+		t.Parallel()
+		flags := runtimeOptionFlagSet(false)
+		require.NoError(t, flags.Parse([]string{"--compatibility-mode", "base"}))
+		env := map[string]string{"K6_COMPATIBILITY_MODE": "extended"}
+		opts, err := getRuntimeOptions(flags, env)
+		require.NoError(t, err)
+		assert.Equal(t, null.NewString("base", true), opts.CompatibilityMode)
+	})
+}
