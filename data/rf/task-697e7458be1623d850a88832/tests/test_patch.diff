+// TestPopulateRuntimeOptionsFromEnv tests the populateRuntimeOptionsFromEnv function
+// to ensure environment variables are properly applied to runtime options.
+func TestPopulateRuntimeOptionsFromEnv(t *testing.T) {
+	t.Parallel()
+
+	testCases := []struct {
+		name      string
+		baseOpts  lib.RuntimeOptions
+		env       map[string]string
+		expectErr bool
+		check     func(t *testing.T, opts lib.RuntimeOptions)
+	}{
+		{
+			name: "K6_TYPE from env",
+			baseOpts: lib.RuntimeOptions{
+				Env: make(map[string]string),
+			},
+			env: map[string]string{"K6_TYPE": "archive"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewString("archive", true), opts.TestType)
+			},
+		},
+		{
+			name: "K6_TYPE not overwritten when already set",
+			baseOpts: lib.RuntimeOptions{
+				TestType: null.NewString("js", true),
+				Env:      make(map[string]string),
+			},
+			env: map[string]string{"K6_TYPE": "archive"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewString("js", true), opts.TestType)
+			},
+		},
+		{
+			name: "K6_COMPATIBILITY_MODE from env",
+			baseOpts: lib.RuntimeOptions{
+				Env: make(map[string]string),
+			},
+			env: map[string]string{"K6_COMPATIBILITY_MODE": "base"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewString("base", true), opts.CompatibilityMode)
+			},
+		},
+		{
+			name: "K6_INCLUDE_SYSTEM_ENV_VARS true",
+			baseOpts: lib.RuntimeOptions{
+				Env: make(map[string]string),
+			},
+			env: map[string]string{"K6_INCLUDE_SYSTEM_ENV_VARS": "true"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewBool(true, true), opts.IncludeSystemEnvVars)
+			},
+		},
+		{
+			name: "K6_INCLUDE_SYSTEM_ENV_VARS invalid",
+			baseOpts: lib.RuntimeOptions{
+				Env: make(map[string]string),
+			},
+			env:       map[string]string{"K6_INCLUDE_SYSTEM_ENV_VARS": "notabool"},
+			expectErr: true,
+		},
+		{
+			name: "K6_NO_THRESHOLDS from env",
+			baseOpts: lib.RuntimeOptions{
+				Env: make(map[string]string),
+			},
+			env: map[string]string{"K6_NO_THRESHOLDS": "true"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewBool(true, true), opts.NoThresholds)
+			},
+		},
+		{
+			name: "K6_NO_SUMMARY from env",
+			baseOpts: lib.RuntimeOptions{
+				Env: make(map[string]string),
+			},
+			env: map[string]string{"K6_NO_SUMMARY": "1"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewBool(true, true), opts.NoSummary)
+			},
+		},
+		{
+			name: "K6_SUMMARY_EXPORT from env",
+			baseOpts: lib.RuntimeOptions{
+				Env: make(map[string]string),
+			},
+			env: map[string]string{"K6_SUMMARY_EXPORT": "report.json"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewString("report.json", true), opts.SummaryExport)
+			},
+		},
+		{
+			name: "SSLKEYLOGFILE from env",
+			baseOpts: lib.RuntimeOptions{
+				Env: make(map[string]string),
+			},
+			env: map[string]string{"SSLKEYLOGFILE": "/tmp/keys.log"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewString("/tmp/keys.log", true), opts.KeyWriter)
+			},
+		},
+		{
+			name: "K6_TRACES_OUTPUT from env",
+			baseOpts: lib.RuntimeOptions{
+				Env: make(map[string]string),
+			},
+			env: map[string]string{"K6_TRACES_OUTPUT": "otel"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewString("otel", true), opts.TracesOutput)
+			},
+		},
+		{
+			name: "system env vars included when enabled",
+			baseOpts: lib.RuntimeOptions{
+				IncludeSystemEnvVars: null.NewBool(true, true),
+				Env:                  make(map[string]string),
+			},
+			env: map[string]string{"MY_VAR": "my_value"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, "my_value", opts.Env["MY_VAR"])
+			},
+		},
+	}
+
+	for _, tc := range testCases {
+		tc := tc
+		t.Run(tc.name, func(t *testing.T) {
+			t.Parallel()
+			opts, err := populateRuntimeOptionsFromEnv(tc.baseOpts, tc.env)
+			if tc.expectErr {
+				require.Error(t, err)
+				return
+			}
+			require.NoError(t, err)
+			if tc.check != nil {
+				tc.check(t, opts)
+			}
+		})
+	}
+}
