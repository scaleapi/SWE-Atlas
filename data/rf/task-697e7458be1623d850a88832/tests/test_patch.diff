+// TestSaveBoolFromEnv tests the saveBoolFromEnv helper function
+func TestSaveBoolFromEnv(t *testing.T) {
+	t.Parallel()
+
+	testCases := []struct {
+		name        string
+		env         map[string]string
+		varName     string
+		placeholder null.Bool
+		expectErr   bool
+		expected    null.Bool
+	}{
+		{
+			name:        "var not present",
+			env:         map[string]string{},
+			varName:     "K6_TEST",
+			placeholder: null.Bool{},
+			expected:    null.Bool{},
+		},
+		{
+			name:        "var present true",
+			env:         map[string]string{"K6_TEST": "true"},
+			varName:     "K6_TEST",
+			placeholder: null.Bool{},
+			expected:    null.NewBool(true, true),
+		},
+		{
+			name:        "var present false",
+			env:         map[string]string{"K6_TEST": "false"},
+			varName:     "K6_TEST",
+			placeholder: null.Bool{},
+			expected:    null.NewBool(false, true),
+		},
+		{
+			name:        "var present 1",
+			env:         map[string]string{"K6_TEST": "1"},
+			varName:     "K6_TEST",
+			placeholder: null.Bool{},
+			expected:    null.NewBool(true, true),
+		},
+		{
+			name:        "var present 0",
+			env:         map[string]string{"K6_TEST": "0"},
+			varName:     "K6_TEST",
+			placeholder: null.Bool{},
+			expected:    null.NewBool(false, true),
+		},
+		{
+			name:        "invalid bool value",
+			env:         map[string]string{"K6_TEST": "invalid"},
+			varName:     "K6_TEST",
+			placeholder: null.Bool{},
+			expectErr:   true,
+		},
+		{
+			name:        "already set placeholder not overwritten",
+			env:         map[string]string{"K6_TEST": "true"},
+			varName:     "K6_TEST",
+			placeholder: null.NewBool(false, true),
+			expected:    null.NewBool(false, true),
+		},
+	}
+
+	for _, tc := range testCases {
+		tc := tc
+		t.Run(tc.name, func(t *testing.T) {
+			t.Parallel()
+			placeholder := tc.placeholder
+			err := saveBoolFromEnv(tc.env, tc.varName, &placeholder)
+			if tc.expectErr {
+				require.Error(t, err)
+				return
+			}
+			require.NoError(t, err)
+			assert.Equal(t, tc.expected, placeholder)
+		})
+	}
+}
