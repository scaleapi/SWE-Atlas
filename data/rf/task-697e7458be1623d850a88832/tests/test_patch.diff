+// TestRuntimeOptionsFromFlags tests the runtimeOptionsFromFlags function directly
+// to ensure proper flag parsing and default value handling.
+func TestRuntimeOptionsFromFlags(t *testing.T) {
+	t.Parallel()
+
+	testCases := []struct {
+		name      string
+		useSysEnv bool
+		cliFlags  []string
+		check     func(t *testing.T, opts lib.RuntimeOptions)
+	}{
+		{
+			name:      "default values with sys env enabled",
+			useSysEnv: true,
+			cliFlags:  []string{},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewBool(true, false), opts.IncludeSystemEnvVars)
+				assert.Equal(t, null.NewString("extended", false), opts.CompatibilityMode)
+				assert.Equal(t, null.NewString("none", false), opts.TracesOutput)
+				assert.NotNil(t, opts.Env)
+			},
+		},
+		{
+			name:      "default values with sys env disabled",
+			useSysEnv: false,
+			cliFlags:  []string{},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewBool(false, false), opts.IncludeSystemEnvVars)
+				assert.Equal(t, null.NewString("extended", false), opts.CompatibilityMode)
+			},
+		},
+		{
+			name:      "test type flag",
+			useSysEnv: false,
+			cliFlags:  []string{"--type", "js"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewString("js", true), opts.TestType)
+			},
+		},
+		{
+			name:      "compatibility mode base",
+			useSysEnv: false,
+			cliFlags:  []string{"--compatibility-mode", "base"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewString("base", true), opts.CompatibilityMode)
+			},
+		},
+		{
+			name:      "no-thresholds flag",
+			useSysEnv: false,
+			cliFlags:  []string{"--no-thresholds"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewBool(true, true), opts.NoThresholds)
+			},
+		},
+		{
+			name:      "no-summary flag",
+			useSysEnv: false,
+			cliFlags:  []string{"--no-summary"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewBool(true, true), opts.NoSummary)
+			},
+		},
+		{
+			name:      "summary-export flag",
+			useSysEnv: false,
+			cliFlags:  []string{"--summary-export", "output.json"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewString("output.json", true), opts.SummaryExport)
+			},
+		},
+		{
+			name:      "traces-output flag",
+			useSysEnv: false,
+			cliFlags:  []string{"--traces-output", "otel=localhost:4317"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewString("otel=localhost:4317", true), opts.TracesOutput)
+			},
+		},
+		{
+			name:      "multiple flags combined",
+			useSysEnv: true,
+			cliFlags:  []string{"--no-thresholds", "--no-summary", "--compatibility-mode", "base"},
+			check: func(t *testing.T, opts lib.RuntimeOptions) {
+				assert.Equal(t, null.NewBool(true, true), opts.NoThresholds)
+				assert.Equal(t, null.NewBool(true, true), opts.NoSummary)
+				assert.Equal(t, null.NewString("base", true), opts.CompatibilityMode)
+			},
+		},
+	}
+
+	for _, tc := range testCases {
+		tc := tc
+		t.Run(tc.name, func(t *testing.T) {
+			t.Parallel()
+			flags := runtimeOptionFlagSet(tc.useSysEnv)
+			require.NoError(t, flags.Parse(tc.cliFlags))
+			opts := runtimeOptionsFromFlags(flags)
+			tc.check(t, opts)
+		})
+	}
+}
