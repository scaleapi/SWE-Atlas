diff --git a/js/compiler/sourcemap_wrap_test.go b/js/compiler/sourcemap_wrap_test.go
new file mode 100644
--- /dev/null
+++ b/js/compiler/sourcemap_wrap_test.go
@@ -0,0 +1,27 @@
+package compiler
+
+import (
+	"testing"
+
+	"github.com/grafana/sobek"
+	"github.com/stretchr/testify/assert"
+	"github.com/stretchr/testify/require"
+
+	"go.k6.io/k6/lib/testutils"
+)
+
+func TestParseWrapWithInlineSourceMap(t *testing.T) {
+	t.Parallel()
+	c := New(testutils.NewLogger(t))
+
+	src := "var x = 1;\n//# sourceMappingURL=data:application/json;base64," +
+		"eyJ2ZXJzaW9uIjozLCJzb3VyY2VzIjpbInNjcmlwdC5qcyJdLCJuYW1lcyI6W10sIm1hcHBpbmdzIjoiQUFBQSJ9"
+
+	prg, code, err := c.Parse(src, "script.js", true)
+	require.NoError(t, err)
+	assert.Contains(t, code, "(function(module, exports){")
+	assert.Contains(t, code, "sourceMappingURL")
+	assert.NotContains(t, code, "sourcemappingurl")
+	_, err = sobek.CompileAST(prg, true)
+	require.NoError(t, err)
+}
