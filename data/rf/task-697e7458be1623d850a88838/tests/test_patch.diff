+= ServiceEnumerator raises exception when socket closes during scan
+
+~ closed_socket_test
+
+def _make_closing_socket():
+    _state = [0]
+    class _CS(object):
+        @property
+        def closed(self):
+            return _state[0] > 0
+        def sr1(self, *args, **kwargs):
+            _state[0] += 1
+            return UDS(b"\x7f\x01\x10")
+    return _CS()
+
+_e_close = MyTestCase()
+_raised = False
+try:
+    _e_close.execute(_make_closing_socket(), EcuState(session=1))
+except Exception:
+    _raised = True
+
+assert _raised, "Expected exception when socket closes during scan"
+
+= ServiceEnumerator negative and positive response properties only include entries with responses
+
+~ response_filter_test
+
+def _test_response_filtering():
+    e = MyTestCase()
+    r1 = UDS(b"\x20abcd")
+    r1.time = 1.0
+    r1.sent_time = 1.0
+    rn = UDS(b"\x7f\x20\x10")
+    rn.time = 1.1
+    e._store_result(EcuState(session=1), r1, rn)
+    r2 = UDS(b"\x21abcd")
+    r2.time = 2.0
+    r2.sent_time = 2.0
+    e._store_result(EcuState(session=1), r2, None)
+    r3 = UDS(b"\x22abcd")
+    r3.time = 3.0
+    r3.sent_time = 3.0
+    rp = UDS(b"\x62abcd")
+    rp.time = 3.1
+    e._store_result(EcuState(session=1), r3, rp)
+    neg = e.results_with_negative_response
+    pos = e.results_with_positive_response
+    resp = e.results_with_response
+    for x in neg:
+        assert x in resp, "Negative response entry must be in results_with_response"
+    for x in pos:
+        assert x in resp, "Positive response entry must be in results_with_response"
+    assert len(neg) == 1
+    assert len(pos) == 1
+    assert len(resp) == 2
+    assert len(e.results_without_response) == 1
+
+_test_response_filtering()
+
+= ServiceEnumerator retry on None produces more debug output than no-retry baseline
+
+~ retry_none_log_test
+
+import logging
+from scapy.error import log_interactive
+
+def _test_retry_none_log():
+    _records = []
+    class _H(logging.Handler):
+        def emit(self, record):
+            _records.append(record)
+    h = _H()
+    h.setLevel(logging.DEBUG)
+    log_interactive.addHandler(h)
+    old = log_interactive.level
+    log_interactive.setLevel(logging.DEBUG)
+    try:
+        s1 = MockISOTPSocket()
+        s1.rcvd_queue.put(UDS(b"\x7f\x01\x10"))
+        e1 = MyTestCase()
+        e1.execute(s1, EcuState(session=1), timeout=0.01)
+        b = len([r for r in _records if r.levelno == logging.DEBUG])
+        _records[:] = []
+        s2 = MockISOTPSocket()
+        s2.rcvd_queue.put(UDS(b"\x7f\x01\x10"))
+        e2 = MyTestCase()
+        e2.execute(s2, EcuState(session=1), retry_if_none_received=True, timeout=0.01)
+        a = len([r for r in _records if r.levelno == logging.DEBUG])
+    finally:
+        log_interactive.removeHandler(h)
+        log_interactive.setLevel(old)
+    return a, b
+
+_retry_a, _retry_b = _test_retry_none_log()
+assert _retry_a > _retry_b, "Retries should produce more debug log output than baseline (%d vs %d)" % (_retry_a, _retry_b)
+
