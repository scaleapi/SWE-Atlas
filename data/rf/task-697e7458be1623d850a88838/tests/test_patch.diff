+import scapy.tools.automotive.obdscanner as _obdmod
+import inspect as _inspect
+
+assert hasattr(_obdmod, "get_can_socket"), "obdscanner must expose get_can_socket"
+assert callable(_obdmod.get_can_socket)
+assert hasattr(_obdmod, "get_isotp_socket"), "obdscanner must expose get_isotp_socket"
