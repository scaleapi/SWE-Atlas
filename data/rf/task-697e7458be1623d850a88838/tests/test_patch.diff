+= OBD get_supported handles non-iterable PID fields without crashing
+
+import queue as _queue
+from scapy.contrib.automotive.obd.obd import OBD, OBD_S01, OBD_S01_PR, OBD_S01_PR_Record, OBD_PID00, OBD_PID03, OBD_PID0B, OBD_PID0F, OBD_NR
+from scapy.contrib.automotive.obd.scanner import OBD_S01_Enumerator
+
+class _OBDMockSocket:
+    def __init__(self, responses):
+        self.q = _queue.Queue()
+        for r in responses:
+            self.q.put(r)
+        self.closed = False
+    def sr1(self, pkt, timeout=None, verbose=None):
+        try:
+            return self.q.get(timeout=0.1)
+        except _queue.Empty:
+            return None
+    def close(self):
+        self.closed = True
+
+def _test_get_supported_handles_type_error():
+    responses = [OBD(service=65)/OBD_S01_PR(data_records=[OBD_S01_PR_Record(pid=0)/OBD_PID00(supported_pids="PID03+PID0B+PID0F")]), OBD(service=65)/OBD_S01_PR(data_records=[OBD_S01_PR_Record(pid=0x20)]), OBD(service=127)/OBD_NR(request_service_id=1, response_code=0x12)]
+    sock = _OBDMockSocket(responses)
+    e = OBD_S01_Enumerator()
+    result = e.get_supported(sock, EcuState(session=1))
+    assert 3 in result
+    assert 11 in result
+    assert 15 in result
+    assert len(result) == len(set(result))
+
+_test_get_supported_handles_type_error()
+
+= OBD get_supported returns deduplicated PID values
+
+def _test_get_supported_dedup():
+    responses = [OBD(service=65)/OBD_S01_PR(data_records=[OBD_S01_PR_Record(pid=0)/OBD_PID00(supported_pids="PID03+PID0B+PID0F")]), OBD(service=127)/OBD_NR(request_service_id=1, response_code=0x12)]
+    sock = _OBDMockSocket(responses)
+    e = OBD_S01_Enumerator()
+    result = e.get_supported(sock, EcuState(session=1))
+    assert len(result) == len(set(result)), "Supported PIDs must be unique"
+    assert 3 in result
+    assert 11 in result
+    assert 15 in result
+
+_test_get_supported_dedup()
+
