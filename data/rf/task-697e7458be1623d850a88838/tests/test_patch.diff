+= get_can_socket returns a socket for native backend
+
+def _test_get_can_socket_native():
+    _orig = _obdmod.PYTHON_CAN
+    try:
+        _obdmod.PYTHON_CAN = False
+        from unittest.mock import MagicMock, patch
+        with patch.object(_obdmod, 'CANSocket', return_value=MagicMock()) as mock_cs:
+            result = _obdmod.get_can_socket("vcan0", None, None)
+            mock_cs.assert_called_once()
+            call_args = mock_cs.call_args
+            all_vals = list(call_args[0]) + list(call_args[1].values())
+            assert "vcan0" in all_vals, "get_can_socket must forward the channel to CANSocket"
+            assert result is not None
+    finally:
+        _obdmod.PYTHON_CAN = _orig
+
+_test_get_can_socket_native()
+
