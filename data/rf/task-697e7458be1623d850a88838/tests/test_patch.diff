+= main() cleans up sockets in finally block even on failure
+
+def _test_main_cleanup_on_failure():
+    from unittest.mock import MagicMock, patch
+    import sys as _sys
+    import signal as _signal
+    mock_csock = MagicMock()
+    mock_isock = MagicMock()
+    _saved = _sys.argv[:]
+    _sys.argv = ['obdscanner', '-c', 'vcan0', '-s', '7e0', '-d', '7e8', '-1']
+    try:
+        with patch.object(_obdmod, 'get_can_socket', return_value=mock_csock), \
+             patch.object(_obdmod, 'get_isotp_socket', return_value=mock_isock), \
+             patch.object(_obdmod, 'run_scan', side_effect=Exception("test error")), \
+             patch.object(_signal, 'signal'):
+            try:
+                _obdmod.main()
+            except SystemExit:
+                pass
+        mock_isock.close.assert_called_once()
+        mock_csock.close.assert_called_once()
+    finally:
+        _sys.argv = _saved
+
+_test_main_cleanup_on_failure()
