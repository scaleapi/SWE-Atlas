+= get_can_socket, get_isotp_socket, run_scan have correct parameter counts
+
+_gcs_params = list(_inspect.signature(_obdmod.get_can_socket).parameters.keys())
+assert len(_gcs_params) == 3, "get_can_socket should accept 3 parameters, got %d" % len(_gcs_params)
+
+_gis_params = list(_inspect.signature(_obdmod.get_isotp_socket).parameters.keys())
+assert len(_gis_params) == 3, "get_isotp_socket should accept 3 parameters, got %d" % len(_gis_params)
+
+_rs_params = list(_inspect.signature(_obdmod.run_scan).parameters.keys())
+assert len(_rs_params) == 5, "run_scan should accept 5 parameters, got %d" % len(_rs_params)
