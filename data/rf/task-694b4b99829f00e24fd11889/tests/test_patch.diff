+// TestDefaultHandlerFilesProcessedOnSuccess verifies that the default handler
+// increments filesProcessed when it successfully processes content.
+func TestDefaultHandlerFilesProcessedOnSuccess(t *testing.T) {
+	handler := newDefaultHandler(defaultHandlerType)
+	label := string(defaultHandlerType)
+
+	file, err := os.Open("testdata/nonarchive.txt")
+	assert.NoError(t, err)
+	defer file.Close()
+
+	rdr, err := newFileReader(file)
+	assert.NoError(t, err)
+	defer rdr.Close()
+
+	before := counterValue(handler.metrics.filesProcessed, label)
+
+	ctx := logContext.AddLogger(logContext.Background())
+	dataChan, err := handler.HandleFile(ctx, rdr)
+	assert.NoError(t, err)
+
+	count := 0
+	for range dataChan {
+		count++
+	}
+	assert.Greater(t, count, 0, "should produce output for valid text content")
+
+	after := counterValue(handler.metrics.filesProcessed, label)
+	assert.Greater(t, after, before, "filesProcessed must increment on successful processing")
+}
