+type errorPanicReader struct{}
+
+func (r errorPanicReader) Read(p []byte) (int, error) {
+	panic(errors.New("induced error panic"))
+}
+
+type stringPanicReader struct{}
+
+func (r stringPanicReader) Read(p []byte) (int, error) {
+	panic("induced string panic")
+}
+
+func counterValue(cv *prometheus.CounterVec, label string) float64 {
+	c, err := cv.GetMetricWithLabelValues(label)
+	if err != nil {
+		return 0
+	}
+	var m dto.Metric
+	c.Write(&m)
+	return m.GetCounter().GetValue()
+}
