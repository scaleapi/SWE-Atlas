+// TestARHandlerFilesProcessedOnlyOnSuccess verifies that the AR handler
+// does not count files as processed when they fail to load.
+func TestARHandlerFilesProcessedOnlyOnSuccess(t *testing.T) {
+	handler := newARHandler()
+	label := string(arHandlerType)
+
+	rdr, err := newFileReader(strings.NewReader("not a valid AR archive"))
+	assert.NoError(t, err)
+	defer rdr.Close()
+
+	before := counterValue(handler.metrics.filesProcessed, label)
+
+	ctx := logContext.AddLogger(logContext.Background())
+	archiveChan, err := handler.HandleFile(ctx, rdr)
+	assert.NoError(t, err)
+
+	for range archiveChan {
+	}
+
+	after := counterValue(handler.metrics.filesProcessed, label)
+	assert.Equal(t, before, after, "filesProcessed must not increment when AR loading fails")
+}
