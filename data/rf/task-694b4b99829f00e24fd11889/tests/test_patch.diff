+// TestARHandlerPanicRecoveryWithError verifies the AR handler recovers from
+// panics that produce error values without crashing.
+func TestARHandlerPanicRecoveryWithError(t *testing.T) {
+	handler := newARHandler()
+
+	rdr := fileReader{
+		BufferedReadSeeker: iobuf.NewBufferedReaderSeeker(errorPanicReader{}),
+		mime:               mimetype.Detect([]byte("")),
+	}
+
+	ctx := logContext.AddLogger(logContext.Background())
+	archiveChan, err := handler.HandleFile(ctx, rdr)
+	assert.NoError(t, err)
+
+	done := make(chan struct{})
+	go func() {
+		for range archiveChan {
+		}
+		close(done)
+	}()
+
+	select {
+	case <-done:
+	case <-time.After(5 * time.Second):
+		t.Fatal("AR handler did not recover from panic")
+	}
+}
