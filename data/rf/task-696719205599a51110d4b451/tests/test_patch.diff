+package engine
+
+import (
+	"sync"
+	"testing"
+	"time"
+
+	"github.com/sirupsen/logrus"
+	"github.com/stretchr/testify/assert"
+	"github.com/stretchr/testify/require"
+
+	"go.k6.io/k6/lib"
+	"go.k6.io/k6/lib/testutils"
+	"go.k6.io/k6/metrics"
+)
+
+func newTestMetricsEngineWithThresholds(
+	tb testing.TB, thresholdsMap map[string]metrics.Thresholds,
+) (*MetricsEngine, *metrics.Registry) {
+	tb.Helper()
+	logger := testutils.NewLogger(tb)
+	logger.SetLevel(logrus.DebugLevel)
+	registry := metrics.NewRegistry()
+	builtins := metrics.RegisterBuiltinMetrics(registry)
+
+	for name := range thresholdsMap {
+		_, _ = registry.NewMetric(name, metrics.Gauge)
+	}
+
+	piState := &lib.TestPreInitState{
+		Logger:         logger,
+		RuntimeOptions: lib.RuntimeOptions{},
+		Registry:       registry,
+		BuiltinMetrics: builtins,
+	}
+	testRunState := &lib.TestRunState{
+		TestPreInitState: piState,
+		Options:          lib.Options{Thresholds: thresholdsMap},
+	}
+	et, err := lib.NewExecutionTuple(nil, nil)
+	require.NoError(tb, err)
+	es := lib.NewExecutionState(testRunState, et, 0, 0)
+	me, err := NewMetricsEngine(es)
+	require.NoError(tb, err)
+	return me, registry
+}
+
+func addSample(registry *metrics.Registry, name string, value float64) {
+	m := registry.Get(name)
+	m.Sink.Add(metrics.Sample{
+		TimeSeries: metrics.TimeSeries{Metric: m},
+		Time:       time.Now(),
+		Value:      value,
+	})
+}
+
+func TestCreateIngester(t *testing.T) {
+	t.Parallel()
+	me, _ := newTestMetricsEngineWithThresholds(t, nil)
+
+	ingester := me.CreateIngester()
+	require.NotNil(t, ingester)
+}
+
+func TestCreateIngesterReturnsDifferentInstances(t *testing.T) {
+	t.Parallel()
+	me, _ := newTestMetricsEngineWithThresholds(t, nil)
+
+	first := me.CreateIngester()
+	second := me.CreateIngester()
+	require.NotNil(t, first)
+	require.NotNil(t, second)
+	assert.NotSame(t, first, second)
+}
+
+func TestGetMetricsWithBreachedThresholdsCountInitiallyZero(t *testing.T) {
+	t.Parallel()
+	me, _ := newTestMetricsEngineWithThresholds(t, nil)
+	assert.Equal(t, uint32(0), me.GetMetricsWithBreachedThresholdsCount())
+}
+
+func TestGetMetricsWithBreachedThresholdsCountConcurrentSafe(t *testing.T) {
+	t.Parallel()
+	ths := metrics.NewThresholds([]string{"value<50"})
+	require.NoError(t, ths.Parse())
+	me, registry := newTestMetricsEngineWithThresholds(t, map[string]metrics.Thresholds{
+		"conc_metric": ths,
+	})
+	addSample(registry, "conc_metric", 100)
+
+	finalize := me.StartThresholdCalculations(func(err error) {})
+	time.Sleep(3 * time.Second)
+	finalize()
+
+	var wg sync.WaitGroup
+	for i := 0; i < 10; i++ {
+		wg.Add(1)
+		go func() {
+			defer wg.Done()
+			count := me.GetMetricsWithBreachedThresholdsCount()
+			assert.True(t, count > 0)
+		}()
+	}
+	wg.Wait()
+}
+
+func TestStartThresholdCalculationsPassingThresholds(t *testing.T) {
+	t.Parallel()
+	ths := metrics.NewThresholds([]string{"value<100"})
+	require.NoError(t, ths.Parse())
+	me, registry := newTestMetricsEngineWithThresholds(t, map[string]metrics.Thresholds{
+		"pass_metric": ths,
+	})
+	addSample(registry, "pass_metric", 50)
+
+	abortCalled := false
+	finalize := me.StartThresholdCalculations(func(err error) {
+		abortCalled = true
+	})
+	require.NotNil(t, finalize)
+
+	breached := finalize()
+	assert.Empty(t, breached)
+	assert.False(t, abortCalled)
+	assert.Equal(t, uint32(0), me.GetMetricsWithBreachedThresholdsCount())
+}
+
+func TestStartThresholdCalculationsBreachedThresholds(t *testing.T) {
+	t.Parallel()
+	ths := metrics.NewThresholds([]string{"value<50"})
+	require.NoError(t, ths.Parse())
+	me, registry := newTestMetricsEngineWithThresholds(t, map[string]metrics.Thresholds{
+		"fail_metric": ths,
+	})
+	addSample(registry, "fail_metric", 100)
+
+	finalize := me.StartThresholdCalculations(func(err error) {})
+	require.NotNil(t, finalize)
+
+	breached := finalize()
+	assert.Contains(t, breached, "fail_metric")
+	assert.True(t, me.GetMetricsWithBreachedThresholdsCount() > 0)
+
+	metric := registry.Get("fail_metric")
+	assert.True(t, metric.Tainted.Bool)
+}
+
+func TestStartThresholdCalculationsAbortOnFail(t *testing.T) {
+	t.Parallel()
+	ths := metrics.NewThresholds([]string{"value<50"})
+	require.NoError(t, ths.Parse())
+	ths.Abort = true
+	me, registry := newTestMetricsEngineWithThresholds(t, map[string]metrics.Thresholds{
+		"abort_metric": ths,
+	})
+	addSample(registry, "abort_metric", 100)
+
+	var abortErr error
+	var mu sync.Mutex
+	finalize := me.StartThresholdCalculations(func(err error) {
+		mu.Lock()
+		abortErr = err
+		mu.Unlock()
+	})
+
+	time.Sleep(3 * time.Second)
+	finalize()
+
+	mu.Lock()
+	defer mu.Unlock()
+	require.Error(t, abortErr)
+	assert.Contains(t, abortErr.Error(), "abort_metric")
+}
+
+func TestStartThresholdCalculationsNoMetrics(t *testing.T) {
+	t.Parallel()
+	me, _ := newTestMetricsEngineWithThresholds(t, nil)
+
+	abortCalled := false
+	finalize := me.StartThresholdCalculations(func(err error) {
+		abortCalled = true
+	})
+
+	breached := finalize()
+	assert.Empty(t, breached)
+	assert.False(t, abortCalled)
+	assert.Equal(t, uint32(0), me.GetMetricsWithBreachedThresholdsCount())
+}
+
+func TestStartThresholdCalculationsMultipleMetricsMixed(t *testing.T) {
+	t.Parallel()
+	passThs := metrics.NewThresholds([]string{"value<200"})
+	require.NoError(t, passThs.Parse())
+	failThs := metrics.NewThresholds([]string{"value<10"})
+	require.NoError(t, failThs.Parse())
+
+	me, registry := newTestMetricsEngineWithThresholds(t, map[string]metrics.Thresholds{
+		"metric_pass": passThs,
+		"metric_fail": failThs,
+	})
+	addSample(registry, "metric_pass", 50)
+	addSample(registry, "metric_fail", 100)
+
+	finalize := me.StartThresholdCalculations(func(err error) {})
+
+	breached := finalize()
+	assert.Contains(t, breached, "metric_fail")
+	assert.NotContains(t, breached, "metric_pass")
+
+	passMetric := registry.Get("metric_pass")
+	failMetric := registry.Get("metric_fail")
+	assert.False(t, passMetric.Tainted.Bool)
+	assert.True(t, failMetric.Tainted.Bool)
+}
+
+func TestStartThresholdCalculationsUpdatesBreachedCount(t *testing.T) {
+	t.Parallel()
+	ths := metrics.NewThresholds([]string{"value<10"})
+	require.NoError(t, ths.Parse())
+	me, registry := newTestMetricsEngineWithThresholds(t, map[string]metrics.Thresholds{
+		"counted_metric": ths,
+	})
+	addSample(registry, "counted_metric", 100)
+
+	assert.Equal(t, uint32(0), me.GetMetricsWithBreachedThresholdsCount())
+
+	finalize := me.StartThresholdCalculations(func(err error) {})
+	time.Sleep(3 * time.Second)
+
+	assert.True(t, me.GetMetricsWithBreachedThresholdsCount() > 0)
+
+	finalize()
+	assert.True(t, me.GetMetricsWithBreachedThresholdsCount() > 0)
+}
