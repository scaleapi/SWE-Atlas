--- /dev/null
+++ b/public/app/features/panel/components/VizTypePicker/VizTypePicker.test.tsx
@@ -0,0 +1,47 @@
+import { render, screen } from '@testing-library/react';
+
+import { VizTypePicker } from './VizTypePicker';
+
+const vizPlugin = {
+  id: 'timeseries',
+  name: 'Time series',
+  sort: 1,
+  info: { logos: { small: '' }, description: 'Time series charts' },
+};
+
+const widgetPlugin = {
+  id: 'text',
+  name: 'Text',
+  sort: 2,
+  skipDataQuery: true,
+  info: { logos: { small: '' }, description: 'Text panel' },
+};
+
+const allPlugins = [vizPlugin, widgetPlugin];
+
+jest.mock('../../state/util', () => ({
+  getAllPanelPluginMeta: () => allPlugins,
+  getVizPluginMeta: () => allPlugins.filter((p: any) => !p.skipDataQuery),
+  getWidgetPluginMeta: () => allPlugins.filter((p: any) => p.skipDataQuery),
+  filterPluginList: (plugins: any[]) => plugins,
+}));
+
+describe('VizTypePicker', () => {
+  it('should display all panel plugins in a single list without separating by skipDataQuery', () => {
+    render(
+      <VizTypePicker pluginId="timeseries" searchQuery="" onChange={jest.fn()} />
+    );
+
+    expect(screen.getByText('Time series')).toBeInTheDocument();
+    expect(screen.getByText('Text')).toBeInTheDocument();
+  });
+
+  it('should render both visualization and widget type plugins together', () => {
+    render(
+      <VizTypePicker pluginId="" searchQuery="" onChange={jest.fn()} />
+    );
+
+    expect(screen.getByText('Time series')).toBeInTheDocument();
+    expect(screen.getByText('Text')).toBeInTheDocument();
+  });
+});
