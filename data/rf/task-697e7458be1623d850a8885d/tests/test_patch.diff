+import { render, screen } from '@testing-library/react';
+
+import { PanelTypeFilter } from './PanelTypeFilter';
+
+const allPlugins = [
+  { id: 'timeseries', name: 'Time series', sort: 1, info: { logos: { small: '' } } },
+  { id: 'text', name: 'Text', sort: 2, skipDataQuery: true, info: { logos: { small: '' } } },
+  { id: 'gauge', name: 'Gauge', sort: 3, info: { logos: { small: '' } } },
+];
+
+jest.mock('app/features/panel/state/util', () => ({
+  getAllPanelPluginMeta: () => allPlugins,
+  getVizPluginMeta: () => allPlugins.filter((p: any) => !p.skipDataQuery),
+  getWidgetPluginMeta: () => allPlugins.filter((p: any) => p.skipDataQuery),
+}));
+
+describe('PanelTypeFilter', () => {
+  it('should render the panel type filter with all plugins available', () => {
+    const onChange = jest.fn();
+    render(<PanelTypeFilter onChange={onChange} />);
+    expect(screen.getByLabelText('Panel Type filter')).toBeInTheDocument();
+  });
+
+  it('should provide all panel plugins as options without widget filtering', () => {
+    const onChange = jest.fn();
+    render(<PanelTypeFilter onChange={onChange} />);
+    const filter = screen.getByLabelText('Panel Type filter');
+    expect(filter).toBeInTheDocument();
+  });
+
+  it('should render without requiring an isWidget prop', () => {
+    const { container } = render(<PanelTypeFilter onChange={jest.fn()} />);
+    expect(container.firstChild).toBeTruthy();
+  });
+});
