-	MEM_UNDEFINED(&table->stat_sum_of_other_index_sizes,
-		      sizeof table->stat_sum_of_other_index_sizes);
-	MEM_UNDEFINED(&table->stat_modified_counter,
-		      sizeof table->stat_modified_counter);
-
-	dict_index_t*   index;
