diff --git a/mysql-test/suite/innodb/t/innodb_stats_flush_no_reload.test b/mysql-test/suite/innodb/t/innodb_stats_flush_no_reload.test
new file mode 100644
index 00000000000..bad4a7a0933
--- /dev/null
+++ b/mysql-test/suite/innodb/t/innodb_stats_flush_no_reload.test
@@ -0,0 +1,133 @@
+#
+# MDEV-35000: Verify that FLUSH TABLE no longer triggers InnoDB
+# persistent statistics deinitialization and reload.
+# RENAME TABLE remains the supported way to force a stats reload.
+#
+
+-- source include/have_innodb.inc
+
+-- vertical_results
+
+-- let $check_stats1 = SELECT COUNT(*) FROM mysql.innodb_table_stats WHERE table_name = 'tf'
+-- let $check_stats2 = SELECT COUNT(*) FROM mysql.innodb_index_stats WHERE table_name = 'tf'
+
+#
+# Test 1: FLUSH TABLE does NOT cause stats to be reloaded after deletion
+#
+
+CREATE TABLE tf (a INT, PRIMARY KEY (a)) ENGINE=INNODB STATS_PERSISTENT=1;
+
+# verify stats were created
+-- eval $check_stats1
+-- eval $check_stats2
+
+# delete the persistent stats
+DELETE FROM mysql.innodb_table_stats WHERE table_name = 'tf';
+DELETE FROM mysql.innodb_index_stats WHERE table_name = 'tf';
+
+# confirm stats are gone
+-- eval $check_stats1
+-- eval $check_stats2
+
+# FLUSH TABLE and reopen - stats should NOT come back
+FLUSH TABLE tf;
+SELECT * FROM tf;
+
+-- eval $check_stats1
+-- eval $check_stats2
+
+DROP TABLE tf;
+
+#
+# Test 2: RENAME TABLE DOES cause stats to be reloaded after deletion
+#
+
+CREATE TABLE tf (a INT, PRIMARY KEY (a)) ENGINE=INNODB STATS_PERSISTENT=1;
+
+# verify stats were created
+-- eval $check_stats1
+-- eval $check_stats2
+
+# delete the persistent stats
+DELETE FROM mysql.innodb_table_stats WHERE table_name = 'tf';
+DELETE FROM mysql.innodb_index_stats WHERE table_name = 'tf';
+
+# confirm stats are gone
+-- eval $check_stats1
+-- eval $check_stats2
+
+# RENAME TABLE forces stats deinit, next open triggers recalculation
+RENAME TABLE tf TO tmp, tmp TO tf;
+SELECT * FROM tf;
+
+-- eval $check_stats1
+-- eval $check_stats2
+
+DROP TABLE tf;
+
+#
+# Test 3: Stats persist across normal table open/close cycles
+# (no FLUSH, no RENAME - just open and close)
+#
+
+CREATE TABLE tf (a INT, PRIMARY KEY (a)) ENGINE=INNODB STATS_PERSISTENT=1;
+INSERT INTO tf VALUES (1), (2), (3);
+
+let $wait_condition = SELECT stat_value = 3 FROM mysql.innodb_index_stats WHERE table_name = 'tf' AND index_name = 'PRIMARY' AND stat_name = 'n_diff_pfx01';
+-- source include/wait_condition.inc
+
+# verify stats reflect the inserted rows
+-- eval $check_stats1
+-- eval $check_stats2
+
+# close and reopen the table multiple times
+FLUSH TABLE tf;
+SELECT COUNT(*) FROM tf;
+FLUSH TABLE tf;
+SELECT COUNT(*) FROM tf;
+FLUSH TABLE tf;
+SELECT COUNT(*) FROM tf;
+
+# stats should still be present and unchanged
+-- eval $check_stats1
+-- eval $check_stats2
+
+DROP TABLE tf;
+
+#
+# Test 4: Transient stats fallback with STATS_PERSISTENT=0
+# Table should still be usable, stats computed transiently
+#
+
+CREATE TABLE tf (a INT, PRIMARY KEY (a)) ENGINE=INNODB STATS_PERSISTENT=0;
+INSERT INTO tf VALUES (1), (2), (3);
+
+# persistent stats tables should have no entry for this table
+-- eval $check_stats1
+
+SELECT COUNT(*) FROM tf;
+
+# no persistent stats should appear
+-- eval $check_stats1
+
+DROP TABLE tf;
+
+#
+# Test 5: TRUNCATE TABLE clears and re-saves stats
+#
+
+CREATE TABLE tf (a INT, PRIMARY KEY (a)) ENGINE=INNODB STATS_PERSISTENT=1;
+INSERT INTO tf VALUES (1), (2), (3);
+
+let $wait_condition = SELECT stat_value = 3 FROM mysql.innodb_index_stats WHERE table_name = 'tf' AND index_name = 'PRIMARY' AND stat_name = 'n_diff_pfx01';
+-- source include/wait_condition.inc
+
+-- eval $check_stats1
+
+TRUNCATE TABLE tf;
+
+# after truncate, stats should be reset (zeroed) but still present
+-- eval $check_stats1
+-- eval $check_stats2
+
+DROP TABLE tf;
