+class TestDumpMethodTempFileBranch(unittest.TestCase):
+    """Verify dump methods handle the filename=None branch correctly.
+
+    When no filename is provided, the dump methods should:
+    1. Generate a temporary file with the appropriate extension
+    2. Write the output to the temp file
+    3. Launch an appropriate viewer (os.startfile on Windows, subprocess on others)
+    """
+
+    @staticmethod
+    def _find_canvas_method(cls):
+        dump_methods = {'psdump', 'pdfdump', 'svgdump'}
+        candidates = ('canvas_dump', '_get_canvas_dump', '_canvas_dump',
+                       '_make_canvas', '_dump_document', '_generate_canvas')
+        for name in candidates:
+            if hasattr(cls, name) and name not in dump_methods:
+                return name
+        for name in sorted(dir(cls)):
+            if name in dump_methods or name.startswith('__'):
+                continue
+            if ('canvas' in name.lower() or 'dump' in name.lower()):
+                attr = getattr(cls, name, None)
+                if callable(attr):
+                    return name
+        return None
+
+    @staticmethod
+    def _find_mixin_module(pkt_type, method_name):
+        for cls in pkt_type.__mro__:
+            if method_name in cls.__dict__:
+                return cls.__module__
+        return pkt_type.__module__
+
+    def _build_patches(self, pkt, canvas_method, dump_method_name,
+                       reader_attr, windows_val):
+        """Build a dict of patch context managers that work regardless of
+        whether the mixin uses module-level or local imports."""
+        import sys
+        mock_canvas = MagicMock()
+        mock_conf = MagicMock()
+        setattr(mock_conf.prog, reader_attr,
+                '/usr/bin/viewer' if not windows_val else None)
+
+        mixin_mod = self._find_mixin_module(type(pkt), dump_method_name)
+
+        p = {}
+        p['canvas'] = patch.object(type(pkt), canvas_method,
+                                   return_value=mock_canvas)
+        p['get_temp_file'] = patch('scapy.utils.get_temp_file',
+                                   return_value='/tmp/fakefile')
+        p['conf'] = patch('scapy.config.conf', mock_conf)
+        p['consts_win'] = patch('scapy.consts.WINDOWS', windows_val)
+        p['ctx_mgr'] = patch('scapy.utils.ContextManagerSubprocess')
+        p['stdout'] = patch('sys.stdout', new_callable=io.StringIO)
+        p['subproc'] = patch('subprocess.Popen')
+
+        mod = sys.modules.get(mixin_mod)
+        if mod and hasattr(mod, 'WINDOWS'):
+            p['mod_win'] = patch.object(mod, 'WINDOWS', windows_val)
+        if mod and hasattr(mod, 'subprocess'):
+            p['mod_subproc'] = patch.object(mod, 'subprocess')
+
+        if windows_val:
+            if mod and hasattr(mod, 'os'):
+                p['startfile'] = patch.object(mod.os, 'startfile',
+                                              create=True)
+            else:
+                import os as _os
+                p['startfile'] = patch.object(_os, 'startfile', create=True)
+
+        return p, mock_canvas
+
+    def _run_dump_no_filename(self, dump_method_name, write_method_name,
+                              reader_attr, windows_val):
+        from scapy.packet import Packet
+        pkt = Packet()
+        canvas_method = self._find_canvas_method(type(pkt))
+        self.assertIsNotNone(canvas_method)
+
+        patches, mock_canvas = self._build_patches(
+            pkt, canvas_method, dump_method_name, reader_attr, windows_val)
+
+        ctx = {}
+        try:
+            for key, p in patches.items():
+                ctx[key] = p.start()
+            getattr(pkt, dump_method_name)()
+        finally:
+            for p in patches.values():
+                p.stop()
+
+        getattr(mock_canvas, write_method_name).assert_called()
+        return mock_canvas, ctx
+
+    def test_psdump_no_filename_writes_to_temp(self):
+        mock_canvas, _ = self._run_dump_no_filename(
+            'psdump', 'writeEPSfile', 'psreader', False)
+        mock_canvas.writeEPSfile.assert_called_with('/tmp/fakefile')
+
+    def test_pdfdump_no_filename_writes_to_temp(self):
+        mock_canvas, _ = self._run_dump_no_filename(
+            'pdfdump', 'writePDFfile', 'pdfreader', False)
+        mock_canvas.writePDFfile.assert_called_with('/tmp/fakefile')
+
+    def test_svgdump_no_filename_writes_to_temp(self):
+        mock_canvas, _ = self._run_dump_no_filename(
+            'svgdump', 'writeSVGfile', 'svgreader', False)
+        mock_canvas.writeSVGfile.assert_called_with('/tmp/fakefile')
+
+    def _assert_viewer_launched(self, ctx):
+        if 'mod_subproc' in ctx:
+            ctx['mod_subproc'].Popen.assert_called()
+        else:
+            ctx['subproc'].assert_called()
+
+    def test_psdump_no_filename_launches_viewer(self):
+        _, ctx = self._run_dump_no_filename(
+            'psdump', 'writeEPSfile', 'psreader', False)
+        self._assert_viewer_launched(ctx)
+
+    def test_pdfdump_no_filename_launches_viewer(self):
+        _, ctx = self._run_dump_no_filename(
+            'pdfdump', 'writePDFfile', 'pdfreader', False)
+        self._assert_viewer_launched(ctx)
+
+    def test_svgdump_no_filename_launches_viewer(self):
+        _, ctx = self._run_dump_no_filename(
+            'svgdump', 'writeSVGfile', 'svgreader', False)
+        self._assert_viewer_launched(ctx)
+
+    def test_psdump_no_filename_windows_startfile(self):
+        _, ctx = self._run_dump_no_filename(
+            'psdump', 'writeEPSfile', 'psreader', True)
+        ctx['startfile'].assert_called_with('/tmp/fakefile')
+
+    def test_pdfdump_no_filename_windows_startfile(self):
+        _, ctx = self._run_dump_no_filename(
+            'pdfdump', 'writePDFfile', 'pdfreader', True)
+        ctx['startfile'].assert_called_with('/tmp/fakefile')
+
+    def test_svgdump_no_filename_windows_startfile(self):
+        _, ctx = self._run_dump_no_filename(
+            'svgdump', 'writeSVGfile', 'svgreader', True)
+        ctx['startfile'].assert_called_with('/tmp/fakefile')
+
