+class TestRandStringCompat(unittest.TestCase):
+    """Verify RandString handles both string and int character types."""
+
+    def test_randstring_produces_bytes(self):
+        from scapy.volatile import RandString
+        rs = RandString(size=10)
+        result = rs._fix()
+        self.assertIsInstance(result, bytes)
+        self.assertEqual(len(result), 10)
+
+    def test_randstring_respects_charset(self):
+        from scapy.volatile import RandString
+        rs = RandString(size=10, chars=b"ABCDEF")
+        result = rs._fix()
+        self.assertIsInstance(result, bytes)
+        self.assertEqual(len(result), 10)
+        for byte_val in result:
+            self.assertIn(chr(byte_val) if isinstance(byte_val, int) else byte_val,
+                          "ABCDEF")
+
+    def test_randstring_consistent_length(self):
+        from scapy.volatile import RandString
+        rs = RandString(size=5)
+        for _ in range(10):
+            result = rs._fix()
+            self.assertEqual(len(result), 5)
+
