+class TestSuperSocketClose(unittest.TestCase):
+    """Verify socket close handles Windows correctly."""
+
+    def test_close_on_windows_with_invalid_fd(self):
+        from scapy.supersocket import SuperSocket
+        mock_sock = MagicMock()
+        mock_sock.fileno.return_value = -1
+        ss = SuperSocket.__new__(SuperSocket)
+        ss.closed = False
+        ss.ins = mock_sock
+        ss.outs = mock_sock
+        with patch('scapy.supersocket.WINDOWS', True):
+            ss.close()
+        mock_sock.close.assert_called()
+
+    def test_close_skips_invalid_fd_on_non_windows(self):
+        from scapy.supersocket import SuperSocket
+        mock_outs = MagicMock()
+        mock_outs.fileno.return_value = -1
+        mock_ins = MagicMock()
+        mock_ins.fileno.return_value = -1
+        ss = SuperSocket.__new__(SuperSocket)
+        ss.closed = False
+        ss.ins = mock_ins
+        ss.outs = mock_outs
+        with patch('scapy.supersocket.WINDOWS', False):
+            ss.close()
+        mock_outs.close.assert_not_called()
+        mock_ins.close.assert_not_called()
+
+    def test_close_works_with_valid_fd_on_non_windows(self):
+        from scapy.supersocket import SuperSocket
+        mock_outs = MagicMock()
+        mock_outs.fileno.return_value = 5
+        mock_ins = MagicMock()
+        mock_ins.fileno.return_value = 6
+        ss = SuperSocket.__new__(SuperSocket)
+        ss.closed = False
+        ss.ins = mock_ins
+        ss.outs = mock_outs
+        with patch('scapy.supersocket.WINDOWS', False):
+            ss.close()
+        mock_outs.close.assert_called_once()
+        mock_ins.close.assert_called_once()
+
+
+if __name__ == '__main__':
+    unittest.main()
