+class TestDumpMethodBehavior(unittest.TestCase):
+    """Verify dump methods work correctly through both Packet and PacketList."""
+
+    @staticmethod
+    def _find_canvas_method(cls):
+        """Discover the canvas generation method regardless of naming convention.
+
+        Valid solutions may name it canvas_dump, _get_canvas_dump, etc.
+        We find it by looking for a callable on the class that is related to
+        canvas/document generation but is not one of the public dump methods.
+        """
+        dump_methods = {'psdump', 'pdfdump', 'svgdump'}
+        candidates = ('canvas_dump', '_get_canvas_dump', '_canvas_dump',
+                       '_make_canvas', '_dump_document', '_generate_canvas')
+        for name in candidates:
+            if hasattr(cls, name) and name not in dump_methods:
+                return name
+        for name in sorted(dir(cls)):
+            if name in dump_methods or name.startswith('__'):
+                continue
+            if ('canvas' in name.lower() or 'dump' in name.lower()):
+                attr = getattr(cls, name, None)
+                if callable(attr):
+                    return name
+        return None
+
+    def test_packet_psdump_writes_eps_to_given_filename(self):
+        from scapy.packet import Packet
+        pkt = Packet()
+        method = self._find_canvas_method(type(pkt))
+        self.assertIsNotNone(method, "No canvas generation method found on Packet")
+        mock_canvas = MagicMock()
+        with patch.object(type(pkt), method, return_value=mock_canvas):
+            pkt.psdump(filename='/tmp/specific.eps')
+        mock_canvas.writeEPSfile.assert_called_with('/tmp/specific.eps')
+
+    def test_packet_pdfdump_writes_pdf_to_given_filename(self):
+        from scapy.packet import Packet
+        pkt = Packet()
+        method = self._find_canvas_method(type(pkt))
+        self.assertIsNotNone(method, "No canvas generation method found on Packet")
+        mock_canvas = MagicMock()
+        with patch.object(type(pkt), method, return_value=mock_canvas):
+            pkt.pdfdump(filename='/tmp/specific.pdf')
+        mock_canvas.writePDFfile.assert_called_with('/tmp/specific.pdf')
+
+    def test_packet_svgdump_writes_svg_to_given_filename(self):
+        from scapy.packet import Packet
+        pkt = Packet()
+        method = self._find_canvas_method(type(pkt))
+        self.assertIsNotNone(method, "No canvas generation method found on Packet")
+        mock_canvas = MagicMock()
+        with patch.object(type(pkt), method, return_value=mock_canvas):
+            pkt.svgdump(filename='/tmp/specific.svg')
+        mock_canvas.writeSVGfile.assert_called_with('/tmp/specific.svg')
+
+    def test_packet_and_packetlist_share_psdump(self):
+        from scapy.packet import Packet
+        from scapy.plist import PacketList
+        self.assertIs(
+            Packet.psdump, PacketList.psdump,
+            "Packet and PacketList psdump should be the exact same function"
+        )
+
+    def test_packet_and_packetlist_share_pdfdump(self):
