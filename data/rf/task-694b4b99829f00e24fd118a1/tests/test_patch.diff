+    def test_psdump_comes_from_shared_base(self):
+        from scapy.packet import Packet
+        from scapy.plist import PacketList
+        owner_packet = None
+        owner_plist = None
+        for cls in Packet.__mro__:
+            if 'psdump' in cls.__dict__:
+                owner_packet = cls
+                break
+        for cls in PacketList.__mro__:
+            if 'psdump' in cls.__dict__:
+                owner_plist = cls
+                break
+        self.assertIsNotNone(owner_packet)
+        self.assertIsNotNone(owner_plist)
+        self.assertIs(owner_packet, owner_plist,
+                      "psdump should come from the same shared base class")
