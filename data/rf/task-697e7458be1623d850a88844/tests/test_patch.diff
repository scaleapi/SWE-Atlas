@@ -0,0 +1,116 @@
+package abbysale
+
+import (
+	"context"
+	"testing"
+	"time"
+
+	"github.com/trufflesecurity/trufflehog/v3/pkg/common"
+	"github.com/trufflesecurity/trufflehog/v3/pkg/pb/detectorspb"
+)
+
+func TestAbbysale_Mock(t *testing.T) {
+	tests := []struct {
+		name                string
+		s                   Scanner
+		data                string
+		verify              bool
+		wantFound           bool
+		wantVerify          bool
+		wantVerificationErr bool
+	}{
+		{
+			name:       "verified on 200",
+			s:          Scanner{client: common.ConstantResponseHttpClient(200, `{}`)},
+			data:       `abbysale token xaji0y6dpbhsahxthv3a3zmf8mdd4v30t9nt3w5u`,
+			verify:     true,
+			wantFound:  true,
+			wantVerify: true,
+		},
+		{
+			name:       "unverified on 401",
+			s:          Scanner{client: common.ConstantResponseHttpClient(401, "{}")},
+			data:       `abbysale token xaji0y6dpbhsahxthv3a3zmf8mdd4v30t9nt3w5u`,
+			verify:     true,
+			wantFound:  true,
+			wantVerify: false,
+		},
+		{
+			name:                "no panic on 500",
+			s:                   Scanner{client: common.ConstantResponseHttpClient(500, "{}")},
+			data:                `abbysale token xaji0y6dpbhsahxthv3a3zmf8mdd4v30t9nt3w5u`,
+			verify:              true,
+			wantFound:           true,
+			wantVerify:          false,
+			wantVerificationErr: true,
+		},
+		{
+			name:                "no panic on timeout",
+			s:                   Scanner{client: common.SaneHttpClientTimeOut(1 * time.Microsecond)},
+			data:                `abbysale token xaji0y6dpbhsahxthv3a3zmf8mdd4v30t9nt3w5u`,
+			verify:              true,
+			wantFound:           true,
+			wantVerify:          false,
+			wantVerificationErr: true,
+		},
+		{
+			name:      "no match",
+			s:         Scanner{},
+			data:      "no secrets here",
+			verify:    true,
+			wantFound: false,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			got, err := tt.s.FromData(context.Background(), tt.verify, []byte(tt.data))
+			if err != nil {
+				t.Fatalf("FromData() returned error: %v", err)
+			}
+
+			if tt.wantFound {
+				if len(got) == 0 {
+					t.Fatal("expected at least one result, got none")
+				}
+				for _, r := range got {
+					if len(r.Raw) == 0 {
+						t.Error("result has empty Raw field")
+					}
+					if r.DetectorType != detectorspb.DetectorType_Abbysale {
+						t.Errorf("wrong DetectorType: got %v, want %v", r.DetectorType, detectorspb.DetectorType_Abbysale)
+					}
+				}
+				hasVerified := false
+				for _, r := range got {
+					if r.Verified {
+						hasVerified = true
+						break
+					}
+				}
+				if tt.wantVerify && !hasVerified {
+					t.Error("expected at least one verified result, got none")
+				}
+			if !tt.wantVerify {
+				for _, r := range got {
+					if r.Verified {
+						t.Error("expected no verified results, but got one")
+						break
+					}
+				}
+			}
+			if tt.wantVerificationErr {
+				for _, r := range got {
+					if r.VerificationError() == nil {
+						t.Error("expected verification error to be set")
+					}
+				}
+			}
+		} else {
+				if len(got) != 0 {
+					t.Errorf("expected no results, got %d", len(got))
+				}
+			}
+		})
+	}
+}
