+= PDU dispatch: OpcDaFackLE dispatched for LE packets with pduType 9
+~ fack le dispatch
+
+header_le = OpcDaHeaderMessage(versionMajor=5, versionMinor=0, pduType=9,
+    pfc_flags=3, integerRepresentation='littleEndian',
+    characterRepresentation='ascii', floatingPointRepresentation='ieee',
+    res=0) / OpcDaHeaderNLE(fragLength=32, authLength=0, callID=1)
+pdu_class = header_le[OpcDaHeaderNLE].guess_payload_class(b"")
+assert pdu_class == OpcDaFackLE, "PDU type 9 with LE header should dispatch to OpcDaFackLE"
+
+= PDU dispatch: OpcDaBind_nakLE dispatched for LE packets with pduType 13
+~ bind_nak le dispatch
+
+header_le = OpcDaHeaderMessage(versionMajor=5, versionMinor=0, pduType=13,
+    pfc_flags=3, integerRepresentation='littleEndian',
+    characterRepresentation='ascii', floatingPointRepresentation='ieee',
+    res=0) / OpcDaHeaderNLE(fragLength=32, authLength=0, callID=1)
+pdu_class = header_le[OpcDaHeaderNLE].guess_payload_class(b"")
+assert pdu_class == OpcDaBind_nakLE, "PDU type 13 with LE header should dispatch to OpcDaBind_nakLE"
+
+= PDU dispatch: Big-endian header dispatches to BE PDU class
+~ pdu dispatch be
+
+header_be = OpcDaHeaderMessage(versionMajor=5, versionMinor=0, pduType=9,
+    pfc_flags=3, integerRepresentation='bigEndian',
+    characterRepresentation='ascii', floatingPointRepresentation='ieee',
+    res=0) / OpcDaHeaderN(fragLength=32, authLength=0, callID=1)
+pdu_class = header_be[OpcDaHeaderN].guess_payload_class(b"")
+assert pdu_class == OpcDaFack, "PDU type 9 with BE header should dispatch to OpcDaFack"
+
+= OpcDaBind_ack field name fix (pad2 instead of pda2)
+~ bind_ack typo
+
+bind_ack = OpcDaBind_ack()
+assert hasattr(bind_ack, 'pad2'), "OpcDaBind_ack should have 'pad2' field"
+
+= OpcDaAlter_Context_Resp field name fix (portSpec instead of portSPec)
+~ alter_context_resp typo
+
+alter_resp = OpcDaAlter_Context_Resp()
+assert hasattr(alter_resp, 'portSpec'), "OpcDaAlter_Context_Resp should have 'portSpec' field"
+assert hasattr(alter_resp, 'pad2'), "OpcDaAlter_Context_Resp should have 'pad2' field"
+assert hasattr(alter_resp, 'resultList'), "OpcDaAlter_Context_Resp should have 'resultList' field"
+assert hasattr(alter_resp, 'authentication'), "OpcDaAlter_Context_Resp should have 'authentication' field"
+
+= OpcDaFault has authentication field
+~ fault auth
+
+fault = OpcDaFault()
+assert hasattr(fault, 'authentication'), "OpcDaFault should have 'authentication' field"
+assert hasattr(fault, 'stubData'), "OpcDaFault should have 'stubData' field"
+fault_le = OpcDaFaultLE()
+assert hasattr(fault_le, 'authentication'), "OpcDaFaultLE should have 'authentication' field"
+
+= OpcDaReject uses stubData field name
+~ reject stubdata
+
+reject = OpcDaReject()
+assert hasattr(reject, 'stubData'), "OpcDaReject should have 'stubData' field"
+
+= AV_PAIR class with correct field names per MS-NLMP spec
+~ av_pair fields
+
+av_pair = AV_PAIR()
+assert hasattr(av_pair, 'avID'), "AV_PAIR should have 'avID' field"
+assert hasattr(av_pair, 'avLen'), "AV_PAIR should have 'avLen' field"
+assert hasattr(av_pair, 'value'), "AV_PAIR should have 'value' field"
+av_pair_le = AV_PAIRLE()
+assert hasattr(av_pair_le, 'avID'), "AV_PAIRLE should have 'avID' field"
+
+= ResultElement has reason field
+~ result element reason
+
+result = ResultElement(resultContextNegotiation=1, reason=0)
+assert hasattr(result, 'reason'), "ResultElement should have 'reason' field"
+
+= LenStringPacket has data field
+~ lenstringpacket
+pkt = LenStringPacket()
+assert hasattr(pkt, 'length'), "LenStringPacket should have 'length' field"
+assert hasattr(pkt, 'data'), "LenStringPacket should have 'data' field"
+
+= NTLMSSP packet with MS-NLMP specification field names
+~ ntlmssp ms-nlmp
+ntlm = NTLMSSP()
+assert hasattr(ntlm, 'lmChallengeResponseLen'), "NTLMSSP should have 'lmChallengeResponseLen'"
+assert hasattr(ntlm, 'ntChallengeResponseLen'), "NTLMSSP should have 'ntChallengeResponseLen'"
+assert hasattr(ntlm, 'workstationLen'), "NTLMSSP should have 'workstationLen'"
+assert hasattr(ntlm, 'encryptedRandomSessionKeyLen'), "NTLMSSP should have 'encryptedRandomSessionKeyLen'"
+assert hasattr(ntlm, 'productMajorVersion'), "NTLMSSP should have 'productMajorVersion'"
+assert hasattr(ntlm, 'productMinorVersion'), "NTLMSSP should have 'productMinorVersion'"
+assert hasattr(ntlm, 'NTLMRevisionCurrent'), "NTLMSSP should have 'NTLMRevisionCurrent'"
+assert hasattr(ntlm, 'lmChallengeResponse'), "NTLMSSP should have 'lmChallengeResponse'"
+assert hasattr(ntlm, 'ntChallengeResponse'), "NTLMSSP should have 'ntChallengeResponse'"
+assert hasattr(ntlm, 'workstation'), "NTLMSSP should have 'workstation'"
+assert hasattr(ntlm, 'encryptedRandomSessionKey'), "NTLMSSP should have 'encryptedRandomSessionKey'"
+
+= OpcDaRequest has uuid and stubData fields
+~ request fields
+
+request = OpcDaRequest()
+assert hasattr(request, 'uuid'), "OpcDaRequest should have 'uuid' field"
+assert hasattr(request, 'stubData'), "OpcDaRequest should have 'stubData' field"
+
+= RequestStubData class replaces RequestSubData
+~ request stubdata class
+
+stub = RequestStubData()
+assert stub.name == 'RequestStubData', "RequestStubData should have correct name"
+assert hasattr(stub, 'stubdata'), "RequestStubData should have 'stubdata' field"
+stub_le = RequestStubDataLE()
+assert hasattr(stub_le, 'stubdata'), "RequestStubDataLE should have 'stubdata' field"
