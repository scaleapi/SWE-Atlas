+/**
+ * @jest-environment jsdom
+ */
+
+import { agencyTierContext } from '../controller';
+
+jest.mock( 'calypso/a8c-for-agencies/components/a4a-page-view-tracker', () => () => (
+	<div data-testid="page-view-tracker" />
+) );
+
+jest.mock( 'calypso/a8c-for-agencies/components/sidebar-menu/main', () => () => (
+	<div data-testid="main-sidebar" />
+) );
+
+jest.mock( '../primary/agency-tier-overview', () => () => (
+	<div data-testid="agency-tier-overview" />
+) );
+
+describe( 'agencyTierContext', () => {
+	it( 'should set context.primary with AgencyTierOverview', () => {
+		const context: any = { path: '/agency-tier' };
+		const next = jest.fn();
+
+		agencyTierContext( context, next );
+
+		expect( context.primary ).toBeDefined();
+		expect( next ).toHaveBeenCalled();
+	} );
+
+	it( 'should not conditionally render based on any feature flag', () => {
+		const context: any = { path: '/agency-tier' };
+		const next = jest.fn();
+
+		agencyTierContext( context, next );
+
+		const rendered = context.primary;
+		expect( rendered ).toBeDefined();
+		expect( rendered.props.children ).toEqual(
+			expect.arrayContaining( [
+				expect.objectContaining( { type: expect.any( Function ) } ),
+			] )
+		);
+	} );
+
+	it( 'should set context.secondary with MainSidebar', () => {
+		const context: any = { path: '/agency-tier' };
+		const next = jest.fn();
+
+		agencyTierContext( context, next );
+
+		expect( context.secondary ).toBeDefined();
+	} );
+
+	it( 'should call next to continue the routing chain', () => {
+		const context: any = { path: '/agency-tier' };
+		const next = jest.fn();
+
+		agencyTierContext( context, next );
+
+		expect( next ).toHaveBeenCalledTimes( 1 );
+	} );
+} );
