+/**
+ * @jest-environment node
+ */
+
+import fs from 'fs';
+import path from 'path';
+
+const configDir = path.resolve( __dirname, '../../../../../config' );
+
+const a4aConfigFiles = [
+	'a8c-for-agencies-development.json',
+	'a8c-for-agencies-horizon.json',
+	'a8c-for-agencies-production.json',
+	'a8c-for-agencies-stage.json',
+];
+
+describe( 'tiers-revamp feature flag removal from config files', () => {
+	a4aConfigFiles.forEach( ( configFile ) => {
+		it( `should not contain tiers-revamp in ${ configFile }`, () => {
+			const configPath = path.join( configDir, configFile );
+			const config = JSON.parse( fs.readFileSync( configPath, 'utf-8' ) );
+			expect( config.features ).toBeDefined();
+			expect( config.features ).not.toHaveProperty( 'tiers-revamp' );
+		} );
+	} );
+} );
+
+describe( 'AgencyTierOverviewV2 component removal', () => {
+	const v2Dir = path.resolve(
+		__dirname,
+		'../primary/agency-tier-overview-v2'
+	);
+
+	it( 'should no longer have the V2 overview component directory', () => {
+		expect( fs.existsSync( v2Dir ) ).toBe( false );
+	} );
+
+	it( 'should no longer have the V2 index.tsx file', () => {
+		expect( fs.existsSync( path.join( v2Dir, 'index.tsx' ) ) ).toBe( false );
+	} );
+
+	it( 'should no longer have the V2 style.scss file', () => {
+		expect( fs.existsSync( path.join( v2Dir, 'style.scss' ) ) ).toBe( false );
+	} );
+} );
+
+describe( 'tiers-revamp feature flag removal from source files', () => {
+	const sourceFiles = [
+		path.resolve( __dirname, '../../../components/sidebar-menu/hooks/use-main-menu-items.tsx' ),
+		path.resolve( __dirname, '../controller.tsx' ),
+		path.resolve( __dirname, '../primary/agency-tier-overview/index.tsx' ),
+		path.resolve( __dirname, '../../overview/sidebar/agency-tier/index.tsx' ),
+	];
+
+	sourceFiles.forEach( ( sourceFile ) => {
+		const fileName = path.basename( sourceFile );
+		it( `should not reference tiers-revamp in ${ fileName }`, () => {
+			const content = fs.readFileSync( sourceFile, 'utf-8' );
+			expect( content ).not.toContain( 'tiers-revamp' );
+		} );
+
+		it( `should not import isEnabled from calypso-config in ${ fileName }`, () => {
+			const content = fs.readFileSync( sourceFile, 'utf-8' );
+			expect( content ).not.toMatch( /import.*isEnabled.*from.*calypso-config/ );
+		} );
+	} );
+} );
+
+describe( 'V1 stylesheet cleanup', () => {
+	it( 'should have replaced the old V1 SCSS with a minimal stylesheet', () => {
+		const stylePath = path.resolve(
+			__dirname,
+			'../primary/agency-tier-overview/style.scss'
+		);
+		const content = fs.readFileSync( stylePath, 'utf-8' );
+		const lines = content.trim().split( '\n' ).filter( ( l: string ) => l.trim().length > 0 );
+		expect( lines.length ).toBeLessThanOrEqual( 5 );
+	} );
+
+	it( 'should not contain old V1 class selectors', () => {
+		const stylePath = path.resolve(
+			__dirname,
+			'../primary/agency-tier-overview/style.scss'
+		);
+		const content = fs.readFileSync( stylePath, 'utf-8' );
+		expect( content ).not.toContain( '.agency-tier-overview__top-content' );
+		expect( content ).not.toContain( '.agency-tier-overview__benefit-card' );
+		expect( content ).not.toContain( '.agency-tier-overview__current-tier-badge' );
+		expect( content ).not.toContain( '.agency-tier-overview__bottom-content' );
+	} );
+} );
