+/**
+ * @jest-environment jsdom
+ */
+import { renderHook } from '@testing-library/react';
+import { useIsMarketplaceRedesignEnabled } from '../use-is-marketplace-redesign-enabled';
+
+let mockSiteId: number | null = null;
+let mockIsLoggedIn = false;
+let mockHostingOptIn = false;
+let mockFlagEnabled = true;
+
+jest.mock( '@automattic/calypso-config', () => ( {
+	isEnabled: jest.fn( () => mockFlagEnabled ),
+} ) );
+
+jest.mock( 'react-redux', () => ( {
+	...jest.requireActual( 'react-redux' ),
+	useSelector: jest.fn( ( selector ) => selector( {} ) ),
+} ) );
+
+jest.mock( 'calypso/state/ui/selectors', () => ( {
+	getSelectedSiteId: jest.fn( () => mockSiteId ),
+} ) );
+
+jest.mock( 'calypso/state/current-user/selectors', () => ( {
+	isUserLoggedIn: jest.fn( () => mockIsLoggedIn ),
+} ) );
+
+jest.mock( 'calypso/state/sites/selectors/has-hosting-dashboard-opt-in', () => ( {
+	hasHostingDashboardOptIn: jest.fn( () => mockHostingOptIn ),
+} ) );
+
+describe( 'useIsMarketplaceRedesignEnabled', () => {
+	beforeEach( () => {
+		mockSiteId = null;
+		mockIsLoggedIn = false;
+		mockHostingOptIn = false;
+		mockFlagEnabled = true;
+	} );
+
+	it( 'returns false when a site is selected, regardless of other conditions', () => {
+		mockSiteId = 123;
+		mockFlagEnabled = true;
+		mockIsLoggedIn = false;
+
+		const { result } = renderHook( () => useIsMarketplaceRedesignEnabled() );
+		expect( result.current ).toBe( false );
+	} );
+
+	it( 'returns false when a site is selected even with dashboard opt-in', () => {
+		mockSiteId = 456;
+		mockFlagEnabled = true;
+		mockIsLoggedIn = true;
+		mockHostingOptIn = true;
+
+		const { result } = renderHook( () => useIsMarketplaceRedesignEnabled() );
+		expect( result.current ).toBe( false );
+	} );
+
+	it( 'returns true for logged out users when no site is selected and flag is enabled', () => {
+		mockSiteId = null;
+		mockFlagEnabled = true;
+		mockIsLoggedIn = false;
+
+		const { result } = renderHook( () => useIsMarketplaceRedesignEnabled() );
+		expect( result.current ).toBe( true );
+	} );
+
+	it( 'returns true for logged in users with dashboard opt-in when no site is selected', () => {
+		mockSiteId = null;
+		mockFlagEnabled = true;
+		mockIsLoggedIn = true;
+		mockHostingOptIn = true;
+
+		const { result } = renderHook( () => useIsMarketplaceRedesignEnabled() );
+		expect( result.current ).toBe( true );
+	} );
+
+	it( 'returns false for logged in users without dashboard opt-in when no site is selected', () => {
+		mockSiteId = null;
+		mockFlagEnabled = true;
+		mockIsLoggedIn = true;
+		mockHostingOptIn = false;
+
+		const { result } = renderHook( () => useIsMarketplaceRedesignEnabled() );
+		expect( result.current ).toBe( false );
+	} );
+
+	it( 'returns false when the feature flag is disabled even for logged out users', () => {
+		mockSiteId = null;
+		mockFlagEnabled = false;
+		mockIsLoggedIn = false;
+
+		const { result } = renderHook( () => useIsMarketplaceRedesignEnabled() );
+		expect( result.current ).toBe( false );
+	} );
+
+	it( 'returns false when flag is disabled even with dashboard opt-in', () => {
+		mockSiteId = null;
+		mockFlagEnabled = false;
+		mockIsLoggedIn = true;
+		mockHostingOptIn = true;
+
+		const { result } = renderHook( () => useIsMarketplaceRedesignEnabled() );
+		expect( result.current ).toBe( false );
+	} );
+
+	it( 'returns a boolean value', () => {
+		const { result } = renderHook( () => useIsMarketplaceRedesignEnabled() );
+		expect( typeof result.current ).toBe( 'boolean' );
+	} );
+} );
