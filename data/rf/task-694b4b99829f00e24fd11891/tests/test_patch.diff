+/** @jest-environment jsdom */
+import { render } from '@testing-library/react';
+import FullWidthSection from '../';
+
+describe( 'FullWidthSection', () => {
+	it( 'returns children directly when enabled is false', () => {
+		const { container } = render(
+			<FullWidthSection enabled={ false }>
+				<span data-testid="child">Hello</span>
+			</FullWidthSection>
+		);
+		expect( container.querySelector( '.full-width-section' ) ).toBeNull();
+		expect( container.textContent ).toBe( 'Hello' );
+	} );
+
+	it( 'returns children directly when enabled is not provided (defaults to false)', () => {
+		const { container } = render(
+			<FullWidthSection>
+				<span>Content</span>
+			</FullWidthSection>
+		);
+		expect( container.querySelector( '.full-width-section' ) ).toBeNull();
+		expect( container.textContent ).toBe( 'Content' );
+	} );
+
+	it( 'wraps children in section div when enabled is true', () => {
+		const { container } = render(
+			<FullWidthSection enabled={ true }>
+				<span>Wrapped</span>
+			</FullWidthSection>
+		);
+		const section = container.querySelector( '.full-width-section' );
+		expect( section ).not.toBeNull();
+		expect( section.querySelector( '.full-width-section__content' ) ).not.toBeNull();
+		expect( container.textContent ).toBe( 'Wrapped' );
+	} );
+
+	it( 'applies custom className when enabled is true', () => {
+		const { container } = render(
+			<FullWidthSection enabled={ true } className="my-custom-class">
+				<span>Test</span>
+			</FullWidthSection>
+		);
+		const section = container.querySelector( '.full-width-section' );
+		expect( section.classList.contains( 'my-custom-class' ) ).toBe( true );
+	} );
+
+	it( 'does not apply className wrapper when enabled is false', () => {
+		const { container } = render(
+			<FullWidthSection enabled={ false } className="my-custom-class">
+				<span>Test</span>
+			</FullWidthSection>
+		);
+		expect( container.querySelector( '.my-custom-class' ) ).toBeNull();
+	} );
+
+	it( 'renders multiple children when enabled is true', () => {
+		const { container } = render(
+			<FullWidthSection enabled={ true }>
+				<span>One</span>
+				<span>Two</span>
+			</FullWidthSection>
+		);
+		const content = container.querySelector( '.full-width-section__content' );
+		expect( content.children.length ).toBe( 2 );
+	} );
+} );
