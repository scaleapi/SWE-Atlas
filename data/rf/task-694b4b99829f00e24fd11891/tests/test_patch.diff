@@ -0,0 +1,98 @@
+/**
+ * @jest-environment jsdom
+ */
+import { getCategories } from '../use-categories';
+
+describe( 'getCategories', () => {
+	it( 'returns a record of category objects with standard keys', () => {
+		const categories = getCategories();
+		expect( typeof categories ).toBe( 'object' );
+		expect( categories ).toHaveProperty( 'discover' );
+		expect( categories ).toHaveProperty( 'paid' );
+		expect( categories ).toHaveProperty( 'popular' );
+		expect( categories ).toHaveProperty( 'featured' );
+		expect( categories ).toHaveProperty( 'monetization' );
+		expect( categories ).toHaveProperty( 'business' );
+	} );
+
+	it( 'accepts a boolean parameter without throwing', () => {
+		expect( () => getCategories( true ) ).not.toThrow();
+		expect( () => getCategories( false ) ).not.toThrow();
+		expect( () => getCategories() ).not.toThrow();
+	} );
+
+	it( 'defaults to redesign disabled when called without arguments', () => {
+		const withDefault = getCategories();
+		const withFalse = getCategories( false );
+		expect( withDefault.paid.title ).toBe( withFalse.paid.title );
+		expect( withDefault.popular.title ).toBe( withFalse.popular.title );
+		expect( withDefault.featured.title ).toBe( withFalse.featured.title );
+	} );
+
+	it( 'returns different titles for paid category based on the parameter', () => {
+		const enabled = getCategories( true );
+		const disabled = getCategories( false );
+		expect( enabled.paid.title ).not.toBe( disabled.paid.title );
+	} );
+
+	it( 'returns different descriptions for paid category based on the parameter', () => {
+		const enabled = getCategories( true );
+		const disabled = getCategories( false );
+		expect( enabled.paid.description ).not.toBe( disabled.paid.description );
+	} );
+
+	it( 'returns different titles for popular category based on the parameter', () => {
+		const enabled = getCategories( true );
+		const disabled = getCategories( false );
+		expect( enabled.popular.title ).not.toBe( disabled.popular.title );
+	} );
+
+	it( 'returns different titles for featured category based on the parameter', () => {
+		const enabled = getCategories( true );
+		const disabled = getCategories( false );
+		expect( enabled.featured.title ).not.toBe( disabled.featured.title );
+	} );
+
+	it( 'returns different descriptions for featured category based on the parameter', () => {
+		const enabled = getCategories( true );
+		const disabled = getCategories( false );
+		expect( enabled.featured.description ).not.toBe( disabled.featured.description );
+	} );
+
+	it( 'returns different titles for monetization category based on the parameter', () => {
+		const enabled = getCategories( true );
+		const disabled = getCategories( false );
+		expect( enabled.monetization.title ).not.toBe( disabled.monetization.title );
+	} );
+
+	it( 'returns different descriptions for monetization category based on the parameter', () => {
+		const enabled = getCategories( true );
+		const disabled = getCategories( false );
+		expect( enabled.monetization.description ).not.toBe( disabled.monetization.description );
+	} );
+
+	it( 'returns different titles for business category based on the parameter', () => {
+		const enabled = getCategories( true );
+		const disabled = getCategories( false );
+		expect( enabled.business.title ).not.toBe( disabled.business.title );
+	} );
+
+	it( 'returns different descriptions for business category based on the parameter', () => {
+		const enabled = getCategories( true );
+		const disabled = getCategories( false );
+		expect( enabled.business.description ).not.toBe( disabled.business.description );
+	} );
+
+	it( 'each category has a slug property', () => {
+		const categories = getCategories( true );
+		for ( const key of Object.keys( categories ) ) {
+			expect( categories[ key ] ).toHaveProperty( 'slug' );
+		}
+	} );
+
+	it( 'categories that do not vary remain the same regardless of parameter', () => {
+		const enabled = getCategories( true );
+		const disabled = getCategories( false );
+		expect( enabled.discover.title ).toBe( disabled.discover.title );
+	} );
+} );
diff --git a/client/my-sites/plugins/hooks/test/use-is-marketplace-redesign-enabled.test.ts b/client/my-sites/plugins/hooks/test/use-is-marketplace-redesign-enabled.test.ts
