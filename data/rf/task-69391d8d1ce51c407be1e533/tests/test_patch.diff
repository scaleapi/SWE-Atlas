+# delete_custom_domain
+def test_delete_custom_domain_sets_pending_deletion():
+    """Test that delete_custom_domain sets pending_deletion to True."""
+    domain = random_domain()
+    custom_domain = CustomDomain.create(
+        user_id=user.id,
+        domain=domain,
+        commit=True,
+    )
+    assert custom_domain.pending_deletion is False
+
+    delete_custom_domain(custom_domain)
+
+    assert custom_domain.pending_deletion is True
+
+
+def test_delete_custom_domain_creates_job():
+    """Test that delete_custom_domain creates a Job with correct parameters."""
+    domain = random_domain()
+    custom_domain = CustomDomain.create(
+        user_id=user.id,
+        domain=domain,
+        commit=True,
+    )
+
+    delete_custom_domain(custom_domain)
+
+    job = Job.filter_by(
+        name=JOB_DELETE_DOMAIN,
+    ).order_by(Job.id.desc()).first()
+
+    assert job is not None
+    assert job.payload == {"custom_domain_id": custom_domain.id}
+    assert job.run_at is not None
+
+
+def test_delete_custom_domain_returns_none():
+    """Test that delete_custom_domain returns None (interface verification)."""
+    domain = random_domain()
+    custom_domain = CustomDomain.create(
+        user_id=user.id,
+        domain=domain,
+        commit=True,
+    )
+
+    result = delete_custom_domain(custom_domain)
+    assert result is None
+
+
+def test_delete_custom_domain_already_pending():
+    """Test that calling delete_custom_domain on an already-pending domain still works."""
+    domain = random_domain()
+    custom_domain = CustomDomain.create(
+        user_id=user.id,
+        domain=domain,
+        commit=True,
+    )
+    custom_domain.pending_deletion = True
+    Session.commit()
+
+    delete_custom_domain(custom_domain)
+
+    assert custom_domain.pending_deletion is True
+    job = Job.filter_by(
+        name=JOB_DELETE_DOMAIN,
+    ).order_by(Job.id.desc()).first()
+    assert job is not None
