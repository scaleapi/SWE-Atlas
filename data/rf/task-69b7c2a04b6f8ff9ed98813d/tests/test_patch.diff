+static void test_create_and_free(void) {
+    fprintf(stderr, "\n--- test_create_and_free ---\n");
+
+    struct rrdhost_system_info *si = rrdhost_system_info_create();
+    CHECK(si != NULL, "rrdhost_system_info_create returned NULL");
+
+    CHECK(rrdhost_system_info_hops(si) == 0, "hops should be 0 after create");
+    CHECK(rrdhost_system_info_install_type(si) == NULL, "install_type should be NULL after create");
+    CHECK(rrdhost_system_info_prebuilt_dist(si) == NULL, "prebuilt_dist should be NULL after create");
+
+    rrdhost_system_info_free(si);
+    rrdhost_system_info_free(NULL);
+}
+
+static void test_hops_accessors(void) {
+    fprintf(stderr, "\n--- test_hops_accessors ---\n");
+
+    struct rrdhost_system_info *si = rrdhost_system_info_create();
+
+    CHECK(rrdhost_system_info_hops(si) == 0, "default hops should be 0");
+
+    rrdhost_system_info_hops_set(si, 3);
+    CHECK(rrdhost_system_info_hops(si) == 3, "hops should be 3 after set, got %d", rrdhost_system_info_hops(si));
+
+    rrdhost_system_info_hops_set(si, 0);
+    CHECK(rrdhost_system_info_hops(si) == 0, "hops should be 0 after reset");
+
+    rrdhost_system_info_hops_set(si, -1);
+    CHECK(rrdhost_system_info_hops(si) == -1, "hops should support negative values");
+
+    CHECK(rrdhost_system_info_hops(NULL) == 0, "hops(NULL) should return 0");
+
+    rrdhost_system_info_free(si);
+}
