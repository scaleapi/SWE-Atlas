+static void test_to_url_encode_stream(void) {
+    fprintf(stderr, "\n--- test_to_url_encode_stream ---\n");
+
+    struct rrdhost_system_info *si = rrdhost_system_info_create();
+    rrdhost_system_info_set_by_name(si, "NETDATA_HOST_OS_NAME", "Ubuntu 22.04");
+    rrdhost_system_info_set_by_name(si, "NETDATA_SYSTEM_ARCHITECTURE", "x86_64");
+    rrdhost_system_info_ml_capable_set(si, true);
+    rrdhost_system_info_ml_enabled_set(si, true);
+    rrdhost_system_info_mc_version_set(si, 2);
+
+    BUFFER *wb = buffer_create(4096, NULL);
+    rrdhost_system_info_to_url_encode_stream(wb, si);
+
+    const char *output = buffer_tostring(wb);
+    CHECK(strstr(output, "ml_capable=1") != NULL, "URL stream should contain ml_capable=1");
+    CHECK(strstr(output, "ml_enabled=1") != NULL, "URL stream should contain ml_enabled=1");
+    CHECK(strstr(output, "mc_version=2") != NULL, "URL stream should contain mc_version=2");
+    CHECK(strstr(output, "NETDATA_SYSTEM_OS_NAME") != NULL, "URL stream should contain OS name key");
+    CHECK(strstr(output, "NETDATA_SYSTEM_ARCHITECTURE") != NULL, "URL stream should contain architecture key");
+    CHECK(strstr(output, "Ubuntu") == NULL || strstr(output, "Ubuntu%20") != NULL || strstr(output, "Ubuntu+") != NULL,
+          "space in Ubuntu 22.04 should be URL encoded");
+
+    buffer_free(wb);
+    rrdhost_system_info_free(si);
+}
