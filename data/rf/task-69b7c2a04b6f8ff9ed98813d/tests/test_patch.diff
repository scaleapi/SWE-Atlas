+static void test_buffer_key_value_urlencode(void) {
+    fprintf(stderr, "\n--- test_buffer_key_value_urlencode ---\n");
+
+    BUFFER *wb = buffer_create(256, NULL);
+
+    buffer_key_value_urlencode(wb, "&key1", "simple");
+    const char *output = buffer_tostring(wb);
+    CHECK(strstr(output, "&key1=simple") != NULL, "simple value should encode to key=value");
+
+    buffer_flush(wb);
+    buffer_key_value_urlencode(wb, "&key2", "hello world");
+    output = buffer_tostring(wb);
+    CHECK(strstr(output, "&key2=") != NULL, "key should be present");
+    CHECK(strstr(output, "hello world") == NULL, "space should be URL encoded");
+
+    buffer_flush(wb);
+    buffer_key_value_urlencode(wb, "&key3", NULL);
+    output = buffer_tostring(wb);
+    CHECK(strstr(output, "&key3=") != NULL, "NULL value should produce key=");
+
+    buffer_flush(wb);
+    buffer_key_value_urlencode(wb, "&key4", "");
+    output = buffer_tostring(wb);
+    CHECK(strstr(output, "&key4=") != NULL, "empty value should produce key=");
+
+    buffer_free(wb);
+}
