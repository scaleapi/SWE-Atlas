+static void test_set_by_name_overwrite(void) {
+    fprintf(stderr, "\n--- test_set_by_name_overwrite ---\n");
+
+    struct rrdhost_system_info *si = rrdhost_system_info_create();
+
+    rrdhost_system_info_set_by_name(si, "NETDATA_HOST_OS_NAME", "Ubuntu");
+
+    RRDLABELS *labels = rrdlabels_create();
+    rrdhost_system_info_to_rrdlabels(si, labels);
+    char *value = NULL;
+    rrdlabels_get_value_strdup_or_null(labels, &value, "_os_name");
+    CHECK(value != NULL && strcmp(value, "Ubuntu") == 0, "first set should produce Ubuntu");
+    freez(value); value = NULL;
+    rrdlabels_destroy(labels);
+
+    rrdhost_system_info_set_by_name(si, "NETDATA_HOST_OS_NAME", "Debian");
+
+    labels = rrdlabels_create();
+    rrdhost_system_info_to_rrdlabels(si, labels);
+    rrdlabels_get_value_strdup_or_null(labels, &value, "_os_name");
+    CHECK(value != NULL && strcmp(value, "Debian") == 0, "overwrite should produce Debian");
+    freez(value);
+    rrdlabels_destroy(labels);
+
+    rrdhost_system_info_free(si);
+}
