+    freez(value); value = NULL;
+
+    rrdlabels_get_value_strdup_or_null(labels, &value, "_install_type");
+    CHECK(value == NULL, "_install_type should be NULL (not set via set_by_name)");
+    freez(value);
+
+    rrdlabels_destroy(labels);
+    rrdhost_system_info_free(si);
+}
