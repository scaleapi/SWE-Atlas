+static void test_ml_capable_via_stream(void) {
+    fprintf(stderr, "\n--- test_ml_capable_via_stream ---\n");
+
+    struct rrdhost_system_info *si = rrdhost_system_info_create();
+
+    BUFFER *wb = buffer_create(1024, NULL);
+    rrdhost_system_info_to_url_encode_stream(wb, si);
+    CHECK(strstr(buffer_tostring(wb), "ml_capable=0") != NULL, "ml_capable should be 0 by default");
