+static void test_to_json_v1_populated(void) {
+    fprintf(stderr, "\n--- test_to_json_v1_populated ---\n");
+
+    struct rrdhost_system_info *si = rrdhost_system_info_create();
+    rrdhost_system_info_set_by_name(si, "NETDATA_HOST_OS_NAME", "Ubuntu");
+    rrdhost_system_info_set_by_name(si, "NETDATA_SYSTEM_ARCHITECTURE", "x86_64");
