+// TestNormalizeConfig_MergeBase tests that normalizeConfig properly finds
+// the merge base when both base and head are set.
+func TestNormalizeConfig_MergeBase(t *testing.T) {
+	t.Parallel()
+	ctx := context.Background()
+
+	// Clone a repo with branches for merge base testing
+	repoPath, repo, err := CloneRepoUsingUnauthenticated(ctx, "https://github.com/bill-rich/bad-secrets.git")
+	if err != nil {
+		t.Fatalf("failed to clone test repo: %v", err)
+	}
+	defer os.RemoveAll(repoPath)
+
+	t.Run("merge base should be found for divergent branches", func(t *testing.T) {
+		opts := &ScanOptions{
+			BaseHash: "master",
+			HeadHash: "some_branch",
+		}
+		err := normalizeConfig(opts, repo)
+		assert.NoError(t, err)
+		// BaseHash should now be the merge base commit hash
+		assert.Len(t, opts.BaseHash, 40, "BaseHash should be resolved to a 40-char hash")
+	})
+}
