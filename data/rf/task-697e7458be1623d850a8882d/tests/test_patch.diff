+// TestNormalizeConfig_BranchResolution tests that normalizeConfig properly resolves
+// branch names to commit hashes. This tests the behavior, not specific implementation.
+func TestNormalizeConfig_BranchResolution(t *testing.T) {
+	t.Parallel()
+	ctx := context.Background()
+
+	// Clone a test repo
+	repoPath, repo, err := CloneRepoUsingUnauthenticated(ctx, "https://github.com/dustin-decker/secretsandstuff.git")
+	if err != nil {
+		t.Fatalf("failed to clone test repo: %v", err)
+	}
+	defer os.RemoveAll(repoPath)
+
+	t.Run("branch names should be resolved to hashes", func(t *testing.T) {
+		opts := &ScanOptions{
+			BaseHash: "master",
+			HeadHash: "master",
+		}
+		err := normalizeConfig(opts, repo)
+		assert.NoError(t, err)
+		// After normalization, BaseHash should be a 40-char hex hash, not "master"
+		if opts.BaseHash == "master" {
+			t.Error("BaseHash was not resolved from branch name to hash")
+		}
+		if len(opts.BaseHash) != 40 {
+			t.Errorf("BaseHash should be a 40-char hash, got %d chars: %s", len(opts.BaseHash), opts.BaseHash)
+		}
+	})
+
+	t.Run("valid commit hashes should work", func(t *testing.T) {
+		const hash = "70001020fab32b1fcf2f1f0e5c66424eae649826"
+		opts := &ScanOptions{
+			BaseHash: hash,
+			HeadHash: hash,
+		}
+		err := normalizeConfig(opts, repo)
+		assert.NoError(t, err)
+		assert.Equal(t, hash, opts.BaseHash, "direct hash should be preserved")
+		assert.Equal(t, hash, opts.HeadHash, "direct hash should be preserved")
+	})
+
+	t.Run("empty options should not error", func(t *testing.T) {
+		opts := &ScanOptions{}
+		err := normalizeConfig(opts, repo)
+		assert.NoError(t, err)
+		assert.Empty(t, opts.BaseHash, "empty BaseHash should remain empty")
+		assert.Empty(t, opts.HeadHash, "empty HeadHash should remain empty")
+	})
+
+	t.Run("only base hash set should work", func(t *testing.T) {
+		const hash = "70001020fab32b1fcf2f1f0e5c66424eae649826"
+		opts := &ScanOptions{
+			BaseHash: hash,
+		}
+		err := normalizeConfig(opts, repo)
+		assert.NoError(t, err)
+		assert.Equal(t, hash, opts.BaseHash, "BaseHash should be preserved when head is absent")
+		assert.Empty(t, opts.HeadHash, "HeadHash should remain empty")
+	})
+
+	t.Run("only head hash set should work", func(t *testing.T) {
+		const hash = "70001020fab32b1fcf2f1f0e5c66424eae649826"
+		opts := &ScanOptions{
+			HeadHash: hash,
+		}
+		err := normalizeConfig(opts, repo)
+		assert.NoError(t, err)
+		assert.Equal(t, hash, opts.HeadHash, "HeadHash should be preserved when base is absent")
+		assert.Empty(t, opts.BaseHash, "BaseHash should remain empty")
+	})
+}
