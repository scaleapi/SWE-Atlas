+// TestScanRepo_WithRemote verifies that ScanRepo completes without error on a
+// repository that has a remote, exercising the remote URL logging path introduced
+// by the refactor (repoUrl → repoURL rename and multi-line log format).
+func TestScanRepo_WithRemote(t *testing.T) {
+	t.Parallel()
+	ctx := context.Background()
+
+	repoPath, repo, err := CloneRepoUsingUnauthenticated(ctx, "https://github.com/dustin-decker/secretsandstuff.git")
+	if err != nil {
+		t.Fatalf("failed to clone test repo: %v", err)
+	}
+	defer os.RemoveAll(repoPath)
+
+	s := &Git{}
+	// Scope the scan to a single known commit to keep the test fast.
+	scanOptions := &ScanOptions{
+		BaseHash: "70001020fab32b1fcf2f1f0e5c66424eae649826",
+		HeadHash: "70001020fab32b1fcf2f1f0e5c66424eae649826",
+	}
+	reporter := &sourcestest.TestReporter{}
+	err = s.ScanRepo(ctx, repo, repoPath, scanOptions, reporter)
+	assert.NoError(t, err, "ScanRepo should complete without error on a repo with a remote")
+}
