+// TestNormalizeConfig_ErrorHandling tests that normalizeConfig returns proper errors
+// for invalid inputs. This verifies the improved error handling requirement.
+func TestNormalizeConfig_ErrorHandling(t *testing.T) {
+	t.Parallel()
+	ctx := context.Background()
+
+	// Clone a test repo
+	repoPath, repo, err := CloneRepoUsingUnauthenticated(ctx, "https://github.com/dustin-decker/secretsandstuff.git")
+	if err != nil {
+		t.Fatalf("failed to clone test repo: %v", err)
+	}
+	defer os.RemoveAll(repoPath)
+
+	t.Run("invalid base ref should return error", func(t *testing.T) {
+		opts := &ScanOptions{
+			BaseHash: "nonexistent-branch-that-does-not-exist-xyz123",
+		}
+		err := normalizeConfig(opts, repo)
+		assert.Error(t, err, "should return error for invalid base ref")
+	})
+
+	t.Run("invalid head ref should return error", func(t *testing.T) {
+		opts := &ScanOptions{
+			HeadHash: "nonexistent-branch-that-does-not-exist-xyz123",
+		}
+		err := normalizeConfig(opts, repo)
+		assert.Error(t, err, "should return error for invalid head ref")
+	})
+
+	t.Run("nil repo should return error", func(t *testing.T) {
+		opts := &ScanOptions{
+			BaseHash: "master",
+		}
+		err := normalizeConfig(opts, nil)
+		assert.Error(t, err, "should return error for nil repo")
+	})
+}
