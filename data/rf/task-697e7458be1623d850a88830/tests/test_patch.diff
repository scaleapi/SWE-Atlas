+func TestFromData_ConcurrentResultsComplete(t *testing.T) {
+	ts := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		w.WriteHeader(http.StatusOK)
+	}))
+	defer ts.Close()
+
+	c := &customRegexWebhook{
+		&custom_detectorspb.CustomRegex{
+			Name:     "test",
+			Keywords: []string{"item"},
+			Regex:    map[string]string{"regex": `item\d`},
+			Verify: []*custom_detectorspb.VerifierConfig{
+				{Endpoint: ts.URL, Unsafe: true},
+			},
+		},
+	}
+
+	results, err := c.FromData(context.Background(), true, []byte("item1 item2 item3 item4 item5"))
+	assert.NoError(t, err)
+	assert.Equal(t, 5, len(results))
+
+	raws := make([]string, len(results))
+	for i, r := range results {
+		raws[i] = string(r.Raw)
+		assert.True(t, r.Verified)
+	}
+	assert.ElementsMatch(t, []string{"item1", "item2", "item3", "item4", "item5"}, raws)
+}
