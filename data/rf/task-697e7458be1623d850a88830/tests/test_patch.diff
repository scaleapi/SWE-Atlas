+func TestFromData_VerifyWebhookSuccess(t *testing.T) {
+	ts := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		w.WriteHeader(http.StatusOK)
+	}))
+	defer ts.Close()
+
+	c := &customRegexWebhook{
+		&custom_detectorspb.CustomRegex{
+			Name:     "test",
+			Keywords: []string{"password"},
+			Regex:    map[string]string{"regex": `password=\w+`},
+			Verify: []*custom_detectorspb.VerifierConfig{
+				{
+					Endpoint: ts.URL,
+					Unsafe:   true,
+					Headers:  []string{"Content-Type: application/json"},
+				},
+			},
+		},
+	}
+
+	results, err := c.FromData(context.Background(), true, []byte(`password=secret123`))
+	assert.NoError(t, err)
+	assert.Equal(t, 1, len(results))
+	assert.True(t, results[0].Verified)
+}
