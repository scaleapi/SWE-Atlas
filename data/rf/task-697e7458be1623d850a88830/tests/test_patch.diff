+func TestFromData_VerifyMultipleEndpoints(t *testing.T) {
+	failServer := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		w.WriteHeader(http.StatusInternalServerError)
+	}))
+	defer failServer.Close()
+
+	successServer := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		w.WriteHeader(http.StatusOK)
+	}))
+	defer successServer.Close()
+
+	c := &customRegexWebhook{
+		&custom_detectorspb.CustomRegex{
+			Name:     "test",
+			Keywords: []string{"token"},
+			Regex:    map[string]string{"regex": `token_\w+`},
+			Verify: []*custom_detectorspb.VerifierConfig{
+				{Endpoint: failServer.URL, Unsafe: true},
+				{Endpoint: successServer.URL, Unsafe: true},
+			},
+		},
+	}
+
+	results, err := c.FromData(context.Background(), true, []byte("token_xyz"))
+	assert.NoError(t, err)
+	assert.Equal(t, 1, len(results))
+	assert.True(t, results[0].Verified)
+}
