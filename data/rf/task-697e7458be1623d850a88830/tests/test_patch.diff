+func TestFromData_VerifyHeadersForwarded(t *testing.T) {
+	var receivedAuth string
+	ts := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		receivedAuth = r.Header.Get("Authorization")
+		w.WriteHeader(http.StatusOK)
+	}))
+	defer ts.Close()
+
+	c := &customRegexWebhook{
+		&custom_detectorspb.CustomRegex{
+			Name:     "test",
+			Keywords: []string{"key"},
+			Regex:    map[string]string{"regex": `key_\w+`},
+			Verify: []*custom_detectorspb.VerifierConfig{
+				{
+					Endpoint: ts.URL,
+					Unsafe:   true,
+					Headers:  []string{"Authorization: Bearer testtoken123"},
+				},
+			},
+		},
+	}
+
+	results, err := c.FromData(context.Background(), true, []byte("key_abc"))
+	assert.NoError(t, err)
+	assert.Equal(t, 1, len(results))
+	assert.Equal(t, "Bearer testtoken123", receivedAuth)
+}
