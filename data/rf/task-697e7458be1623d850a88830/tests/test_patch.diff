+func TestFromData_MultipleMatches_NoVerify(t *testing.T) {
+	c := &customRegexWebhook{
+		&custom_detectorspb.CustomRegex{
+			Name:     "test",
+			Keywords: []string{"password"},
+			Regex:    map[string]string{"regex": `password\d`},
+		},
+	}
+
+	results, err := c.FromData(context.Background(), false, []byte("password1 password2 password3"))
+	assert.NoError(t, err)
+	assert.Equal(t, 3, len(results))
+	for _, r := range results {
+		assert.False(t, r.Verified)
+	}
+}
+
+func TestFromData_CancelledContext(t *testing.T) {
+	c := &customRegexWebhook{
+		&custom_detectorspb.CustomRegex{
+			Name:     "test",
+			Keywords: []string{"password"},
+			Regex:    map[string]string{"regex": `password\d`},
+		},
+	}
+
+	ctx, cancel := context.WithCancel(context.Background())
+	cancel()
+
+	results, err := c.FromData(ctx, false, []byte("password1 password2"))
+	if err != nil {
+		// Any error is acceptable when context is already cancelled.
+		return
+	}
+	// If no error, partial or empty results are acceptable.
+	assert.LessOrEqual(t, len(results), 2)
+}
