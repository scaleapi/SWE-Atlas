diff --git a/pkg/engine/ahocorasickcore_test.go b/pkg/engine/ahocorasickcore_test.go
new file mode 100644
index 000000000..000000001
--- /dev/null
+++ b/pkg/engine/ahocorasickcore_test.go
@@ -0,0 +1,155 @@
+package engine
+
+import (
+	"context"
+	"testing"
+
+	"github.com/stretchr/testify/assert"
+
+	"github.com/trufflesecurity/trufflehog/v3/pkg/detectors"
+	"github.com/trufflesecurity/trufflehog/v3/pkg/pb/detectorspb"
+)
+
+type stubDetector struct {
+	detectorType detectorspb.DetectorType
+	keywords     []string
+}
+
+func (d *stubDetector) FromData(ctx context.Context, verify bool, data []byte) ([]detectors.Result, error) {
+	return nil, nil
+}
+func (d *stubDetector) Keywords() []string              { return d.keywords }
+func (d *stubDetector) Type() detectorspb.DetectorType { return d.detectorType }
+
+func TestNewAhoCorasickCore_AcceptsFlatSlice(t *testing.T) {
+	t.Parallel()
+	d1 := &stubDetector{detectorType: detectorspb.DetectorType_AWS, keywords: []string{"aws_access_key"}}
+	d2 := &stubDetector{detectorType: detectorspb.DetectorType_Github, keywords: []string{"ghp_"}}
+
+	ac := NewAhoCorasickCore([]detectors.Detector{d1, d2})
+	assert.NotNil(t, ac)
+
+	matches := ac.MatchString("contains aws_access_key and ghp_ tokens")
+	assert.GreaterOrEqual(t, len(matches), 2, "expected at least 2 keyword matches")
+}
+
+func TestNewAhoCorasickCore_EmptySlice(t *testing.T) {
+	t.Parallel()
+	ac := NewAhoCorasickCore([]detectors.Detector{})
+	assert.NotNil(t, ac)
+
+	matches := ac.MatchString("nothing to match here")
+	assert.Empty(t, matches)
+}
+
+func TestPopulateDetectorsByMatch_ReturnsDetectorDirectly(t *testing.T) {
+	t.Parallel()
+	d := &stubDetector{detectorType: detectorspb.DetectorType_AWS, keywords: []string{"aws"}}
+	ac := NewAhoCorasickCore([]detectors.Detector{d})
+
+	matches := ac.MatchString("aws")
+	assert.NotEmpty(t, matches, "expected at least one match for keyword 'aws'")
+
+	detectorMap := make(map[detectorspb.DetectorType]detectors.Detector)
+	found := ac.PopulateDetectorsByMatch(matches[0], detectorMap)
+
+	assert.True(t, found)
+	assert.Len(t, detectorMap, 1)
+	assert.Equal(t, detectorspb.DetectorType_AWS, detectorMap[detectorspb.DetectorType_AWS].Type())
+}
+
+func TestPopulateDetectorsByMatch_NoMatch(t *testing.T) {
+	t.Parallel()
+	d := &stubDetector{detectorType: detectorspb.DetectorType_AWS, keywords: []string{"aws"}}
+	ac := NewAhoCorasickCore([]detectors.Detector{d})
+
+	matches := ac.MatchString("nothing relevant here")
+	assert.Empty(t, matches)
+}
+
+func TestPopulateDetectorsByMatch_MultipleDetectorsSameKeyword(t *testing.T) {
+	t.Parallel()
+	d1 := &stubDetector{detectorType: detectorspb.DetectorType_AWS, keywords: []string{"token"}}
+	d2 := &stubDetector{detectorType: detectorspb.DetectorType_Github, keywords: []string{"token"}}
+	ac := NewAhoCorasickCore([]detectors.Detector{d1, d2})
+
+	matches := ac.MatchString("my token here")
+	assert.NotEmpty(t, matches)
+
+	detectorMap := make(map[detectorspb.DetectorType]detectors.Detector)
+	found := ac.PopulateDetectorsByMatch(matches[0], detectorMap)
+
+	assert.True(t, found)
+	assert.Len(t, detectorMap, 2)
+	assert.NotNil(t, detectorMap[detectorspb.DetectorType_AWS])
+	assert.NotNil(t, detectorMap[detectorspb.DetectorType_Github])
+}
+
+func TestWithDetectors_AppendsToFlatList(t *testing.T) {
+	t.Parallel()
+	e := &Engine{}
+	d1 := &stubDetector{detectorType: detectorspb.DetectorType_AWS, keywords: []string{"aws"}}
+	d2 := &stubDetector{detectorType: detectorspb.DetectorType_Github, keywords: []string{"github"}}
+
+	WithDetectors(d1)(e)
+	WithDetectors(d2)(e)
+
+	assert.Len(t, e.detectors, 2)
+}
+
+func TestWithDetectors_MultipleInSingleCall(t *testing.T) {
+	t.Parallel()
+	e := &Engine{}
+	d1 := &stubDetector{detectorType: detectorspb.DetectorType_AWS, keywords: []string{"aws"}}
+	d2 := &stubDetector{detectorType: detectorspb.DetectorType_Github, keywords: []string{"github"}}
+
+	WithDetectors(d1, d2)(e)
+
+	assert.Len(t, e.detectors, 2)
+}
+
+func TestWithVerify_SetsFlag(t *testing.T) {
+	t.Parallel()
+	e := &Engine{}
+
+	WithVerify(true)(e)
+	assert.True(t, e.verify)
+
+	WithVerify(false)(e)
+	assert.False(t, e.verify)
+}
+
+func TestWithFilterDetectors_FiltersSlice(t *testing.T) {
+	t.Parallel()
+	e := &Engine{}
+	d1 := &stubDetector{detectorType: detectorspb.DetectorType_AWS, keywords: []string{"aws"}}
+	d2 := &stubDetector{detectorType: detectorspb.DetectorType_Github, keywords: []string{"github"}}
+	d3 := &stubDetector{detectorType: detectorspb.DetectorType_Gitlab, keywords: []string{"gitlab"}}
+
+	WithDetectors(d1, d2, d3)(e)
+	assert.Len(t, e.detectors, 3)
+
+	filterFunc := func(d detectors.Detector) bool {
+		return d.Type() != detectorspb.DetectorType_Github
+	}
+	WithFilterDetectors(filterFunc)(e)
+
+	assert.Len(t, e.detectors, 2)
+	for _, d := range e.detectors {
+		assert.NotEqual(t, detectorspb.DetectorType_Github, d.Type())
+	}
+}
+
+func TestCoreIntegration_MatchAndPopulate(t *testing.T) {
+	t.Parallel()
+	d := &stubDetector{detectorType: detectorspb.DetectorType_AWS, keywords: []string{"AKIA"}}
+	ac := NewAhoCorasickCore([]detectors.Detector{d})
+
+	detectorMap := make(map[detectorspb.DetectorType]detectors.Detector)
+	for _, match := range ac.MatchString("found AKIA1234567890 in data") {
+		ac.PopulateDetectorsByMatch(match, detectorMap)
+	}
+
+	assert.Len(t, detectorMap, 1)
+	assert.Equal(t, detectorspb.DetectorType_AWS, detectorMap[detectorspb.DetectorType_AWS].Type())
+}
