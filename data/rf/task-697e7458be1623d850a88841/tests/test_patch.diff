@@ -0,0 +1,24 @@
+package source_select
+
+import (
+	"testing"
+
+	"github.com/stretchr/testify/assert"
+	"github.com/trufflesecurity/trufflehog/v3/pkg/tui/common"
+)
+
+func TestNew_IncludesAzureRepos(t *testing.T) {
+	c := common.Common{}
+	ss := New(c)
+	items := ss.sourcesList.Items()
+
+	found := false
+	for _, item := range items {
+		if si, ok := item.(SourceItem); ok && si.title == "Azure Repos" {
+			found = true
+			assert.True(t, si.enterprise, "Azure Repos should be an enterprise source")
+			break
+		}
+	}
+	assert.True(t, found, "Azure Repos should be in the source list")
+}
