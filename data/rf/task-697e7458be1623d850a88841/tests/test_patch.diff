+package common
+
+import (
+	"testing"
+
+	"github.com/stretchr/testify/assert"
+	"github.com/trufflesecurity/trufflehog/v3/pkg/tui/components/textinputs"
+)
+
+func TestSummarizeSource_AcceptsInputStructMap(t *testing.T) {
+	keys := []string{"key1"}
+	inputs := map[string]textinputs.Input{
+		"key1": {Value: "value1", IsDefault: false},
+	}
+	labels := map[string]string{
+		"key1": "Label 1",
+	}
+
+	result := SummarizeSource(keys, inputs, labels)
+
+	assert.Contains(t, result, "value1")
+}
+
+func TestSummarizeSource_IncludesNonEmptyValues(t *testing.T) {
+	keys := []string{"key1", "key2"}
+	inputs := map[string]textinputs.Input{
+		"key1": {Value: "value1"},
+		"key2": {Value: "value2"},
+	}
+	labels := map[string]string{
+		"key1": "Label 1",
+		"key2": "Label 2",
+	}
+
+	result := SummarizeSource(keys, inputs, labels)
+
+	assert.Contains(t, result, "value1")
+	assert.Contains(t, result, "value2")
+}
+
+func TestSummarizeSource_SkipsEmptyValues(t *testing.T) {
+	keys := []string{"key1", "key2"}
+	inputs := map[string]textinputs.Input{
+		"key1": {Value: "value1"},
+		"key2": {Value: ""},
+	}
+	labels := map[string]string{
+		"key1": "Label 1",
+		"key2": "Label 2",
+	}
+
+	result := SummarizeSource(keys, inputs, labels)
+
+	assert.Contains(t, result, "value1")
+	assert.NotContains(t, result, "Label 2")
+}
