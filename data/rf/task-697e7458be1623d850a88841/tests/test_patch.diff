+
+	org, orgExists := inputs["org"]
+	repo, repoExists := inputs["repo"]
+	assert.True(t, orgExists, "org should be present when both are default")
+	assert.True(t, repoExists, "repo should be present when both are default")
+	assert.NotEmpty(t, org.Value, "org should have non-empty default value")
+	assert.NotEmpty(t, repo.Value, "repo should have non-empty default value")
