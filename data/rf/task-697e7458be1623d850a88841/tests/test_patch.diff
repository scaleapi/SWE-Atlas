+	repo, repoExists := inputs["repo"]
+	assert.True(t, repoExists, "should have 'repo' key")
+	assert.True(t, repo.IsDefault, "repo should be required and default when empty")
+	assert.NotEmpty(t, repo.Value, "repo should have non-empty default value")
