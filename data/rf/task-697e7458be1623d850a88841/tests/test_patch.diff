+package textinputs
+
+import (
+	"testing"
+
+	"github.com/stretchr/testify/assert"
+)
+
+func TestInput_HasValueAndIsDefaultFields(t *testing.T) {
+	input := Input{
+		Value:     "test-value",
+		IsDefault: true,
+	}
+	assert.Equal(t, "test-value", input.Value)
+	assert.True(t, input.IsDefault)
+}
+
+func TestGetInputs_RequiredEmptyField_UsesPlaceholderAndSetsIsDefault(t *testing.T) {
+	config := []InputConfig{
+		{
+			Key:         "required_key",
+			Required:    true,
+			Placeholder: "default-value",
+		},
+	}
+	model := New(config)
+
+	inputs := model.GetInputs()
+
+	assert.Equal(t, "default-value", inputs["required_key"].Value)
+	assert.True(t, inputs["required_key"].IsDefault)
+}
+
+func TestGetInputs_NonRequiredEmptyField_RemainsEmptyWithIsDefaultFalse(t *testing.T) {
+	config := []InputConfig{
+		{
+			Key:         "optional_key",
+			Required:    false,
+			Placeholder: "placeholder",
+		},
+	}
+	model := New(config)
+
+	inputs := model.GetInputs()
+
+	assert.Equal(t, "", inputs["optional_key"].Value)
+	assert.False(t, inputs["optional_key"].IsDefault)
+}
+
+func TestGetInputs_MixedRequiredAndOptional(t *testing.T) {
+	config := []InputConfig{
+		{Key: "required", Required: true, Placeholder: "req-default"},
+		{Key: "optional", Required: false, Placeholder: "opt-placeholder"},
+	}
+	model := New(config)
+
+	inputs := model.GetInputs()
+
+	assert.Equal(t, "req-default", inputs["required"].Value)
+	assert.True(t, inputs["required"].IsDefault)
+	assert.Equal(t, "", inputs["optional"].Value)
+	assert.False(t, inputs["optional"].IsDefault)
+}
