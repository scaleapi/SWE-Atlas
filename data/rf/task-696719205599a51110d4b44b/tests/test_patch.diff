diff --git a/lib/testutils/logrus_hook_test.go b/lib/testutils/logrus_hook_test.go
new file mode 100644
index 000000000..4805475c8
--- /dev/null
+++ b/lib/testutils/logrus_hook_test.go
@@ -0,0 +1,119 @@
+package testutils
+
+import (
+	"testing"
+
+	"github.com/sirupsen/logrus"
+	"github.com/stretchr/testify/assert"
+	"github.com/stretchr/testify/require"
+)
+
+func TestNewLogHookDefaultLevels(t *testing.T) {
+	hook := NewLogHook()
+	assert.Equal(t, logrus.AllLevels, hook.HookedLevels)
+}
+
+func TestNewLogHookSpecificLevels(t *testing.T) {
+	hook := NewLogHook(logrus.WarnLevel, logrus.ErrorLevel)
+	assert.Equal(t, []logrus.Level{logrus.WarnLevel, logrus.ErrorLevel}, hook.HookedLevels)
+}
+
+func TestSimpleLogrusHookLastEntryEmpty(t *testing.T) {
+	hook := NewLogHook()
+	assert.Nil(t, hook.LastEntry())
+}
+
+func TestSimpleLogrusHookLastEntry(t *testing.T) {
+	hook := NewLogHook()
+	logger := logrus.New()
+	logger.AddHook(hook)
+	logger.SetOutput(&testOutput{t})
+
+	logger.Warn("first message")
+	logger.Error("second message")
+
+	entry := hook.LastEntry()
+	require.NotNil(t, entry)
+	assert.Equal(t, "second message", entry.Message)
+	assert.Equal(t, logrus.ErrorLevel, entry.Level)
+}
+
+func TestSimpleLogrusHookReset(t *testing.T) {
+	hook := NewLogHook()
+	logger := logrus.New()
+	logger.AddHook(hook)
+	logger.SetOutput(&testOutput{t})
+
+	logger.Warn("a message")
+	require.NotNil(t, hook.LastEntry())
+
+	hook.Reset()
+	assert.Nil(t, hook.LastEntry())
+}
+
+func TestSimpleLogrusHookDrainAfterReset(t *testing.T) {
+	hook := NewLogHook()
+	logger := logrus.New()
+	logger.AddHook(hook)
+	logger.SetOutput(&testOutput{t})
+
+	logger.Warn("msg1")
+	logger.Error("msg2")
+	hook.Reset()
+
+	entries := hook.Drain()
+	assert.Empty(t, entries)
+}
+
+func TestNewLoggerReturnsFieldLogger(t *testing.T) {
+	logger := NewLogger(t)
+	require.NotNil(t, logger)
+
+	var fl logrus.FieldLogger = logger
+	assert.NotNil(t, fl)
+}
+
+func TestNewLoggerNilTB(t *testing.T) {
+	logger := NewLogger(nil)
+	require.NotNil(t, logger)
+}
+
+func TestNewLoggerWithHookDefaultLevels(t *testing.T) {
+	logger, hook := NewLoggerWithHook(t)
+	require.NotNil(t, logger)
+	require.NotNil(t, hook)
+	assert.Equal(t, logrus.AllLevels, hook.HookedLevels)
+}
+
+func TestNewLoggerWithHookSpecificLevels(t *testing.T) {
+	logger, hook := NewLoggerWithHook(t, logrus.WarnLevel, logrus.ErrorLevel)
+	require.NotNil(t, logger)
+	require.NotNil(t, hook)
+	assert.Equal(t, []logrus.Level{logrus.WarnLevel, logrus.ErrorLevel}, hook.HookedLevels)
+
+	logger.WithField("key", "val").Warn("test warn")
+	entry := hook.LastEntry()
+	require.NotNil(t, entry)
+	assert.Equal(t, logrus.WarnLevel, entry.Level)
+}
+
+func TestNewLoggerWithHookNilTB(t *testing.T) {
+	logger, hook := NewLoggerWithHook(nil)
+	require.NotNil(t, logger)
+	require.NotNil(t, hook)
+
+	logger.WithField("k", "v").Info("discarded msg")
+	assert.NotNil(t, hook.LastEntry())
+}
+
+func TestNewLoggerWithHookCapturesAtCorrectLevel(t *testing.T) {
+	logger, hook := NewLoggerWithHook(t, logrus.ErrorLevel)
+
+	logger.WithField("k", "v").Info("should not be captured")
+	assert.Nil(t, hook.LastEntry())
+
+	logger.WithField("k", "v").Error("should be captured")
+	entry := hook.LastEntry()
+	require.NotNil(t, entry)
+	assert.Equal(t, logrus.ErrorLevel, entry.Level)
+}
