+= AutoTime inherits from RandNum
+from scapy.volatile import AutoTime, RandNum
+assert issubclass(AutoTime, RandNum)
+
+= AutoTime default initialization
+import time
+at = AutoTime()
+fixed = at._fix()
+assert isinstance(fixed, float)
+assert abs(fixed - time.time()) < 1
+
+= AutoTime with base time
+import time
+base_time = time.time() - 100
+at = AutoTime(base=base_time)
+fixed = at._fix()
+assert abs(fixed - base_time) < 1
+
+= AutoTime repr does not crash
+at = AutoTime()
+r = repr(at)
+assert r is not None
+
+= IntAutoTime returns integer
+from scapy.volatile import IntAutoTime
+import time
+iat = IntAutoTime()
+fixed = iat._fix()
+assert isinstance(fixed, int)
+assert abs(fixed - int(time.time())) < 2
+
