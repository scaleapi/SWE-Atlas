+//! Tests for filecontainer module refactoring.
+//! Validates direct FFI calls replace the old SuricataContext vtable indirection.
+
+#[cfg(test)]
+mod tests {
+    use crate::filecontainer::FileContainer;
+    use crate::core::{StreamingBufferConfig, SuricataFileContext};
+    use std::ptr::NonNull;
+
+    /// Creates a test-only SuricataFileContext with a synthetic static lifetime.
+    /// StreamingBufferConfig is an opaque FFI type; the #[cfg(test)] stubs
+    /// never dereference it, so a dangling pointer is safe in this context.
+    fn make_test_cfg() -> &'static SuricataFileContext {
+        let sbcfg: &'static StreamingBufferConfig = unsafe {
+            &*(NonNull::<StreamingBufferConfig>::dangling().as_ptr())
+        };
+        Box::leak(Box::new(SuricataFileContext { files_sbcfg: sbcfg }))
+    }
+
+    #[test]
+    fn test_file_container_default() {
+        let fc = FileContainer::default();
+        let _ = format!("{:?}", fc);
+    }
+
+    #[test]
+    fn test_file_container_default_debug_format() {
+        let fc = FileContainer::default();
+        let debug_str = format!("{:?}", fc);
+        assert!(debug_str.contains("FileContainer"));
+        assert!(debug_str.contains("head"));
+        assert!(debug_str.contains("tail"));
+    }
+
+    #[test]
+    fn test_file_container_free() {
+        let mut fc = FileContainer::default();
+        let cfg = make_test_cfg();
+        fc.free(cfg);
+    }
+
+    #[test]
+    fn test_file_container_file_open() {
+        let mut fc = FileContainer::default();
+        let cfg = make_test_cfg();
+        let result = fc.file_open(cfg, 1, b"test_file.txt", 0);
+        assert_eq!(result, 0);
+    }
+
+    #[test]
+    fn test_file_container_file_open_with_flags() {
+        let mut fc = FileContainer::default();
+        let cfg = make_test_cfg();
+        let result = fc.file_open(cfg, 1, b"flagged_file.txt", 0x0001);
+        assert_eq!(result, 0);
+    }
+
+    #[test]
+    fn test_file_container_file_append_data() {
+        let mut fc = FileContainer::default();
+        let cfg = make_test_cfg();
+        let track_id: u32 = 1;
+        let result = fc.file_append(cfg, &track_id, b"hello world", false);
+        assert_eq!(result, 0);
+    }
+
+    #[test]
+    fn test_file_container_file_append_gap() {
+        let mut fc = FileContainer::default();
+        let cfg = make_test_cfg();
+        let track_id: u32 = 1;
+        let result = fc.file_append(cfg, &track_id, b"gap data", true);
+        assert_eq!(result, 0);
+    }
+
+    #[test]
+    fn test_file_container_file_append_empty_data() {
+        let mut fc = FileContainer::default();
+        let cfg = make_test_cfg();
+        let track_id: u32 = 1;
+        let result = fc.file_append(cfg, &track_id, b"", false);
+        assert_eq!(result, 0);
+    }
+
+    #[test]
+    fn test_file_container_file_append_empty_gap() {
+        let mut fc = FileContainer::default();
+        let cfg = make_test_cfg();
+        let track_id: u32 = 1;
+        let result = fc.file_append(cfg, &track_id, b"", true);
+        assert_eq!(result, 0);
+    }
+
+    #[test]
+    fn test_file_container_file_close() {
+        let mut fc = FileContainer::default();
+        let cfg = make_test_cfg();
+        let track_id: u32 = 1;
+        let result = fc.file_close(cfg, &track_id, 0);
+        assert_eq!(result, 0);
+    }
+
+    #[test]
+    fn test_file_container_file_close_with_flags() {
+        let mut fc = FileContainer::default();
+        let cfg = make_test_cfg();
+        let track_id: u32 = 1;
+        let result = fc.file_close(cfg, &track_id, 0x0001);
+        assert_eq!(result, 0);
+    }
+
+    #[test]
+    fn test_file_container_full_lifecycle() {
+        let mut fc = FileContainer::default();
+        let cfg = make_test_cfg();
+        let track_id: u32 = 42;
+
+        let open_result = fc.file_open(cfg, track_id, b"lifecycle_test.bin", 0);
+        assert_eq!(open_result, 0);
+
+        let append_result = fc.file_append(cfg, &track_id, b"file content", false);
+        assert_eq!(append_result, 0);
+
+        let gap_result = fc.file_append(cfg, &track_id, b"gap segment", true);
+        assert_eq!(gap_result, 0);
+
+        let close_result = fc.file_close(cfg, &track_id, 0);
+        assert_eq!(close_result, 0);
+
+        fc.free(cfg);
+    }
+}
